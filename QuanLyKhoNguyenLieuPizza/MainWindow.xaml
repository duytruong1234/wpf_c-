<Window x:Class="QuanLyKhoNguyenLieuPizza.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyKhoNguyenLieuPizza"
        xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
        mc:Ignorable="d"
        Title="Quan Ly Kho Nguyen Lieu Pizza" 
        Height="750" 
        Width="1200"
        MinHeight="700"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ResizeMode="CanResize">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <ContentControl Content="{Binding CurrentView}"/>
    </Grid>
</Window>
