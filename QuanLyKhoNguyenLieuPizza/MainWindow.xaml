<Window x:Class="QuanLyKhoNguyenLieuPizza.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuanLyKhoNguyenLieuPizza"
        xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Quản Lý Kho Nguyên Liệu Pizza" 
        Height="750" 
        Width="1200"
        MinHeight="700"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Icon="Resources/Images/app.ico">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Tiêu đề Bar Button Style -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Nút Kiểu -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FECACA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <!-- Outer border with rounded corners and shadow -->
    <Border x:Name="WindowBorder" Background="#F8FAFC" CornerRadius="20" 
            BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" 
                              Color="#000000" Opacity="0.14"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Tiêu đề Bar -->
            <Border Grid.Row="0" CornerRadius="20,20,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FAFBFF" Offset="0.5"/>
                        <GradientStop Color="#F8FAFC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <!-- Bottom border line -->
                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- App Tiêu đề Area -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" 
                                    Margin="16,0,0,0">
                            <!-- Pizza icon -->
                            <Border Width="28" Height="28" CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E85D04" Offset="0"/>
                                        <GradientStop Color="#F48C06" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="FoodPizza24" FontSize="14" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PizzaInn Warehouse" 
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#475569"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                            <TextBlock Text="•" Foreground="#CBD5E1" Margin="8,0" 
                                       VerticalAlignment="Center" FontSize="10"/>
                            <TextBlock Text="Quản lý kho nguyên liệu" 
                                       FontSize="11" Foreground="#94A3B8"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Window Control Nút Hành động -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                    VerticalAlignment="Center" Margin="0,0,10,0">
                            <!-- Minimize -->
                            <Button Style="{StaticResource TitleBarButton}" 
                                    Click="MinimizeButton_Click" ToolTip="Thu nhỏ">
                                <Path Data="M4,12 L20,12" Stroke="#64748B" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="12" Height="12" Stretch="Uniform"/>
                            </Button>
                            <!-- Maximize/Restore -->
                            <Button Style="{StaticResource TitleBarButton}" 
                                    Click="MaximizeButton_Click" ToolTip="Phóng to"
                                    Margin="4,0">
                                <Path x:Name="MaximizeIcon" 
                                      Data="M4,4 L20,4 L20,20 L4,20 Z" 
                                      Stroke="#64748B" StrokeThickness="1.5" Fill="Transparent"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="11" Height="11" Stretch="Uniform"/>
                            </Button>
                            <!-- Close -->
                            <Button Style="{StaticResource CloseButton}" 
                                    Click="CloseButton_Click" ToolTip="Đóng">
                                <Path Data="M6,6 L18,18 M18,6 L6,18" Stroke="#EF4444" StrokeThickness="1.5"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Width="11" Height="11" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>

            <!-- Nội dung Chính Area -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Border>
</Window>
