<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- ████████  PIZZA WAREHOUSE - UNIFIED DESIGN SYSTEM  ████████  -->
    <!-- ══════════════════════════════════════════════════════════════ -->

    <!-- ==================== BRAND COLORS (Pizza Warm) ==================== -->
    <Color x:Key="PizzaRedColor">#C0392B</Color>
    <Color x:Key="PizzaRedDarkColor">#A93226</Color>
    <Color x:Key="PizzaRedLightColor">#E74C3C</Color>
    <Color x:Key="CheeseYellowColor">#F1C40F</Color>
    <Color x:Key="CheeseYellowDarkColor">#D4AC0D</Color>
    <Color x:Key="WarmOrangeColor">#E67E22</Color>
    <Color x:Key="CrustBrownColor">#D35400</Color>
    
    <SolidColorBrush x:Key="PizzaRedBrush" Color="{StaticResource PizzaRedColor}"/>
    <SolidColorBrush x:Key="PizzaRedDarkBrush" Color="{StaticResource PizzaRedDarkColor}"/>
    <SolidColorBrush x:Key="PizzaRedLightBrush" Color="{StaticResource PizzaRedLightColor}"/>
    <SolidColorBrush x:Key="CheeseYellowBrush" Color="{StaticResource CheeseYellowColor}"/>
    <SolidColorBrush x:Key="CheeseYellowDarkBrush" Color="{StaticResource CheeseYellowDarkColor}"/>
    <SolidColorBrush x:Key="WarmOrangeBrush" Color="{StaticResource WarmOrangeColor}"/>
    <SolidColorBrush x:Key="CrustBrownBrush" Color="{StaticResource CrustBrownColor}"/>

    <!-- ==================== ACTION COLORS (Modern Indigo) ==================== -->
    <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
    <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
    <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
    <SolidColorBrush x:Key="PrimaryGreen" Color="#22C55E"/>
    <SolidColorBrush x:Key="DarkGreen" Color="#16A34A"/>

    <!-- ==================== STATUS COLORS ==================== -->
    <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>
    <SolidColorBrush x:Key="SuccessGreenLight" Color="#F0FDF4"/>
    <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
    <SolidColorBrush x:Key="WarningOrangeLight" Color="#FFFBEB"/>
    <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerRedLight" Color="#FEF2F2"/>
    <SolidColorBrush x:Key="InfoCyan" Color="#06B6D4"/>
    <SolidColorBrush x:Key="InfoCyanLight" Color="#ECFEFF"/>
    
    <Color x:Key="SuccessGreenColor">#27AE60</Color>
    <Color x:Key="WarningAmberColor">#F39C12</Color>
    <Color x:Key="DangerRedColor">#E74C3C</Color>
    <Color x:Key="InfoBlueColor">#3498DB</Color>
    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="WarningAmberBrush" Color="{StaticResource WarningAmberColor}"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRedColor}"/>
    <SolidColorBrush x:Key="InfoBlueBrush" Color="{StaticResource InfoBlueColor}"/>

    <!-- ==================== NEUTRAL GRAY SCALE ==================== -->
    <Color x:Key="SoftWhiteColor">#F8F9FA</Color>
    <Color x:Key="CardWhiteColor">#FFFFFF</Color>
    <Color x:Key="DarkTextColor">#2C3E50</Color>
    <Color x:Key="SubTextColor">#7F8C8D</Color>
    <Color x:Key="BorderLightColor">#ECF0F1</Color>

    <SolidColorBrush x:Key="SoftWhiteBrush" Color="{StaticResource SoftWhiteColor}"/>
    <SolidColorBrush x:Key="CardWhiteBrush" Color="{StaticResource CardWhiteColor}"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="{StaticResource DarkTextColor}"/>
    <SolidColorBrush x:Key="SubTextBrush" Color="{StaticResource SubTextColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>

    <!-- Slate gray shades (used across all views) -->
    <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
    <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
    <SolidColorBrush x:Key="Gray600" Color="#475569"/>
    <SolidColorBrush x:Key="Gray700" Color="#334155"/>
    <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
    <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

    <!-- ==================== GRADIENT BRUSHES ==================== -->
    <LinearGradientBrush x:Key="PizzaRedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PizzaRedColor}" Offset="0"/>
        <GradientStop Color="{StaticResource PizzaRedDarkColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="CheeseGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource CheeseYellowColor}" Offset="0"/>
        <GradientStop Color="{StaticResource CheeseYellowDarkColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="WarmGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource WarmOrangeColor}" Offset="0"/>
        <GradientStop Color="{StaticResource CrustBrownColor}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1F2937" Offset="0"/>
        <GradientStop Color="#111827" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#5B6AFF" Offset="0"/>
        <GradientStop Color="#818CF8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#27AE60" Offset="0"/>
        <GradientStop Color="#2ECC71" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E85D04" Offset="0"/>
        <GradientStop Color="#F48C06" Offset="0.5"/>
        <GradientStop Color="#FFBA08" Offset="1"/>
    </LinearGradientBrush>

    <!-- ==================== SHADOW EFFECTS ==================== -->
    <DropShadowEffect x:Key="CardShadowDeep" 
                      BlurRadius="30" ShadowDepth="8" Direction="270" 
                      Color="#000000" Opacity="0.12"/>
    
    <DropShadowEffect x:Key="CardShadowMedium" 
                      BlurRadius="20" ShadowDepth="4" Direction="270" 
                      Color="#000000" Opacity="0.08"/>
    
    <DropShadowEffect x:Key="CardShadowLight" 
                      BlurRadius="10" ShadowDepth="2" Direction="270" 
                      Color="#000000" Opacity="0.05"/>
    
    <DropShadowEffect x:Key="ButtonHoverShadow" 
                      BlurRadius="15" ShadowDepth="3" Direction="270" 
                      Color="{StaticResource PizzaRedColor}" Opacity="0.3"/>

    <!-- ==================== MODERN CARD STYLES ==================== -->
    <Style x:Key="PizzaCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardWhiteBrush}"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Effect" Value="{StaticResource CardShadowMedium}"/>
    </Style>
    
    <Style x:Key="StatsCardModern" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardWhiteBrush}"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Effect" Value="{StaticResource CardShadowDeep}"/>
    </Style>

    <!-- Unified Card Style (used in dashboard, tonkho, nguyenlieu, etc.) -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Material Card with Hover Effect -->
    <Style x:Key="MaterialCard" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.12"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== MODERN BUTTON STYLES ==================== -->
    <!-- Primary Blue Button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlue}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="-1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary Button (Gray) -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Gray100}"/>
        <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Outline Button -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon Button (small, transparent) -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource DangerRed}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#EF4444" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Success Button -->
    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource DarkGreen}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#22C55E" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Pizza Brand Primary Button -->
    <Style x:Key="PizzaPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PizzaRedGradient}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="24,14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="15"
                            Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource CardShadowLight}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ButtonHoverShadow}"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="-2"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            <Setter TargetName="border" Property="RenderTransform">
                                <Setter.Value>
                                    <TranslateTransform Y="0"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="PizzaSecondaryButton" TargetType="Button" BasedOn="{StaticResource PizzaPrimaryButton}">
        <Setter Property="Background" Value="{StaticResource CheeseGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
    </Style>
    
    <Style x:Key="PizzaOutlineButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource PizzaRedBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{StaticResource PizzaRedBrush}"
                            BorderThickness="2"
                            CornerRadius="15"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PizzaRedBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Filter Chip Base -->
    <Style x:Key="FilterChipBase" TargetType="Button">
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ==================== MODERN COMBOBOX STYLE ==================== -->
    <ControlTemplate x:Key="PizzaComboBoxToggleButton" TargetType="ToggleButton">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" 
                    Grid.ColumnSpan="2" 
                    Background="{StaticResource SoftWhiteBrush}" 
                    BorderBrush="{StaticResource BorderLightBrush}" 
                    BorderThickness="1" 
                    CornerRadius="12"/>
            <Path x:Name="Arrow" 
                  Grid.Column="1" 
                  Fill="{StaticResource SubTextBrush}" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Center" 
                  Data="M 0 0 L 4 4 L 8 0 Z"/>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="PizzaComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton" 
                                      Template="{StaticResource PizzaComboBoxToggleButton}" 
                                      Focusable="False" 
                                      ClickMode="Press" 
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter x:Name="ContentSite" 
                                          IsHitTestVisible="False" 
                                          Content="{TemplateBinding SelectionBoxItem}" 
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                          Margin="16,0,28,0" 
                                          VerticalAlignment="Center" 
                                          HorizontalAlignment="Left"/>
                        <TextBox x:Name="PART_EditableTextBox" 
                                 Style="{x:Null}" 
                                 HorizontalAlignment="Left" 
                                 VerticalAlignment="Center" 
                                 Margin="16,0,28,0" 
                                 Focusable="True" 
                                 Background="Transparent" 
                                 Visibility="Hidden" 
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>
                        <Popup x:Name="Popup" 
                               Placement="Bottom" 
                               IsOpen="{TemplateBinding IsDropDownOpen}" 
                               AllowsTransparency="True" 
                               Focusable="False" 
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown" 
                                  SnapsToDevicePixels="True" 
                                  MinWidth="{TemplateBinding ActualWidth}" 
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border x:Name="DropDownBorder" 
                                        Background="White" 
                                        CornerRadius="12" 
                                        BorderThickness="1" 
                                        BorderBrush="{StaticResource BorderLightBrush}"
                                        Effect="{StaticResource CardShadowMedium}"
                                        Margin="0,4,0,0"/>
                                <ScrollViewer Margin="4,8" SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="PizzaComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Border" 
                            Background="Transparent" 
                            CornerRadius="8" 
                            Padding="{TemplateBinding Padding}" 
                            Margin="4,2">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#F0F1FF"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#E8EAFF"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MODERN DATEPICKER STYLE ==================== -->
    <Style x:Key="PizzaDatePickerStyle" TargetType="DatePicker">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
        <Setter Property="Background" Value="{StaticResource SoftWhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== PROGRESS BAR STYLE ==================== -->
    <Style x:Key="PizzaProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="Background" Value="#E8E8E8"/>
        <Setter Property="Foreground" Value="{StaticResource SuccessGreenBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4"/>
                        <Border x:Name="PART_Indicator" 
                                Background="{TemplateBinding Foreground}" 
                                CornerRadius="4" 
                                HorizontalAlignment="Left"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== SIDEBAR BUTTON WITH INDICATOR ==================== -->
    <Style x:Key="PizzaSidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#BDC3C7"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="20,14"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="indicator" 
                                Width="4" HorizontalAlignment="Left" 
                                Background="Transparent" CornerRadius="0,2,2,0"/>
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,12,12,0"
                                Margin="4,0,8,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#34495E"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style x:Key="PizzaSidebarButtonActive" TargetType="Button" BasedOn="{StaticResource PizzaSidebarButton}">
        <Setter Property="Background" Value="#34495E"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="indicator" 
                                Width="4" HorizontalAlignment="Left" CornerRadius="0,2,2,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#E85D04" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,12,12,0"
                                Margin="4,0,8,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== INPUT FIELD STYLES ==================== -->
    <Style x:Key="PizzaInputBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SoftWhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Modern Input Border with focus glow -->
    <Style x:Key="ModernInputBorder" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="4"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                <Setter Property="Background" Value="White"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" 
                                          Color="#5B6AFF" Opacity="0.12"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== TEXTBLOCK STYLES ==================== -->
    <Style x:Key="PizzaHeadingStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="32"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
    </Style>
    
    <Style x:Key="PizzaSubheadingStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
    </Style>
    
    <Style x:Key="PizzaStatNumberStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource DarkTextBrush}"/>
    </Style>
    
    <Style x:Key="PizzaLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource SubTextBrush}"/>
    </Style>

    <!-- ==================== MODERN SCROLLBAR STYLE ==================== -->
    <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="thumb" Background="#C8CBD5E1" CornerRadius="3" Margin="1"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="#94A3B8"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="thumb" Property="Background" Value="#64748B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="root" Background="Transparent" Opacity="0.4">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="root" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="8"/>
                            <Setter Property="MinHeight" Value="8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MODERN TOOLTIP STYLE ==================== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" 
                                              Direction="270" Color="#000000" Opacity="0.15"/>
                        </Border.Effect>
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ==================== MODERN DATAGRID STYLES ==================== -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="AlternatingRowBackground" Value="#FAFBFC"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserReorderColumns" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="RowHeight" Value="44"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="BorderBrush" Value="#F1F5F9"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="SeparatorBrush" Value="Transparent"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Foreground" Value="#334155"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#EEF0FF"/>
                <Setter Property="Foreground" Value="#1E293B"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F8FAFC"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#1E293B"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== HOVER CARD STYLE (Modern) ==================== -->
    <Style x:Key="HoverCardStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.08"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== ACCENT CARD STYLES ==================== -->
    <!-- Card with left blue accent line -->
    <Style x:Key="AccentCardBlue" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="3,0,0,0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card with left orange accent line -->
    <Style x:Key="AccentCardOrange" TargetType="Border" BasedOn="{StaticResource AccentCardBlue}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource WarningOrange}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#F59E0B" Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card with left cyan accent line -->
    <Style x:Key="AccentCardCyan" TargetType="Border" BasedOn="{StaticResource AccentCardBlue}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource InfoCyan}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#06B6D4" Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card with left red accent line -->
    <Style x:Key="AccentCardRed" TargetType="Border" BasedOn="{StaticResource AccentCardBlue}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#EF4444" Opacity="0.10"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==================== PREMIUM SIDEBAR GRADIENT ==================== -->
    <LinearGradientBrush x:Key="SidebarGradientPremium" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0F172A" Offset="0"/>
        <GradientStop Color="#1E293B" Offset="0.4"/>
        <GradientStop Color="#111827" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
