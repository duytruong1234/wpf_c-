<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.VerifyInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="550"
             Background="Transparent">
    
    <UserControl.Resources>
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Transparent ComboBox Style (no border, proper popup dropdown) -->
        <Style x:Key="TransparentComboBoxStyle" TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource PizzaComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid ClipToBounds="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!-- ToggleButton phủ toàn bộ để bắt click -->
                            <ToggleButton x:Name="ToggleButton"
                                          Grid.ColumnSpan="2"
                                          OverridesDefaultStyle="True"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.ColumnSpan="2" Background="Transparent"/>
                                            <!-- Arrow nằm bên trái -->
                                            <Path x:Name="Arrow"
                                                  Grid.Column="0"
                                                  Fill="#94A3B8"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0 0 L 5 5 L 10 0 Z"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource PrimaryColor}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Nội dung đã chọn - nằm bên phải mũi tên -->
                            <ContentPresenter x:Name="ContentSite"
                                              Grid.Column="1"
                                              IsHitTestVisible="False"
                                              Content="{Binding SelectedItem, RelativeSource={RelativeSource TemplatedParent}}"
                                              ContentTemplate="{TemplateBinding ItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,0,4,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>

                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="1"
                                     Style="{x:Null}"
                                     Template="{x:Null}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     Margin="12,0,4,0"
                                     Focusable="True"
                                     Background="Transparent"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>

                            <Popup x:Name="Popup"
                                   Grid.ColumnSpan="2"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            CornerRadius="12"
                                            BorderThickness="1"
                                            BorderBrush="#E2E8F0"
                                            Margin="0,4,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="16" ShadowDepth="4"
                                                              Direction="270" Color="#000000" Opacity="0.12"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="4,8" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <d:UserControl.DataContext>
        <vm:VerifyInfoViewModel/>
    </d:UserControl.DataContext>
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="28" 
                Padding="48,44"
                Width="520"
                Effect="{StaticResource CardShadow}">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly" Margin="0,0,0,10">
                   <StackPanel>
                    <!-- Step Indicator -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,4,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFBA08" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="24" Height="2" Background="#E2E8F0" VerticalAlignment="Center" Margin="2,0"/>
                        <Border Width="28" Height="28" CornerRadius="14" Background="#E2E8F0" Margin="0,0,4,0">
                            <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <Border Width="24" Height="2" Background="#E2E8F0" VerticalAlignment="Center" Margin="2,0"/>
                        <Border Width="28" Height="28" CornerRadius="14" Background="#E2E8F0" Margin="0,0,0,0">
                            <TextBlock Text="3" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Icon - Key/Verify -->
                    <Viewbox Width="52" Height="52" Margin="0,0,0,8">
                    <Grid>
                        <Ellipse Width="80" Height="80">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFBA08" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Path Data="M12.65,10 A6,6 0 1,0 12.65,10.001 M12.65,10 L22,10 L22,14 L20,14 L20,12 L18,12 L18,14 L16,14 L16,10" 
                              Stroke="White" StrokeThickness="2.5" 
                              Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Stretch="Uniform"
                              Width="36" Height="36"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                
                <!-- Header -->
                <TextBlock Text="X&#x00E1;c minh th&#x00F4;ng tin"
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                
                <TextBlock Text="Vui l&#x00F2;ng nh&#x1EAD;p th&#x00F4;ng tin &#x0111;&#x1EC3; x&#x00E1;c minh t&#x00E0;i kho&#x1EA3;n"
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Error Message -->
                <Border Background="#FEF2F2" 
                        CornerRadius="14" 
                        Padding="16,14"
                        Margin="0,0,0,20"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" 
                                CornerRadius="8" Background="#FEE2E2"
                                Margin="0,0,12,0" VerticalAlignment="Center">
                            <Path Data="M12,2 C17.5,2 22,6.5 22,12 C22,17.5 17.5,22 12,22 C6.5,22 2,17.5 2,12 C2,6.5 6.5,2 12,2 M12,4 C7.6,4 4,7.6 4,12 C4,16.4 7.6,20 12,20 C16.4,20 20,16.4 20,12 C20,7.6 16.4,4 12,4 M12,16 L12,18 L11,18 L11,16 M12,6 L12,14 L11,14 L11,6" 
                                  Fill="#DC2626" 
                                  Stretch="Uniform" 
                                  Width="16" Height="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ErrorMessage}" 
                                   Foreground="#DC2626" 
                                   FontSize="13"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Ho Ten -->
                <TextBlock Text="H&#x1ECD; v&#x00E0; t&#x00EA;n"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12,4 A4,4 0 1,1 12,12 A4,4 0 1,1 12,4 M12,14 C8,14 4,16 4,18 L4,20 L20,20 L20,18 C20,16 16,14 12,14" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBox x:Name="txtHoTen" Grid.Column="1"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,0,12,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="Nh&#x1EAD;p h&#x1ECD; v&#x00E0; t&#x00EA;n &#x0111;&#x1EA7;y &#x0111;&#x1EE7;..."
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding Text, ElementName=txtHoTen, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                <!-- Ngay Sinh -->
                <TextBlock Text="Ng&#x00E0;y sinh"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M19,3 L18,3 L18,1 L16,1 L16,3 L8,3 L8,1 L6,1 L6,3 L5,3 C3.89,3 3,3.9 3,5 L3,19 C3,20.1 3.89,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 M19,19 L5,19 L5,8 L19,8" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <DatePicker Grid.Column="1"
                                    Style="{StaticResource ModernDatePickerStyle}"
                                    SelectedDate="{Binding NgaySinh}"
                                    SelectedDateFormat="Short"
                                    Language="vi-VN"
                                    Padding="12,12"
                                    HorizontalAlignment="Stretch"/>
                    </Grid>
                </Border>

                <!-- Chuc Vu -->
                <TextBlock Text="Ch&#x1EE9;c v&#x1EE5;"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="46" Height="46" 
                            CornerRadius="12" Margin="0,0,8,0"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFBA08" Offset="0"/>
                                <GradientStop Color="#F48C06" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M12,2 L2,7 L12,12 L22,7 L12,2 M2,17 L12,22 L22,17 M2,12 L12,17 L22,12" 
                              Stroke="White" StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Border>
                    
                     <ComboBox Grid.Column="1"
                               ItemsSource="{Binding ChucVus}"
                               SelectedItem="{Binding SelectedChucVu}"
                               Style="{StaticResource TransparentComboBoxStyle}"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Center"
                               MinWidth="220"
                               Margin="0,0,4,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TenChucVu}" 
                                           FontFamily="Segoe UI" 
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource PizzaComboBoxItemStyle}">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                    </Grid>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M20,4 L4,4 C2.9,4 2,4.9 2,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 M20,8 L12,13 L4,8 L4,6 L12,11 L20,6" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBox x:Name="txtEmail" Grid.Column="1"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,0,12,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="example@email.com"
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding Text, ElementName=txtEmail, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="&#x2190; Quay l&#x1EA1;i"
                            Grid.Column="0"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            FontSize="15"
                            FontWeight="Medium"
                            Padding="20,14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding BackCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Ti&#x1EBF;p t&#x1EE5;c &#x2192;"
                            Grid.Column="1"
                            Style="{StaticResource WarningButtonStyle}"
                            Command="{Binding VerifyCommand}"
                            HorizontalAlignment="Stretch"
                            Height="54"
                            FontSize="16"
                            Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#CCFFFFFF" CornerRadius="28"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border Width="8" Height="8" Background="#FFBA08" CornerRadius="4" Margin="0,0,6,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="viDot1"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="viDot1"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" Background="#F48C06" CornerRadius="4" Margin="0,0,6,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="viDot2"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="viDot2"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True" BeginTime="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" Background="#E85D04" CornerRadius="4">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="viDot3"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="viDot3"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True" BeginTime="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </StackPanel>
                <TextBlock Text="&#x0110;ang x&#x00E1;c minh..." 
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#F48C06" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
