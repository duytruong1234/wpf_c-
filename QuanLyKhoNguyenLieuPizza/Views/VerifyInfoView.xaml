<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.VerifyInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="550"
             Background="Transparent">
    
    <UserControl.Resources>
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <d:UserControl.DataContext>
        <vm:VerifyInfoViewModel/>
    </d:UserControl.DataContext>
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="28" 
                Padding="48,52"
                Width="520"
                Effect="{StaticResource CardShadow}">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly" Margin="0,0,0,10">
                   <StackPanel>
                    <!-- Icon - Key/Verify -->
                    <Viewbox Width="52" Height="52" Margin="0,0,0,8">
                    <Grid>
                        <Ellipse Width="80" Height="80">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFBA08" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Path Data="M12.65,10 A6,6 0 1,0 12.65,10.001 M12.65,10 L22,10 L22,14 L20,14 L20,12 L18,12 L18,14 L16,14 L16,10" 
                              Stroke="White" StrokeThickness="2.5" 
                              Fill="Transparent"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Stretch="Uniform"
                              Width="36" Height="36"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                
                <!-- Header -->
                <TextBlock Text="X&#x00E1;c minh th&#x00F4;ng tin"
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                
                <TextBlock Text="Vui l&#x00F2;ng nh&#x1EAD;p th&#x00F4;ng tin &#x0111;&#x1EC3; x&#x00E1;c minh t&#x00E0;i kho&#x1EA3;n"
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Error Message -->
                <Border Background="#FEF2F2" 
                        CornerRadius="12" 
                        Padding="16,12"
                        Margin="0,0,0,20"
                        BorderBrush="#FCA5A5"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2 C17.5,2 22,6.5 22,12 C22,17.5 17.5,22 12,22 C6.5,22 2,17.5 2,12 C2,6.5 6.5,2 12,2 M12,4 C7.6,4 4,7.6 4,12 C4,16.4 7.6,20 12,20 C16.4,20 20,16.4 20,12 C20,7.6 16.4,4 12,4 M12,16 L12,18 L11,18 L11,16 M12,6 L12,14 L11,14 L11,6" 
                              Fill="#DC2626" 
                              Stretch="Uniform" 
                              Width="20" Height="20"
                              Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="#B91C1C" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Ho Ten -->
                <TextBlock Text="H&#x1ECD; v&#x00E0; t&#x00EA;n"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12,4 A4,4 0 1,1 12,12 A4,4 0 1,1 12,4 M12,14 C8,14 4,16 4,18 L4,20 L20,20 L20,18 C20,16 16,14 12,14" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBox x:Name="txtHoTen" Grid.Column="1"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding HoTen, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,0,12,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="Nh&#x1EAD;p h&#x1ECD; v&#x00E0; t&#x00EA;n &#x0111;&#x1EA7;y &#x0111;&#x1EE7;..."
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding Text, ElementName=txtHoTen, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                <!-- Ngay Sinh -->
                <TextBlock Text="Ng&#x00E0;y sinh"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M19,3 L18,3 L18,1 L16,1 L16,3 L8,3 L8,1 L6,1 L6,3 L5,3 C3.89,3 3,3.9 3,5 L3,19 C3,20.1 3.89,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 M19,19 L5,19 L5,8 L19,8" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <DatePicker Grid.Column="1"
                                    Style="{StaticResource ModernDatePickerStyle}"
                                    SelectedDate="{Binding NgaySinh}"
                                    Padding="12,12"
                                    HorizontalAlignment="Stretch"/>
                    </Grid>
                </Border>

                <!-- Chuc Vu -->
                <TextBlock Text="Ch&#x1EE9;c v&#x1EE5;"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M12,2 L2,7 L12,12 L22,7 L12,2 M2,17 L12,22 L22,17 M2,12 L12,17 L22,12" 
                                          Stroke="White" StrokeThickness="2"
                                          Fill="Transparent"
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  ItemsSource="{Binding ChucVus}"
                                  SelectedItem="{Binding SelectedChucVu}"
                                  Padding="12,12"
                                  HorizontalAlignment="Stretch"
                                  FontFamily="Segoe UI">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TenChucVu}" FontFamily="Segoe UI" FontSize="14"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem" BasedOn="{StaticResource PizzaComboBoxItemStyle}">
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Setter Property="FontSize" Value="14"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Email -->
                <TextBlock Text="Email"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                        CornerRadius="10" Margin="4">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFBA08" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Path Data="M20,4 L4,4 C2.9,4 2,4.9 2,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 M20,8 L12,13 L4,8 L4,6 L12,11 L20,6" 
                                          Fill="White" 
                                          Stretch="Uniform" 
                                          Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <TextBox x:Name="txtEmail" Grid.Column="1"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,0,12,0"/>

                        <TextBlock Grid.Column="1"
                                   Text="example@email.com"
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding Text, ElementName=txtEmail, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </Grid>
                </Border>

                </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="&#x2190; Quay l&#x1EA1;i"
                            Grid.Column="0"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            FontSize="15"
                            FontWeight="Medium"
                            Padding="20,14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding BackCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Ti&#x1EBF;p t&#x1EE5;c &#x2192;"
                            Grid.Column="1"
                            Style="{StaticResource WarningButtonStyle}"
                            Command="{Binding VerifyCommand}"
                            HorizontalAlignment="Stretch"
                            Height="54"
                            FontSize="16"
                            Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#CCFFFFFF" CornerRadius="28"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Viewbox Width="48" Height="48" Margin="0,0,0,16">
                    <Grid>
                        <Ellipse Width="48" Height="48">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFBA08" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Path Data="M12,2 A10,10 0 1,1 12,22 A10,10 0 1,1 12,2 M12,6 L12,12 L16,14" 
                              Stroke="White" StrokeThickness="2.5" Fill="Transparent"
                              Stretch="Uniform" Width="22" Height="22"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                <TextBlock Text="&#x0110;ang x&#x00E1;c minh..." 
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#F48C06" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

