<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.PhieuNhapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             xmlns:behaviors="clr-namespace:QuanLyKhoNguyenLieuPizza.Behaviors"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <d:UserControl.DataContext>
        <vm:PhieuNhapViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <!-- BẢNG MÀU HIỆN ĐẠI -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernInputBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ========== MANAGER VIEW ========== -->
        <Grid Background="{StaticResource Gray50}" Margin="24"
              Visibility="{Binding IsQuanLy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Tiêu đề + Actions -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="14" Width="48" Height="48" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý phiếu nhập" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Theo dõi và quản lý nhập kho nguyên liệu" FontSize="13" Foreground="{StaticResource Gray400}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource ModernInputBorder}" Width="320" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                        <TextBlock Grid.Column="1" Text="Tìm kiếm phiếu nhập..." FontSize="14" Foreground="{StaticResource Gray400}"
                                   Padding="4,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchTextBox" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" FontSize="14" Padding="0" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Nút Làm mới -->
                <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Cursor="Hand" VerticalAlignment="Center" ToolTip="Làm mới dữ liệu">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Width="44" Height="44">
                                <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="4" Command="{Binding CreatePhieuNhapCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tạo phiếu nhập" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Summary THẺ THỐNG KÊ -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng phiếu nhập" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Archive24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding PhieuNhaps.Count}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Margin="5,0,5,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng tiền nhập" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Money24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{StaticResource SuccessGreen}">
                            <Run Text="{Binding TongTien, StringFormat=\{0:N0\}}"/>
                            <Run Text=" đ" FontSize="20"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Trạng thái phiếu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#FBBF24" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <UniformGrid Columns="3">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SoPhieuChoDuyet}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource WarningOrange}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Chờ duyệt" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SoPhieuDaDuyet}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Đã duyệt" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SoPhieuDaHuy}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Đã hủy" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filters -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Tiêu đề -->
                    <StackPanel Grid.ColumnSpan="6" Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Bộ lọc" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Nhân viên nhập" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <ComboBox ItemsSource="{Binding NhanViens}" SelectedItem="{Binding SelectedNhanVienFilter}"
                                      DisplayMemberPath="HoTen" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Nhà cung cấp" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <ComboBox ItemsSource="{Binding NhaCungCaps}" SelectedItem="{Binding SelectedNhaCungCapFilter}"
                                      DisplayMemberPath="TenNCC" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Từ ngày" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding TuNgay}" BorderThickness="0" Background="Transparent" FontSize="13" Language="vi-VN"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Text="Đến ngày" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding DenNgay}" BorderThickness="0" Background="Transparent" FontSize="13" Language="vi-VN"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,10,0">
                        <TextBlock Text="Trạng thái" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <ComboBox ItemsSource="{Binding TrangThaiOptions}" SelectedItem="{Binding SelectedTrangThaiFilter}"
                                      BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="1" Grid.Column="5" Command="{Binding ClearFilterCommand}" Cursor="Hand" VerticalAlignment="Bottom" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Xóa lọc" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Bảng Dữ liệu -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="10,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mã phiếu nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Ngày nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Nhân viên nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Nhà cung cấp" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Tổng tiền" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="Trạng thái" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="6" Text="Thao tác" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PhieuNhaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border Background="Transparent" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding MaPhieuNhap}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding NgayNhap, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding NhanVienNhap.HoTen}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding NhaCungCap.TenNCC}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding TongTien, StringFormat='{}{0:N0} đ'}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource Gray800}" FontWeight="Bold"/>

                                                <Border Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="12" Padding="12,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                    <Setter Property="Background" Value="#FEF3CD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Không xác định"/>
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                        <Setter Property="Text" Value="Chờ duyệt"/>
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                        <Setter Property="Text" Value="Đã duyệt"/>
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                        <Setter Property="Text" Value="Đã hủy"/>
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Button Grid.Column="6" ToolTip="Chi tiết"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32">
                                                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding PhieuNhaps.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="20" Width="80" Height="80" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Gray300}"/>
                        </Border>
                        <TextBlock Text="Không có phiếu nhập nào" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thử thay đổi bộ lọc hoặc tạo phiếu nhập mới" FontSize="13" Foreground="{StaticResource Gray300}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== EMPLOYEE VIEW ========== -->
        <Grid Background="{StaticResource Gray50}" Margin="32,20,32,32"
              Visibility="{Binding IsNhanVienKho, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Employee Tiêu đề -->
            <Grid Grid.Row="0" Margin="0,0,70,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Lịch sử phiếu nhập" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource Gray900}" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource ModernInputBorder}" Width="280" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                        <TextBlock Grid.Column="1" Text="Tìm kiếm phiếu nhập" FontSize="14" Foreground="{StaticResource Gray400}"
                                   Padding="4,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox2}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox2}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchTextBox2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" FontSize="14" Padding="0" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>

                <Button Grid.Column="2" Command="{Binding CreatePhieuNhapCommand}"
                        VerticalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12"
                                    BorderBrush="{StaticResource Gray200}" BorderThickness="1" Background="White">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tạo phiếu nhập" FontSize="14" Foreground="{StaticResource Gray800}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Employee Filters Card -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Bộ lọc" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Nhà cung cấp" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <ComboBox ItemsSource="{Binding NhaCungCaps}" SelectedItem="{Binding SelectedNhaCungCapFilter}"
                                      DisplayMemberPath="TenNCC" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Từ ngày" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding TuNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Đến ngày" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding DenNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <Button Grid.Row="1" Grid.Column="3" Command="{Binding ClearFilterCommand}" Cursor="Hand" VerticalAlignment="Bottom" Margin="6,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Xóa lọc" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="10,10,0,0">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mã phiếu nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Ngày nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Nhân viên nhập" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Nhà cung cấp" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Tổng tiền" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="Trạng thái" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="6" Text="Thao tác" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PhieuNhaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border Background="Transparent" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.5*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding MaPhieuNhap}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding NgayNhap, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding NhanVienNhap.HoTen}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding NhaCungCap.TenNCC}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding TongTien, StringFormat='{}{0:N0} đ'}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource Gray800}" FontWeight="Bold"/>

                                                <Border Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="12" Padding="12,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F1F5F9"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                    <Setter Property="Background" Value="#FEF3CD"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Không xác định"/>
                                                                <Setter Property="Foreground" Value="#64748B"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                        <Setter Property="Text" Value="Chờ duyệt"/>
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                        <Setter Property="Text" Value="Đã duyệt"/>
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                        <Setter Property="Text" Value="Đã hủy"/>
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Button Grid.Column="6" ToolTip="Chi tiết"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32">
                                                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding PhieuNhaps.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="20" Width="80" Height="80" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Gray300}"/>
                        </Border>
                        <TextBlock Text="Không có phiếu nhập nào" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thử thay đổi bộ lọc hoặc tạo phiếu nhập mới" FontSize="13" Foreground="{StaticResource Gray300}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== MANAGER CREATE DIALOG ========== -->
        <Grid Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <!-- Manager Dialog -->
            <Border Background="White" CornerRadius="20" Width="1200" Height="680" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32"
                    Visibility="{Binding IsQuanLy, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource Gray800}" HorizontalAlignment="Center" Text="Tạo phiếu nhập mới"/>
                        <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CancelDialogCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                    </Grid>

                    <!-- NCC Selection -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="Nhà cung cấp:" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Style="{StaticResource ModernInputBorder}" Width="300">
                            <ComboBox ItemsSource="{Binding NhaCungCapsForm}" SelectedItem="{Binding SelectedNhaCungCapForm}"
                                      DisplayMemberPath="TenNCC" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="32,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Tổng tiền: " FontSize="14" Foreground="{StaticResource Gray500}"/>
                            <TextBlock Text="{Binding TongTienForm, StringFormat=\{0:N0\}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                            <TextBlock Text=" đ" FontSize="14" Foreground="{StaticResource Gray800}" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource LightBlue}" CornerRadius="20" Padding="20" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16,12" Margin="0,0,0,16" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Chọn nguyên liệu" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray700}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding NguyenLieusOfNCC}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.AddNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Margin="6" Cursor="Hand" Width="120">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="White" CornerRadius="12" Padding="0" ClipToBounds="True">
                                                                <StackPanel>
                                                                    <Border Height="70" Background="#F0F0F0" CornerRadius="12,12,0,0" ClipToBounds="True">
                                                                        <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                    </Border>
                                                                    <StackPanel Margin="6,6,6,8" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding TenNguyenLieu}" FontSize="11" FontWeight="Medium" Foreground="{StaticResource Gray800}" 
                                                                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                                                        <TextBlock FontSize="10" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                                            <Run Text=""/>
                                                                            <Run Text="{Binding GiaNhap, Mode=OneWay, StringFormat=\{0:N0\}}"/>
                                                                            <Run Text=" đ"/>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Background="{StaticResource Gray50}" CornerRadius="12,12,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Tên nguyên liệu" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="1" Text="Số lượng" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="2" Text="Đơn vị" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="3" Text="Đơn giá" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="4" Text="HSD" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="5" Text="Thành tiền" Style="{StaticResource TableHeaderStyle}"/>
                                        <TextBlock Grid.Column="6" Text="" Style="{StaticResource TableHeaderStyle}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChiTietForm}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="8,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.3*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="0.9*"/>
                                                            <ColumnDefinition Width="0.9*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="40"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Column="0" Text="{Binding NguyenLieu.TenNguyenLieu}" Style="{StaticResource TableCellStyle}" TextAlignment="Left"/>
                                                        
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}" Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bd" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28"
                                                                                BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                                            <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray200}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <TextBox Text="{Binding SoLuongText, UpdateSourceTrigger=PropertyChanged}"
                                                                     Width="40" TextAlignment="Center" BorderThickness="0" behaviors:NumericInputBehavior.IsDecimalOnly="True"
                                                                     FontSize="14" FontWeight="SemiBold" VerticalContentAlignment="Center" Background="Transparent"/>
                                                            <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}" Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bd" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28"
                                                                                BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray200}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>
                                                        
                                                        <ComboBox Grid.Column="2" ItemsSource="{Binding DonViNhapOptions}" SelectedItem="{Binding SelectedDonViNhap}"
                                                                  DisplayMemberPath="DonViTinh.TenDonVi" BorderThickness="0" Background="Transparent"
                                                                  FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Stretch" Cursor="Hand"/>
                                                        
                                                        <Border Grid.Column="3" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="6" Padding="4,2" Margin="4,0" VerticalAlignment="Center">
                                                            <TextBox Text="{Binding DonGia, UpdateSourceTrigger=LostFocus, StringFormat=N0}" behaviors:NumericInputBehavior.IsNumericOnly="True"
                                                                     BorderThickness="0" Background="Transparent" FontSize="13" TextAlignment="Center" 
                                                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                        </Border>
                                                        
                                                        <DatePicker Grid.Column="4" SelectedDate="{Binding HSD, Mode=TwoWay}" 
                                                                    BorderThickness="0" Background="Transparent" FontSize="11" 
                                                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" Language="vi-VN"/>
                                                        
                                                        <TextBlock Grid.Column="5" Text="{Binding ThanhTien, StringFormat='{}{0:N0} đ'}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource Gray800}" FontWeight="SemiBold"/>

                                                                        <Button Grid.Column="6" Command="{Binding DataContext.RemoveChiTietCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Center">
                                                                            <Button.Template>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="border" Padding="8" CornerRadius="6">
                                                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource DangerRed}"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Button.Template>
                                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0"
                                            Visibility="{Binding ChiTietForm.Count, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="Chưa có nguyên liệu nào" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Vui lòng chọn nhà cung cấp và nguyên liệu để thêm" FontSize="13" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" MaxWidth="250" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Command="{Binding CancelDialogCommand}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="32,14">
                                        <TextBlock Text="Hủy" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Command="{Binding SavePhieuNhapCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="8" Padding="28,12">
                                        <Border.Background>
                                            <SolidColorBrush Color="#5B6AFF" />
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#5B6AFF" Opacity="0.15"/>
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Lưu phiếu" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Employee Dialog -->
            <Border Background="White" CornerRadius="20" Width="1200" Height="680" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32"
                    Visibility="{Binding IsNhanVienKho, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Tạo phiếu nhập" FontSize="26" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                        <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CancelDialogCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                    </Grid>

                    <!-- NCC Selection -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Style="{StaticResource ModernInputBorder}" Width="300">
                            <ComboBox ItemsSource="{Binding NhaCungCapsForm}" SelectedItem="{Binding SelectedNhaCungCapForm}"
                                      DisplayMemberPath="TenNCC" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                        <TextBlock Margin="32,0,0,0" VerticalAlignment="Center">
                            <Run Text="Tổng tiền: " FontSize="14" Foreground="{StaticResource Gray500}"/>
                            <Run Text="{Binding TongTienForm, StringFormat=\{0:N0\}}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                            <Run Text=" đ" FontSize="14" Foreground="{StaticResource Gray800}"/>
                        </TextBlock>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.9*"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F4F7FB" CornerRadius="20" Padding="20" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16,12" Margin="0,0,0,16" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Chọn nguyên liệu" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray700}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding NguyenLieusOfNCC}" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.AddNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Margin="6" Cursor="Hand" Width="120">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="White" CornerRadius="12" Padding="0" ClipToBounds="True">
                                                                <StackPanel>
                                                                    <Border Height="70" Background="#F0F0F0" CornerRadius="12,12,0,0" ClipToBounds="True">
                                                                        <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                    </Border>
                                                                    <StackPanel Margin="6,6,6,8" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding TenNguyenLieu}" FontSize="11" FontWeight="Medium" Foreground="{StaticResource Gray800}" 
                                                                                   HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="16" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="14,14,0,0">
                                    <Grid Margin="8,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="0.9*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Tên nguyên liệu" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Số lượng" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Đơn vị" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Đơn giá" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="HSD" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="Thành tiền" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" Width="40"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ChiTietForm}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="8,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.3*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="0.9*"/>
                                                            <ColumnDefinition Width="0.9*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0" Text="{Binding NguyenLieu.TenNguyenLieu}" 
                                                                   FontSize="12" Foreground="{StaticResource Gray800}" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}" Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bd" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28"
                                                                                BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                                            <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray200}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                            <TextBox Text="{Binding SoLuongText, UpdateSourceTrigger=PropertyChanged}" behaviors:NumericInputBehavior.IsDecimalOnly="True"
                                                                     Width="45" TextAlignment="Center" BorderThickness="0" Background="Transparent"
                                                                     FontSize="14" FontWeight="SemiBold" VerticalContentAlignment="Center" Margin="4,0"/>
                                                            <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}" Cursor="Hand">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bd" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28"
                                                                                BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Gray200}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </StackPanel>

                                                        <ComboBox Grid.Column="2" ItemsSource="{Binding DonViNhapOptions}" SelectedItem="{Binding SelectedDonViNhap}"
                                                                  DisplayMemberPath="DonViTinh.TenDonVi" BorderThickness="0" Background="Transparent"
                                                                  FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Stretch" Cursor="Hand"/>

                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBox Text="{Binding DonGia, UpdateSourceTrigger=LostFocus}" behaviors:NumericInputBehavior.IsNumericOnly="True"
                                                                     FontSize="12" Foreground="{StaticResource Gray800}" 
                                                                     TextAlignment="Right" Background="White" 
                                                                     BorderThickness="1" BorderBrush="{StaticResource Gray300}"
                                                                     Padding="4,2" MinWidth="70"/>
                                                            <TextBlock Text=" đ" FontSize="12" Foreground="{StaticResource Gray800}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                        </StackPanel>

                                                        <DatePicker Grid.Column="4" SelectedDate="{Binding HSD, Mode=TwoWay}" 
                                                                    BorderThickness="0" Background="Transparent" FontSize="11" 
                                                                    VerticalAlignment="Center" HorizontalAlignment="Stretch" Language="vi-VN"/>

                                                        <TextBlock Grid.Column="5" Text="{Binding ThanhTien, StringFormat='{}{0:N0} đ'}" FontSize="12" Foreground="{StaticResource Gray800}" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <Button Grid.Column="6" Command="{Binding DataContext.RemoveChiTietCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Center">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="border" Padding="6" CornerRadius="6">
                                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource DangerRed}"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,0"
                                            Visibility="{Binding ChiTietForm.Count, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="&#xE81E;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="Chưa có nguyên liệu nào" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Vui lòng chọn nhà cung cấp và nhấp vào nguyên liệu để thêm" FontSize="13" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0" MaxWidth="250" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Button Grid.Row="3" Command="{Binding SavePhieuNhapCommand}" HorizontalAlignment="Right" Margin="0,20,0,0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="8" Padding="28,12">
                                    <Border.Background>
                                        <SolidColorBrush Color="#5B6AFF" />
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#5B6AFF" Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Lưu phiếu nhập" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== DETAIL DIALOG ========== -->
        <Grid Visibility="{Binding IsDetailDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="850" MaxHeight="650" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseDetailDialogCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock FontSize="26" FontWeight="Bold" Foreground="{StaticResource Gray800}" HorizontalAlignment="Center">
                            <Run Text="Chi tiết phiếu nhập: "/>
                            <Run Text="{Binding SelectedPhieuNhap.MaPhieuNhap}"/>
                        </TextBlock>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="13" Foreground="{StaticResource Gray500}">
                                    <Run Text="Nhân viên nhập: "/>
                                    <Run Text="{Binding SelectedPhieuNhap.NhanVienNhap.HoTen}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource Gray500}" Margin="0,4,0,0">
                                    <Run Text="Ngày nhập: "/>
                                    <Run Text="{Binding SelectedPhieuNhap.NgayNhap, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource Gray500}" Margin="0,4,0,0">
                                    <Run Text="Nhà cung cấp: "/>
                                    <Run Text="{Binding SelectedPhieuNhap.NhaCungCap.TenNCC}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Trạng thái: " FontSize="13" Foreground="{StaticResource Gray500}" VerticalAlignment="Center"/>
                                    <Border CornerRadius="8" Padding="10,4" Margin="4,0,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedPhieuNhap.TrangThai}" Value="2">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedPhieuNhap.TrangThai}" Value="3">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Chờ duyệt"/>
                                                    <Setter Property="Foreground" Value="#92400E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedPhieuNhap.TrangThai}" Value="2">
                                                            <Setter Property="Text" Value="Đã duyệt"/>
                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedPhieuNhap.TrangThai}" Value="3">
                                                            <Setter Property="Text" Value="Đã hủy"/>
                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="13" Foreground="{StaticResource Gray500}" Margin="0,4,0,0"
                                           Visibility="{Binding SelectedPhieuNhap.NhanVienDuyet, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run Text="Người duyệt: "/>
                                    <Run Text="{Binding SelectedPhieuNhap.NhanVienDuyet.HoTen}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource Gray500}" Margin="0,4,0,0"
                                           Visibility="{Binding SelectedPhieuNhap.NgayDuyet, Converter={StaticResource NullToVisibilityConverter}}">
                                    <Run Text="Ngày duyệt: "/>
                                    <Run Text="{Binding SelectedPhieuNhap.NgayDuyet, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <TextBlock>
                                    <Run Text="Tổng tiền: " FontSize="14" Foreground="{StaticResource Gray500}"/>
                                    <Run Text="{Binding SelectedPhieuNhap.TongTien, StringFormat=\{0:N0\}}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                                    <Run Text=" đ" FontSize="14" Foreground="{StaticResource Gray800}"/>
                                </TextBlock>
                                
                                <TextBlock Margin="0,8,0,0" Visibility="{Binding SelectedPhieuNhap.GhiChu, Converter={StaticResource StringToVisibilityConverter}}" TextWrapping="Wrap">
                                    <Run Text="Lý do hủy: " FontSize="13" Foreground="{StaticResource Gray500}"/>
                                    <Run Text="{Binding SelectedPhieuNhap.GhiChu}" FontSize="13" FontWeight="SemiBold" Foreground="#991B1B"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource Gray50}" CornerRadius="12,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Tên nguyên liệu" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="1" Text="Số lượng" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="Đơn vị" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="Hệ số" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="4" Text="HSD" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="5" Text="Đơn giá" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="6" Text="Thành tiền" Style="{StaticResource TableHeaderStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                                <ItemsControl ItemsSource="{Binding ChiTietPhieuNhaps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="0.8*"/>
                                                        <ColumnDefinition Width="0.8*"/>
                                                        <ColumnDefinition Width="0.8*"/>
                                                        <ColumnDefinition Width="0.8*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding NguyenLieu.TenNguyenLieu}" Style="{StaticResource TableCellStyle}" TextAlignment="Left" Padding="20,16"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding SoLuong, StringFormat=\{0:N4\}}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding TenDonViNhap}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding HeSo, StringFormat=\{0:N4\}}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding HSD, StringFormat=\{0:dd/MM/yyyy\}, FallbackValue='-'}" Style="{StaticResource TableCellStyle}" FontSize="11"/>
                                                    <TextBlock Grid.Column="5" Text="{Binding DonGia, StringFormat='{}{0:N0} đ'}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding ThanhTien, StringFormat='{}{0:N0} đ'}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource Gray800}" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Command="{Binding PrintPhieuNhapCommand}" CommandParameter="{Binding SelectedPhieuNhap}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="28,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray600}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="In phiếu" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Duyệt Phiếu Button - Chỉ Quản Lý và phiếu Chờ duyệt -->
                        <Button Command="{Binding ApprovePhieuNhapCommand}" IsEnabled="{Binding CanApprove}"
                                Visibility="{Binding IsQuanLy, Converter={StaticResource BoolToVisibilityConverter}}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="28,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#059669" Offset="0"/>
                                                <GradientStop Color="#10B981" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Duyệt phiếu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Hủy Phiếu Button -->
                        <Button Command="{Binding CancelPhieuNhapCommand}" IsEnabled="{Binding CanCancel}"
                                Visibility="{Binding IsCancelVisible, Converter={StaticResource BoolToVisibilityConverter}}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource DangerRed}" CornerRadius="10" Padding="28,12">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Hủy phiếu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Sửa Phiếu -->
                        <Button Command="{Binding EditPhieuNhapCommand}" CommandParameter="{Binding SelectedPhieuNhap}" IsEnabled="{Binding CanEditDelete}"
                                Visibility="{Binding IsEditDeleteVisible, Converter={StaticResource BoolToVisibilityConverter}}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="28,12">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                                <GradientStop Color="#818CF8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="Sửa phiếu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Xóa Phiếu - chỉ cho phiếu đã hủy -->
                        <Button Command="{Binding DeletePhieuNhapCommand}" CommandParameter="{Binding SelectedPhieuNhap}" IsEnabled="{Binding CanDelete}"
                                Visibility="{Binding IsDeleteVisible, Converter={StaticResource BoolToVisibilityConverter}}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource DangerRed}" CornerRadius="10" Padding="28,12">
                                        <TextBlock Text="Xóa phiếu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Màn hình Chờ -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80FFFFFF">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBlue}"/>
                <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray500}" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>


