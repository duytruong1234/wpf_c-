<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:BanHangViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessGreenLight" Color="#D1FAE5"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerRedLight" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="WarningOrangeLight" Color="#FEF3C7"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Gray50}">

        <!-- ═══════════════ MAIN POS VIEW ═══════════════ -->
        <Grid Visibility="{Binding IsMainView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- PAGE HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bán hàng Pizza" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Chọn pizza và thanh toán" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding ShowOrderHistoryCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Lịch sử đơn hàng" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- STAT CARDS -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu hôm nay" FontSize="12" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Text="{Binding DoanhThuHomNay, StringFormat={}{0:N0} đ}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Tổng đơn hôm nay" FontSize="12" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Text="{Binding TongDonHomNay}" FontSize="22" FontWeight="Bold" Foreground="#059669"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- POS CONTENT: Menu + Cart -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- PRODUCT MENU -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Tìm kiếm sản phẩm..." FontSize="14" Foreground="{StaticResource Gray400}"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           Visibility="{Binding SearchText, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </Grid>
                        </Border>

                        <!-- Product Grid -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding HangHoas}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectHangHoaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,12,12">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="card" Background="White" CornerRadius="14" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.04"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="120"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Product Image -->
                                                            <Border Grid.Row="0" CornerRadius="14,14,0,0" Background="{StaticResource Gray100}" ClipToBounds="True">
                                                                <Grid>
                                                                    <TextBlock Text="🍕" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}"
                                                                           Stretch="UniformToFill"/>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Info -->
                                                            <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                                                <TextBlock Text="{Binding TenHangHoa}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding MaHangHoa}" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty -->
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HangHoas.Count, Converter={StaticResource IntToVisibilityConverter}}">
                            <TextBlock Text="🍕" FontSize="40" HorizontalAlignment="Center"/>
                            <TextBlock Text="Chưa có sản phẩm nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CART -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Cart Header -->
                        <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" Padding="20,16">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource PrimaryBlue}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Giỏ hàng" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}" VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource PrimaryBlue}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TongSoMon}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Command="{Binding ClearCartCommand}" Cursor="Hand" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock x:Name="txt" Text="Xóa tất cả" FontSize="12" Foreground="{StaticResource DangerRed}" Cursor="Hand"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Cart Items -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="8,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Product Image -->
                                                <Border Width="48" Height="48" CornerRadius="10" Background="{StaticResource Gray100}" ClipToBounds="True" Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Grid>
                                                        <TextBlock Text="&#x1F355;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding HangHoa.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding HangHoa.TenHangHoa}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Size.TenSize}" FontSize="11" Foreground="{StaticResource PrimaryBlue}" FontWeight="Medium"/>
                                                        <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource Gray300}" Visibility="{Binding DeBanh.TenDeBanh, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding DeBanh.TenDeBanh}" FontSize="11" Foreground="{StaticResource Gray500}" Visibility="{Binding DeBanh.TenDeBanh, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} đ}" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,2,0,4"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="b" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28">
                                                                        <TextBlock Text="−" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Gray200}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <TextBlock Text="{Binding SoLuong}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"
                                                                   VerticalAlignment="Center" Margin="12,0"/>
                                                        <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="b" Background="{StaticResource LightBlue}" CornerRadius="6" Width="28" Height="28">
                                                                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="b" Property="Background" Value="#DCE0FF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ThanhTien, StringFormat={}{0:N0} đ}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                                    <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Right" Margin="0,6,0,0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <TextBlock x:Name="txt" Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="txt" Property="Foreground" Value="{StaticResource DangerRed}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Cart empty -->
                        <TextBlock Grid.Row="1" Text="Giỏ hàng trống" FontSize="14" Foreground="{StaticResource Gray300}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding CartItems.Count, Converter={StaticResource IntToVisibilityConverter}}"/>

                        <!-- Checkout Footer -->
                        <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="20,16" BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <!-- GhiChu -->
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Ghi ch&#xFA;:" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                                </Grid>
                                <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,12">
                                    <Grid>
                                        <TextBox Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" 
                                                 FontSize="13" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="60" VerticalScrollBarVisibility="Auto"/>
                                        <TextBlock Text="Nh&#x1EAD;p ghi ch&#xFA; (t&#xF9;y ch&#x1ECD;n)..." FontSize="13" Foreground="{StaticResource Gray400}" 
                                                   IsHitTestVisible="False" VerticalAlignment="Top"
                                                   Visibility="{Binding GhiChu, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Tổng cộng:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                    <TextBlock Text="{Binding TongTienGioHang, StringFormat={}{0:N0} đ}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Button Command="{Binding CheckoutCommand}" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" CornerRadius="12" Padding="0,16" HorizontalAlignment="Stretch">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                                        <GradientStop Color="#818CF8" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                                </Border.Effect>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Thanh toán" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════ ORDER HISTORY VIEW ═══════════════ -->
        <Grid Visibility="{Binding IsOrderHistoryView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding BackToMainCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Quay lại" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Lịch sử đơn hàng" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Xem lại các đơn hàng đã bán" FontSize="12" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Date Filter -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Từ ngày:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FilterFromDate}" FontSize="13" Margin="0,0,20,0"/>
                    <TextBlock Text="Đến ngày:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FilterToDate}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Orders Table -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mã phiếu" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Ngày bán" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Nhân viên" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Tổng tiền" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Thao tác" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PhieuBanHangs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding MaPhieuBan}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding NgayBan, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NhanVienBan.HoTen}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TongTien, StringFormat={}{0:N0} đ}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlue}"/>

                                            <!-- View Detail Button -->
                                            <Button Grid.Column="4" 
                                                    Command="{Binding DataContext.ViewOrderDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" ToolTip="Xem chi tiết" Cursor="Hand"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="30" Height="30">
                                                            <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding PhieuBanHangs.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Không có đơn hàng nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ SIZE / DE SELECTION DIALOG ═══════════════ -->
        <Grid Visibility="{Binding IsSizeDeDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="460"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel HorizontalAlignment="Center">
                            <!-- Product Image -->
                            <Border Width="80" Height="80" CornerRadius="14" Background="{StaticResource Gray100}" ClipToBounds="True" HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Grid>
                                    <TextBlock Text="&#x1F355;" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Source="{Binding SelectedHangHoa.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                            <TextBlock Text="Ch&#x1ECD;n Size &amp; &#x110;&#x1EBF;" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedHangHoa.TenHangHoa}" FontSize="14" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CancelSizeDeDialogCommand}" Cursor="Hand" VerticalAlignment="Top">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Form -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <!-- Size -->
                        <TextBlock Text="Chọn Size *" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding SelectedSize}"
                                      DisplayMemberPath="TenSize" BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- De Banh -->
                        <TextBlock Text="Chọn Đế bánh (tùy chọn)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <ComboBox ItemsSource="{Binding DeBanhs}" SelectedItem="{Binding SelectedDe}"
                                      DisplayMemberPath="TenDeBanh" BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        </Border>

                        <!-- Price Preview -->
                        <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Giá theo size:" FontSize="13" Foreground="{StaticResource Gray500}"/>
                                    <TextBlock Text="{Binding PreviewGiaBanSize, StringFormat={}{0:N0} đ}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Phụ thu đế:" FontSize="13" Foreground="{StaticResource Gray500}"/>
                                    <TextBlock Text="{Binding PreviewGiaThem, StringFormat=+{0:N0} đ}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource WarningOrange}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Border BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,4,0,0">
                                    <Grid>
                                        <TextBlock Text="Tổng giá:" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                                        <TextBlock Text="{Binding PreviewGia, StringFormat={}{0:N0} đ}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelSizeDeDialogCommand}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="32,14">
                                        <TextBlock Text="Hủy" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding ConfirmAddToCartCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="32,14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                                <GradientStop Color="#818CF8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm vào giỏ" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ ORDER DETAIL DIALOG ═══════════════ -->
        <Grid Visibility="{Binding IsOrderDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="600" MaxHeight="550"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Chi tiết đơn hàng" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="14" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Run Text="Mã phiếu: "/>
                                <Run Text="{Binding SelectedPhieuBan.MaPhieuBan, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseOrderDetailCommand}" Cursor="Hand" VerticalAlignment="Top">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Detail Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Table Header -->
                                    <Border Background="{StaticResource Gray50}" CornerRadius="8,8,0,0" Padding="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.4*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.6*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="PIZZA" Style="{StaticResource TableHeaderStyle}" TextAlignment="Left" Padding="12,10"/>
                                            <TextBlock Grid.Column="1" Text="Size" Style="{StaticResource TableHeaderStyle}"/>
                                            <TextBlock Grid.Column="2" Text="&#x110;&#x1EBF;" Style="{StaticResource TableHeaderStyle}"/>
                                            <TextBlock Grid.Column="3" Text="SL" Style="{StaticResource TableHeaderStyle}"/>
                                            <TextBlock Grid.Column="4" Text="Th&#xE0;nh ti&#x1EC1;n" Style="{StaticResource TableHeaderStyle}"/>
                                        </Grid>
                                    </Border>

                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding SelectedChiTiets}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2.4*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="1*"/>
                                                            <ColumnDefinition Width="0.6*"/>
                                                            <ColumnDefinition Width="1.2*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,6">
                                                            <Border Width="36" Height="36" CornerRadius="8" Background="{StaticResource Gray100}" ClipToBounds="True" Margin="0,0,8,0" VerticalAlignment="Center">
                                                                <Grid>
                                                                    <TextBlock Text="&#x1F355;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding HangHoa.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                </Grid>
                                                            </Border>
                                                            <TextBlock Text="{Binding HangHoa.TenHangHoa}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray800}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding DoanhMucSize.TenSize}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding DoanhMucDe.TenDeBanh}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding SoLuong}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="4" Text="{Binding ThanhTien, StringFormat={}{0:N0} đ}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource PrimaryBlue}" FontWeight="SemiBold"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <!-- GhiChu display -->
                        <Border Background="{StaticResource Gray50}" CornerRadius="8" Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding SelectedPhieuBan.GhiChu, Converter={StaticResource StringToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="&#x1F4DD; Ghi ch&#xFA;:" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedPhieuBan.GhiChu}" FontSize="13" Foreground="{StaticResource Gray800}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Grid>
                            <TextBlock Text="T&#x1ED5;ng ti&#x1EC1;n:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedPhieuBan.TongTien, StringFormat={}{0:N0} &#x111;}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ LOADING OVERLAY ═══════════════ -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBlue}"/>
                <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray500}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

