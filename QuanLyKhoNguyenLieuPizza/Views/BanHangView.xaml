<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.BanHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:banhang="clr-namespace:QuanLyKhoNguyenLieuPizza.Views.BanHang"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:BanHangViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Gray50}">

        <!-- ═══════════════ MAIN POS VIEW ═══════════════ -->
        <Grid Visibility="{Binding IsMainView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TIÊU ĐỀ TRANG & THẺ THỐNG KÊ GỌN & NÚT LỊCH SỬ -->
            <Grid Grid.Row="0" Margin="0,0,70,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- Tổng đơn -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <!-- Doanh thu -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <!-- Lịch sử đơn hàng -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tiêu đề trang -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <ui:SymbolIcon Symbol="Cart24" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Bán hàng Pizza" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Chọn pizza và thanh toán" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Box Tổng đơn hôm nay -->
                <Border Grid.Column="1" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="12" Height="44" Padding="12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="10" Width="30" Height="30" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Cart24" FontSize="14" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock Text="Tổng đơn hôm nay" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,0,0,1"/>
                            <TextBlock Text="{Binding TongDonHomNay}" FontSize="15" FontWeight="Bold" Foreground="#059669"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Box Doanh thu hôm nay -->
                <Border Grid.Column="3" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1" CornerRadius="12" Height="44" Padding="12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="10" Width="30" Height="30" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="Wallet24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="0,2,0,0">
                            <TextBlock Text="Doanh thu hôm nay" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,0,0,1"/>
                            <TextBlock Text="{Binding DoanhThuHomNay, StringFormat={}{0:N0} đ}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Order History Nút -->
                <Button Grid.Column="5" Command="{Binding ShowOrderHistoryCommand}" Cursor="Hand" Height="44" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12" Padding="20,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="History24" FontSize="16" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Lịch sử đơn hàng" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- NỘI DUNG POS: Thực đơn + Giỏ hàng -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- THỰC ĐƠN SẢN PHẨM -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tìm kiếm -->
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Symbol="Search24" FontSize="17" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="Tìm kiếm sản phẩm..." FontSize="14" Foreground="{StaticResource Gray400}"
                                           Padding="4,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SearchTextBox" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14" Padding="0" VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Product Grid -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding HangHoas}" HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" VerticalAlignment="Top"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectHangHoaCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,12,12">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="card" Background="White" CornerRadius="14" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.04"/>
                                                        </Border.Effect>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="200"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Product Hình ảnh -->
                                                            <Border Grid.Row="0" CornerRadius="14,14,0,0" Background="{StaticResource Gray100}" ClipToBounds="True">
                                                                <Grid>
                                                                    <ui:SymbolIcon Symbol="FoodPizza24" FontSize="40" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}"
                                                                           Stretch="UniformToFill"/>
                                                                    <!-- Lớp mờ khi hết hàng -->
                                                                    <Border Background="#B0FFFFFF" CornerRadius="0">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                            <Border Background="#FEE2E2" CornerRadius="8" Padding="12,6" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                                                <TextBlock Text="HẾT HÀNG" FontSize="13" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                                                                            </Border>
                                                                            <Border Background="#FFF7ED" CornerRadius="6" Padding="8,4" HorizontalAlignment="Center" MaxWidth="180">
                                                                                <TextBlock Text="{Binding OutOfStockNote}" FontSize="10" Foreground="#C2410C" 
                                                                                           TextWrapping="Wrap" TextAlignment="Center" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                                                                            </Border>
                                                                        </StackPanel>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Info -->
                                                            <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                                                <TextBlock Text="{Binding TenHangHoa}" FontSize="13" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource Gray400}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding MaHangHoa}" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="card" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                                            <Setter TargetName="card" Property="Opacity" Value="0.75"/>
                                                            <Setter TargetName="card" Property="BorderBrush" Value="#FECACA"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Trống -->
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding HangHoas.Count, Converter={StaticResource IntToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="FoodPizza24" FontSize="40" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            <TextBlock Text="Chưa có sản phẩm nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- CART -->
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tiêu đề Giỏ hàng -->
                        <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" Padding="20,16">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Cart24" FontSize="18" Foreground="{StaticResource PrimaryBlue}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Giỏ hàng" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}" VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource PrimaryBlue}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TongSoMon}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Command="{Binding ClearCartCommand}" Cursor="Hand" VerticalAlignment="Center">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock x:Name="txt" Text="Xóa tất cả" FontSize="12" Foreground="{StaticResource DangerRed}" Cursor="Hand"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="txt" Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Cart Items -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="8,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Product Hình ảnh -->
                                                <Border Width="48" Height="48" CornerRadius="10" Background="{StaticResource Gray100}" ClipToBounds="True" Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <Grid>
                                                        <TextBlock Text="&#x1F355;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <Image Source="{Binding HangHoa.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding HangHoa.TenHangHoa}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Size.TenSize}" FontSize="11" Foreground="{StaticResource PrimaryBlue}" FontWeight="Medium"/>
                                                        <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource Gray300}" Visibility="{Binding DeBanh.TenDeBanh, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding DeBanh.TenDeBanh}" FontSize="11" Foreground="{StaticResource Gray500}" Visibility="{Binding DeBanh.TenDeBanh, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DonGia, StringFormat={}{0:N0} đ}" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,2,0,4"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="b" Background="{StaticResource Gray100}" CornerRadius="6" Width="28" Height="28">
                                                                        <TextBlock Text="−" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="b" Property="Background" Value="{StaticResource Gray200}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                        <TextBlock Text="{Binding SoLuong}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"
                                                                   VerticalAlignment="Center" Margin="12,0"/>
                                                        <Button Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" Cursor="Hand">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="b" Background="{StaticResource LightBlue}" CornerRadius="6" Width="28" Height="28">
                                                                        <TextBlock Text="+" FontSize="16" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="b" Property="Background" Value="#DCE0FF"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding ThanhTien, StringFormat={}{0:N0} đ}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                                    <Button Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Right" Margin="0,6,0,0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <ui:SymbolIcon x:Name="txt" Symbol="Delete24" FontSize="14" Foreground="{StaticResource Gray400}"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="txt" Property="Foreground" Value="{StaticResource DangerRed}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Giỏ hàng trống -->
                        <TextBlock Grid.Row="1" Text="Giỏ hàng trống" FontSize="14" Foreground="{StaticResource Gray300}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding CartItems.Count, Converter={StaticResource IntToVisibilityConverter}}"/>

                        <!-- Checkout Chân trang -->
                        <!-- Checkout Chân trang -->
                        <Border Grid.Row="2" CornerRadius="0,0,16,16" Padding="20,16" BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <!-- Tổng tiền hàng -->
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Tổng tiền hàng" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                    <TextBlock Text="{Binding TongTienGioHang, StringFormat={}{0:N0}}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray900}" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Giảm giá -->
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="Giảm giá" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center"/>
                                    <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Width="100" HorizontalAlignment="Right" Padding="8,6">
                                        <TextBox Text="{Binding GiamGia, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="{StaticResource Gray900}" TextAlignment="Right"/>
                                    </Border>
                                </Grid>

                                <!-- Khách cần trả -->
                                <Grid Margin="0,0,0,16">
                                    <TextBlock Text="Khách cần trả" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                                    <TextBlock Text="{Binding KhachCanTra, StringFormat={}{0:N0}}" FontSize="20" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Phương thức -->
                                <ListBox ItemsSource="{Binding DanhSachPhuongThucTT}" SelectedItem="{Binding SelectedPhuongThucTT}" Background="Transparent" BorderThickness="0" Margin="0,0,0,16" ItemContainerStyle="{x:Null}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Cursor="Hand" Background="Transparent">
                                                <Grid Width="20" Height="20" Margin="0,0,10,0">
                                                    <Ellipse Stroke="{StaticResource Gray400}" StrokeThickness="2" Fill="White" x:Name="outer"/>
                                                    <Ellipse Width="10" Height="10" Fill="#0284C7" x:Name="inner" Visibility="Hidden"/>
                                                </Grid>
                                                <TextBlock Text="{Binding}" FontSize="15" Foreground="{StaticResource Gray700}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="outer" Property="Stroke" Value="#0284C7"/>
                                                    <Setter TargetName="outer" Property="StrokeThickness" Value="2.5"/>
                                                    <Setter TargetName="inner" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.Resources>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Margin" Value="0,0,0,0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        </Style>
                                    </ListBox.Resources>
                                </ListBox>

                                <!-- Khu vực Thanh toán Tiền mặt (Hiện khi IsChuyenKhoan = False) -->
                                <StackPanel Visibility="{Binding IsChuyenKhoan, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <!-- Khách thanh toán -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Khách thanh toán" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center"/>
                                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Width="100" HorizontalAlignment="Right" Padding="8,6">
                                            <TextBox Text="{Binding TienKhachDua, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="{StaticResource Gray900}" TextAlignment="Right"/>
                                        </Border>
                                    </Grid>
                                    
                                    <!-- Cảnh báo tiền thiếu -->
                                    <TextBlock Text="{Binding ThongBaoTienKhachThieu}" 
                                               Visibility="{Binding IsTienKhachThieu, Converter={StaticResource BoolToVisibilityConverter}}" 
                                               Foreground="{StaticResource DangerRed}" 
                                               FontSize="13" FontWeight="SemiBold" 
                                               HorizontalAlignment="Right" Margin="0,0,0,12"/>
                                    
                                    <!-- Tiền thừa -->
                                    <Grid Margin="0,0,0,16">
                                        <TextBlock Text="Tiền thừa trả khách" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                        <TextBlock Text="{Binding TienThua, StringFormat={}{0:N0}}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Khu vực Thanh toán Chuyển khoản (Hiện khi IsChuyenKhoan = True) -->
                                <Border Background="#F4F6FF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,16" Visibility="{Binding IsChuyenKhoan, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="White" CornerRadius="12" Padding="8" Margin="0,0,0,8">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                                            </Border.Effect>
                                            <Image Source="{Binding QrCodeUrl}" Width="130" Height="130" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>
                                        <TextBlock Text="MB Bank - 0123456789" FontWeight="Bold" FontSize="13" Foreground="{StaticResource Gray800}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="PIZZINN" FontSize="12" Foreground="{StaticResource Gray500}" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                        <TextBlock Text="{Binding KhachCanTra, StringFormat={}{0:N0} VNĐ}" FontSize="18" FontWeight="Bold" Foreground="#4F46E5" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Quét mã QR để thanh toán" FontSize="11" FontStyle="Italic" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Ghi chú -->
                                <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
                                    <Grid>
                                        <TextBox x:Name="GhiChuBox" Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="{StaticResource Gray800}" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="60"/>
                                        <TextBlock Text="Ghi chú (tùy chọn)..." FontSize="14" Foreground="{StaticResource Gray400}" IsHitTestVisible="False" VerticalAlignment="Top">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=GhiChuBox}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Text, ElementName=GhiChuBox}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!-- 2 Buttons -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="1.2*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Button Grid.Column="0" Command="{Binding PrintTamTinhCommand}" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btn1" Background="White" BorderBrush="#7C3AED" BorderThickness="1" CornerRadius="10" Padding="0,12" HorizontalAlignment="Stretch">
                                                    <TextBlock Text="In tạm tính" FontSize="13" FontWeight="SemiBold" Foreground="#7C3AED" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btn1" Property="Background" Value="#F5F3FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Grid.Column="2" Command="{Binding CheckoutCommand}" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btn2" CornerRadius="10" Padding="0,12" HorizontalAlignment="Stretch">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#818CF8" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <!-- 2 trạng thái text tương ứng 2 phương thức -->
                                                        <TextBlock Text="Thanh toán" FontSize="13" FontWeight="Bold" Foreground="White" Visibility="{Binding IsChuyenKhoan, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                                        <TextBlock Text="Xác nhận đã chuyển khoản" FontSize="13" FontWeight="Bold" Foreground="White" Visibility="{Binding IsChuyenKhoan, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btn2" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════════════ ORDER HISTORY VIEW ═══════════════ -->
        <Grid Visibility="{Binding IsOrderHistoryView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding BackToMainCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Quay lại" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Lịch sử đơn hàng" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Xem lại các đơn hàng đã bán" FontSize="12" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Date Filter -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Mail24" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Từ ngày:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FilterFromDate}" FontSize="13" Margin="0,0,20,0"/>
                    <TextBlock Text="Đến ngày:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FilterToDate}" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Bảng Đơn hàng -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.4*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mã phiếu" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Ngày bán" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Nhân viên" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Tổng tiền" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Thanh toán" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="Thao tác" Style="{StaticResource TableHeaderStyle}" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PhieuBanHangs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.4*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding MaPhieuBan}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding NgayBan, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding NhanVienBan.HoTen}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding TongTien, StringFormat={}{0:N0} đ}" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource Gray600}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ThanhToan, StringFormat={}{0:N0} đ}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlue}"/>

                                            <!-- Thao tác Nút -->
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Chi tiết -->
                                                <Button Command="{Binding DataContext.ViewOrderDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="Xem chi tiết" Cursor="Hand" Margin="0,0,8,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="30" Height="30">
                                                                <ui:SymbolIcon Symbol="Eye24" FontSize="15" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Sửa -->
                                                <Button Command="{Binding DataContext.EditPhieuBanCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="Sửa phương thức TT/Ghi chú" Cursor="Hand" Margin="0,0,8,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="#FFFBEB" CornerRadius="8" Width="30" Height="30">
                                                                <ui:SymbolIcon Symbol="Edit24" FontSize="15" Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FEF3C7"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Xóa -->
                                                <Button Command="{Binding DataContext.DeletePhieuBanCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="Xóa đơn hàng" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="30" Height="30">
                                                                <ui:SymbolIcon Symbol="Delete24" FontSize="15" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FECACA"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding PhieuBanHangs.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="History24" FontSize="38" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Không có đơn hàng nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ DIALOG USERCONTROLS ═══════════════ -->
        <banhang:SizeDeSelectionDialog DataContext="{Binding}"/>
        <banhang:OrderDetailDialog DataContext="{Binding}"/>
        <banhang:EditDeleteDialogs DataContext="{Binding}"/>

        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="999">
            <!-- Nền tối sang trọng (Dark SlateBlur effect) -->
            <Border Background="#E60F172A" />
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="120" Height="120" Margin="0,0,0,30" HorizontalAlignment="Center">
                    <!-- Vòng tròn nền mờ -->
                    <Ellipse Width="120" Height="120" Stroke="#1E293B" StrokeThickness="4"/>
                    
                    <!-- Progress ring hiện đại -->
                    <ui:ProgressRing IsIndeterminate="True" Foreground="#818CF8" Width="120" Height="120" BorderThickness="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing.Effect>
                            <DropShadowEffect BlurRadius="15" Color="#818CF8" Opacity="0.6" ShadowDepth="0"/>
                        </ui:ProgressRing.Effect>
                    </ui:ProgressRing>
                    
                    <!-- Biểu tượng giữa -->
                    <Border Width="60" Height="60" CornerRadius="30" Background="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="WalletCreditCard24" FontSize="26" Foreground="#E0E7FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                
                <TextBlock Text="ĐANG XỬ LÝ GIAO DỊCH" FontSize="20" FontWeight="Black" Foreground="White" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#818CF8" Opacity="0.4" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Hệ thống đang lưu hóa đơn, vui lòng đợi..." FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,8,0,0"/>

                <!-- Loading Dots hiện đại -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <!-- Dot 1 -->
                    <Ellipse Width="8" Height="8" Fill="#818CF8" Margin="4" Opacity="0.3">
                        <Ellipse.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.6"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-8" Duration="0:0:0.6"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    
                    <!-- Dot 2 -->
                    <Ellipse Width="8" Height="8" Fill="#818CF8" Margin="4" Opacity="0.3">
                        <Ellipse.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.6" BeginTime="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-8" Duration="0:0:0.6" BeginTime="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    
                    <!-- Dot 3 -->
                    <Ellipse Width="8" Height="8" Fill="#818CF8" Margin="4" Opacity="0.3">
                        <Ellipse.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:0.6" BeginTime="0:0:0.4"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)" From="0" To="-8" Duration="0:0:0.6" BeginTime="0:0:0.4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
