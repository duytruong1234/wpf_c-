<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.PhieuXuatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    
    <d:UserControl.DataContext>
        <vm:PhieuXuatViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <!-- MODERN COLOR PALETTE -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernInputBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ========== MANAGER VIEW ========== -->
        <Grid Background="{StaticResource Gray50}" Margin="24"
              Visibility="{Binding IsQuanLy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Title + Actions -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Qu?n l� phi?u xu?t" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Duy?t v� theo d�i y�u c?u xu?t kho" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource ModernInputBorder}" Width="320" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                        <TextBox x:Name="SearchTextBox" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="T�m ki?m phi?u xu?t..." FontSize="14" Foreground="{StaticResource Gray400}"
                                   VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Button Grid.Column="2" Command="{Binding CreatePhieuXuatCommand}" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="T?o phi?u xu?t" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Summary Stat Cards -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#FFF7ED" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource WarningOrange}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ch? duy?t" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding CountChoDuyet}" FontSize="22" FontWeight="Bold" Foreground="#92400E"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,0,5,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#F0FDF4" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource SuccessGreen}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="�� duy?t" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding CountDaDuyet}" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource LightBlue}" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBlue}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="T?ng phi?u xu?t" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding PhieuXuats.Count}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Filters -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Title -->
                    <StackPanel Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="B? l?c" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Nh�n vi�n xu?t" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <ComboBox ItemsSource="{Binding NhanViens}" SelectedItem="{Binding SelectedNhanVienFilter}"
                                      DisplayMemberPath="HoTen" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="T? ng�y" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding TuNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="�?n ng�y" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding DenNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="16,0,0,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Tr?ng th�i" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="Ch? duy?t" IsChecked="{Binding FilterChoDuyet}" Margin="0,0,12,0" FontSize="13"/>
                            <CheckBox Content="�� duy?t" IsChecked="{Binding FilterDaDuyet}" Margin="0,0,12,0" FontSize="13"/>
                            <CheckBox Content="�� h?y" IsChecked="{Binding FilterDaHuy}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Row="1" Grid.Column="4" Command="{Binding ClearFilterCommand}" Cursor="Hand" VerticalAlignment="Bottom" Margin="12,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="16,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="X�a l?c" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Data Table -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="10,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="M� phi?u xu?t" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Ng�y y�u c?u" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="NV y�u c?u" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Ng�y duy?t" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="NV duy?t" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="Tr?ng th�i" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="6" Text="Thao t�c" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PhieuXuats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border Background="Transparent" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="1*"/>
                                                    <ColumnDefinition Width="0.8*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="{Binding MaPhieuXuat}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding NgayYeuCau, StringFormat=\{0:HH:mm dd/MM/yyyy\}}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding NhanVienYeuCau.HoTen}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="3" Text="{Binding NgayDuyet, StringFormat=\{0:HH:mm dd/MM/yyyy\}}" Style="{StaticResource TableCellStyle}"/>
                                                <TextBlock Grid.Column="4" Text="{Binding NhanVienDuyet.HoTen}" Style="{StaticResource TableCellStyle}"/>

                                                <Border Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="12" Padding="12,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FEF3CD"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Ch? duy?t"/>
                                                                <Setter Property="Foreground" Value="#92400E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="2">
                                                                        <Setter Property="Text" Value="�� duy?t"/>
                                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                        <Setter Property="Text" Value="�� h?y"/>
                                                                        <Setter Property="Foreground" Value="#DC2626"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <Button Grid.Column="6" ToolTip="Chi ti?t"
                                                        Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" HorizontalAlignment="Center">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Padding="8,6" Width="32" Height="32">
                                                                <TextBlock Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding PhieuXuats.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="20" Width="80" Height="80" Margin="0,0,0,16">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Gray300}"/>
                        </Border>
                        <TextBlock Text="Kh�ng c� phi?u xu?t n�o" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Th? thay d?i b? l?c ho?c t?o phi?u xu?t m?i" FontSize="13" Foreground="{StaticResource Gray300}" Margin="0,6,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== EMPLOYEE VIEW ========== -->
        <Grid Background="{StaticResource Gray50}" Margin="32"
              Visibility="{Binding IsNhanVien, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Employee Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="L?ch s? phi?u xu?t" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource Gray900}" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource ModernInputBorder}" Width="280" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                        <TextBox x:Name="SearchTextBox2" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Background="Transparent" FontSize="14" VerticalContentAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="T�m ki?m phi?u xu?t" FontSize="14" Foreground="{StaticResource Gray400}"
                                   VerticalAlignment="Center" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox2}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Button Grid.Column="2" Command="{Binding CreatePhieuXuatCommand}"
                        VerticalAlignment="Center" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12"
                                    BorderBrush="{StaticResource Gray200}" BorderThickness="1" Background="White">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="T?o phi?u xu?t" FontSize="14" Foreground="{StaticResource Gray800}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Employee Filters Card -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="B? l?c" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="T? ng�y" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding TuNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="�?n ng�y" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Style="{StaticResource ModernInputBorder}">
                            <DatePicker SelectedDate="{Binding DenNgay}" BorderThickness="0" Background="Transparent" FontSize="13"/>
