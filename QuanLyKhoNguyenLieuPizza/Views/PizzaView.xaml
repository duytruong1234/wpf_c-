<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.PizzaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">
    
    <d:UserControl.DataContext>
        <vm:PizzaViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
    <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#F1F5F9" Offset="0.5"/>
            <GradientStop Color="#F8FAFC" Offset="1"/>
        </LinearGradientBrush>
    </Grid.Background>
        <Grid Margin="32,24,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="14" Width="48" Height="48" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="FoodPizza24" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý món ăn" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Danh sách món ăn" FontSize="13" Foreground="{StaticResource Gray400}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding OpenAddPopupCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="12" Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="3" Direction="270" Color="#5B6AFF" Opacity="0.25"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thêm món ăn" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- THẺ THỐNG KÊ -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng món ăn" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="FoodPizza24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TotalPizza}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Đang bán" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountDangBan}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryGreen}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Ngừng bán" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#EF4444" Offset="0"/>
                                        <GradientStop Color="#F87171" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountNgungBan}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerRed}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- FILTERS -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tìm kiếm -->
                    <Border Grid.Column="0" Background="{StaticResource Gray50}" CornerRadius="10" 
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Search24" FontSize="14" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center"
                                     Foreground="{StaticResource Gray800}" Padding="0,9"/>
                            <TextBlock Grid.Column="1" Text="Tìm kiếm món ăn..." FontSize="13" 
                                       Foreground="{StaticResource Gray300}" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Padding="0,9">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Tình trạng -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Tình trạng:" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                        <CheckBox Content="Đang bán" IsChecked="{Binding FilterDangBan}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <CheckBox Content="Ngừng bán" IsChecked="{Binding FilterNgungBan}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Kích thước -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Kích thước:" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                        <ComboBox ItemsSource="{Binding KichThuocOptions}" 
                                  SelectedItem="{Binding SelectedKichThuocFilter}"
                                  Width="80" FontSize="12"/>
                    </StackPanel>

                    <!-- Clear filter -->
                    <Button Grid.Column="6" Command="{Binding ClearFiltersCommand}" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="14,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" 
                                                   Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Xóa lọc" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedLight}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- PIZZA TABLE -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề Bảng -->
                    <Border Grid.Row="0" Background="{StaticResource Gray50}" Padding="24,14" 
                            BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.6*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MÃ MÓN ĂN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Grid.Column="1" Text="ẢNH" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="TÊN MÓN ĂN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Grid.Column="3" Text="SIZE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="GIÁ BÁN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Right"/>
                            <TextBlock Grid.Column="5" Text="TRẠNG THÁI" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="THAO TÁC" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Nội dung bảng -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredPizzas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="24,12" BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FAFBFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.6*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1.6*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Mã pizza -->
                                            <TextBlock Grid.Column="0" Text="{Binding MaPizza}" 
                                                       FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}" 
                                                       VerticalAlignment="Center"/>

                                            <!-- Hình ảnh -->
                                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    Background="{StaticResource Gray100}">
                                                <Border CornerRadius="20" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Border>

                                            <!-- Tên pizza + Mô tả -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TenPizza}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                                <TextBlock Text="{Binding MoTa}" FontSize="11" Foreground="{StaticResource Gray400}" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="200" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Kích thước -->
                                            <Border Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                    CornerRadius="8" Padding="10,5" Background="{StaticResource Gray50}">
                                                <TextBlock Text="{Binding KichThuoc}" FontSize="12" FontWeight="SemiBold" 
                                                           Foreground="{StaticResource Gray600}"/>
                                            </Border>

                                            <!-- Giá bán -->
                                            <TextBlock Grid.Column="4" Text="{Binding GiaBanFormatted, StringFormat='{}{0} đ'}" 
                                                       FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray800}" 
                                                       TextAlignment="Right" VerticalAlignment="Center"/>

                                            <!-- Trạng thái -->
                                            <Border Grid.Column="5" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="20" Padding="12,5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTrangThaiActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Đang bán"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTrangThaiActive}" Value="False">
                                                                    <Setter Property="Text" Value="Ngừng bán"/>
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Thao tác -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding ToggleStatusCommand}" Cursor="Hand" ToolTip="Đổi trạng thái" Margin="0,0,4,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="statusBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32">
                                                                <ui:SymbolIcon x:Name="statusIcon" Symbol="ArrowSync24" FontSize="12" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="statusBorder" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                                                    <Setter TargetName="statusIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding OpenRecipeCommand}" Cursor="Hand" ToolTip="Cài đặt công thức" Margin="0,0,4,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="recipeBorder" Background="#E0E7FF" CornerRadius="8" Width="32" Height="32">
                                                                <ui:SymbolIcon x:Name="recipeIcon" Symbol="Book24" FontSize="12" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="recipeBorder" Property="Background" Value="#4F46E5"/>
                                                                    <Setter TargetName="recipeIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding EditCommand}" Cursor="Hand" ToolTip="Sửa" Margin="0,0,4,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="editBorder" Background="{StaticResource WarningOrangeLight}" CornerRadius="8" Width="32" Height="32">
                                                                <ui:SymbolIcon x:Name="editIcon" Symbol="Edit24" FontSize="12" Foreground="{StaticResource WarningOrange}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="editBorder" Property="Background" Value="{StaticResource WarningOrange}"/>
                                                                    <Setter TargetName="editIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding DeleteCommand}" Cursor="Hand" ToolTip="Xóa">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="delBorder" Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="32" Height="32">
                                                                <ui:SymbolIcon x:Name="delIcon" Symbol="Delete24" FontSize="12" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="delBorder" Property="Background" Value="{StaticResource DangerRed}"/>
                                                                    <Setter TargetName="delIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Trạng thái Trống -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="20" Width="56" Height="56" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="24" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ADD/EDIT POPUP -->
        <Grid Visibility="{Binding IsAddEditPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000">
            <Border Width="520" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="28,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="FoodPizza24" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Thêm món ăn mới"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Text" Value="Chỉnh sửa món ăn"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding ClosePopupCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                        </Grid>
                    </Border>

                    <!-- Biểu mẫu Body -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="28,24,28,12">
                            <!-- Mã pizza -->
                            <TextBlock Text="Mã món ăn *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,0,0,6"/>
                            <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,10">
                                <TextBox Text="{Binding FormMaPizza, UpdateSourceTrigger=PropertyChanged}" 
                                         IsReadOnly="{Binding IsEditing}"
                                         FontSize="13" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray800}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Opacity" Value="0.6"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Border>

                            <!-- Tên pizza -->
                            <TextBlock Text="Tên món ăn *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,14,0,6"/>
                            <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,10">
                                <TextBox Text="{Binding FormTenPizza, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="13" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray800}"/>
                            </Border>

                            <!-- Loại món ăn -->
                            <TextBlock Text="Loại món ăn *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,14,0,6"/>
                            <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,0">
                                <ComboBox ItemsSource="{Binding LoaiHangHoas}" SelectedItem="{Binding FormLoaiMonAn}"
                                          DisplayMemberPath="TenLoaiHangHoa"
                                          Background="Transparent" BorderThickness="0" FontSize="13" Padding="0,10"/>
                            </Border>

                            <!-- Đơn vị tính -->
                            <TextBlock Text="Đơn vị tính *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,14,0,6"/>
                            <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,0">
                                <ComboBox ItemsSource="{Binding DonViTinhs}" SelectedItem="{Binding FormDonViTinh}"
                                          DisplayMemberPath="TenDonVi"
                                          Background="Transparent" BorderThickness="0" FontSize="13" Padding="0,10"/>
                            </Border>

                            <!-- Row: Kích thước + Giá bán -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Kích thước *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,0,0,6"/>
                                    <ComboBox ItemsSource="{Binding KichThuocOptions}" SelectedItem="{Binding FormKichThuoc}"
                                              FontSize="13" Padding="14,10">
                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Style>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Giá bán *" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,10">
                                        <TextBox Text="{Binding FormGiaBan, UpdateSourceTrigger=PropertyChanged}" 
                                                 FontSize="13" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray800}"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Hình ảnh -->
                            <TextBlock Text="Hình ảnh" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,14,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="{StaticResource Gray50}" CornerRadius="10" BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="14,10">
                                    <TextBox Text="{Binding FormHinhAnh, UpdateSourceTrigger=PropertyChanged}" 
                                             FontSize="13" Background="Transparent" BorderThickness="0" Foreground="{StaticResource Gray800}" IsReadOnly="True"/>
                                </Border>
                                <Button Grid.Column="1" Command="{Binding BrowseImageCommand}" Cursor="Hand" Margin="8,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="imgBorder" Background="{StaticResource Gray100}" CornerRadius="10" Padding="14,10">
                                                <TextBlock Text="Chọn ảnh" FontSize="12" Foreground="{StaticResource Gray600}" FontWeight="Medium"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="imgBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Tình trạng -->
                            <CheckBox Content="Đang bán" IsChecked="{Binding FormTrangThai}" FontSize="12" Margin="0,16,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Chân trang Nút bấm -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource Gray100}" BorderThickness="0,1,0,0" Padding="28,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding ClosePopupCommand}" Cursor="Hand" Margin="0,0,12,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBorder" Background="{StaticResource Gray100}" CornerRadius="10" Padding="20,10">
                                            <TextBlock Text="Hủy" FontSize="13" Foreground="{StaticResource Gray600}" FontWeight="Medium"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding SaveCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="saveBorder" CornerRadius="10" Padding="20,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#5B6AFF" Offset="0"/>
                                                    <GradientStop Color="#818CF8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Thêm mới"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Text" Value="Cập nhật"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="saveBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- RECIPE POPUP (Popup Công Thức / Quy Định) -->
        <Grid Visibility="{Binding IsRecipePopupOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000">
            <Border Width="900" MaxHeight="700" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="28,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#FBBF24" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="White"/>
                                <TextBlock Text="Thành phần nguyên liệu của món ăn" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseRecipePopupCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                        </Grid>
                    </Border>

                    <!-- Nội dung -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="28,20">
                        <StackPanel>
                            <!-- Thông tin Pizza -->
                            <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="Pizza:" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding RecipePizza.TenPizza}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray800}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Left">
                                        <TextBlock Text="Kích thước:" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding RecipePizza.KichThuoc}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray700}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Form Thêm/sửa Thành Phần -->
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Nguyên liệu (*)" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding AllNguyenLieus}" SelectedItem="{Binding RecipeSelectedNguyenLieu}" DisplayMemberPath="TenNguyenLieu" Background="White" BorderBrush="{StaticResource Gray200}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Text="Số lượng (*)" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding RecipeSoLuong, UpdateSourceTrigger=PropertyChanged}" Background="White" BorderBrush="{StaticResource Gray200}"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                        <TextBlock Text="Đơn vị" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding DonViTinhs}" SelectedItem="{Binding RecipeSelectedDonVi}" DisplayMemberPath="TenDonVi" Background="White" BorderBrush="{StaticResource Gray200}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Command="{Binding SaveRecipeItemCommand}" Cursor="Hand" Margin="0,0,8,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="saveBorder" Background="{StaticResource PrimaryBlue}" CornerRadius="8" Padding="16,4" MinHeight="32">
                                                        <TextBlock Foreground="White" FontWeight="Medium" FontSize="13" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Thêm"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRecipeEditing}" Value="True">
                                                                            <Setter Property="Text" Value="Lưu"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="saveBorder" Property="Background" Value="#1D4ED8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Command="{Binding CancelRecipeEditCommand}" Cursor="Hand" Visibility="{Binding IsRecipeEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="cancelBorder" Background="{StaticResource Gray100}" CornerRadius="8" Padding="16,4" MinHeight="32">
                                                        <TextBlock Text="Hủy" Foreground="{StaticResource Gray700}" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="cancelBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Bảng Công Thức -->
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="12,12,0,0" Padding="20,16" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Nguyên liệu" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray700}"/>
                                            <TextBlock Grid.Column="1" Text="Số lượng" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray700}"/>
                                            <TextBlock Grid.Column="2" Text="Đơn vị" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray700}"/>
                                            <TextBlock Grid.Column="3" Text="Thao tác" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray700}" HorizontalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Body -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                        <ItemsControl ItemsSource="{Binding RecipeItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="20,16" Background="Transparent">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="3*"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="1.5*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0" Text="{Binding TenNguyenLieu}" FontSize="13" Foreground="{StaticResource Gray800}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding SoLuongFormatted}" FontSize="13" Foreground="{StaticResource Gray700}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding TenDonVi}" FontSize="13" Foreground="{StaticResource Gray700}" VerticalAlignment="Center"/>
                                                            
                                                            <!-- Thao tác (Sửa và Xóa) -->
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                                                                <Button Command="{Binding EditCommand}" Cursor="Hand" ToolTip="Sửa nguyên liệu" Margin="0,0,8,0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="editBorder" Background="#EEF2FF" CornerRadius="8" Width="32" Height="32">
                                                                                <ui:SymbolIcon Symbol="Edit24" FontSize="14" Foreground="#4338CA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="editBorder" Property="Background" Value="#E0E7FF"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                                <Button Command="{Binding DeleteCommand}" Cursor="Hand" ToolTip="Xóa nguyên liệu">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="delBorder" Background="#FEE2E2" CornerRadius="8" Width="32" Height="32">
                                                                                <ui:SymbolIcon Symbol="Delete24" FontSize="12" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="delBorder" Property="Background" Value="#FCA5A5"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource Gray100}" BorderThickness="0,1,0,0" Padding="28,16" CornerRadius="0,0,20,20">
                        <Button Command="{Binding CloseRecipePopupCommand}" Cursor="Hand" HorizontalAlignment="Right">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="closeBorder" Background="{StaticResource Gray100}" CornerRadius="10" Padding="24,10">
                                        <TextBlock Text="Đóng" FontSize="13" Foreground="{StaticResource Gray600}" FontWeight="Medium"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="closeBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS DIALOG -->
        <Grid Visibility="{Binding IsStatusDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="440"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Trạng thái món ăn" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseStatusDialogCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                    </Grid>

                    <!-- Info -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <TextBlock Text="Tên món ăn" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock Text="{Binding StatusPizza.TenPizza}" FontSize="14" Foreground="{StaticResource Gray800}"/>
                        </Border>

                        <TextBlock Text="Trạng thái hiện tại" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border CornerRadius="10" Padding="14,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#D1FAE5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusPizza.TrangThai}" Value="False">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="14" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Đang bán"/>
                                        <Setter Property="Foreground" Value="#059669"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusPizza.TrangThai}" Value="False">
                                                <Setter Property="Text" Value="Ngừng bán"/>
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Nút chuyển trạng thái -->
                    <Button Grid.Row="2" Command="{Binding ConfirmToggleStatusCommand}" Cursor="Hand" HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="10" Padding="40,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusPizza.TrangThai}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Ngừng bán"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusPizza.TrangThai}" Value="False">
                                                        <Setter Property="Text" Value="Bán lại"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
