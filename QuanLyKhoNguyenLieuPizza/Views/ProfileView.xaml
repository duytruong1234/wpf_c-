<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.ProfileView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
         xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:views="clr-namespace:QuanLyKhoNguyenLieuPizza.Views"
         xmlns:behaviors="clr-namespace:QuanLyKhoNguyenLieuPizza.Behaviors"
         mc:Ignorable="d" 
         d:DesignHeight="620" d:DesignWidth="540">

    <d:UserControl.DataContext>
        <vm:ProfileViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="20" MaxWidth="540"
            ClipToBounds="True"
            Effect="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- GRADIENT Tiêu đề WITH AVATAR -->
            <Grid Grid.Row="0">
                <!-- Gradient Background -->
                <Border Background="{StaticResource HeaderGradient}" Height="160"/>

                <!-- Decorative circles -->
                <Ellipse Width="120" Height="120" Opacity="0.08" Fill="White"
                         HorizontalAlignment="Right" VerticalAlignment="Top"
                         Margin="0,-30,-30,0"
                         IsHitTestVisible="False"/>
                <Ellipse Width="80" Height="80" Opacity="0.06" Fill="White"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom"
                         Margin="-20,-10,0,0"
                         IsHitTestVisible="False"/>

                <!-- Close Nút -->
                <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseCommand}" Margin="0,16,16,0" Panel.ZIndex="10"/>

                <!-- Avatar + Name overlay -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,32,0,0">
                    <!-- Avatar -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,14">
                        <!-- Avatar ring -->
                        <Border Width="108" Height="108" CornerRadius="54"
                                Background="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- Default icon -->
                        <Border Width="100" Height="100" CornerRadius="50" 
                                Background="{StaticResource LightBlue}" 
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ClipToBounds="True"
                                Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Person24" FontSize="44" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Avatar Hình ảnh -->
                        <Border Width="100" Height="100" CornerRadius="50" 
                                ClipToBounds="True"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <!-- Change avatar button -->
                        <Button Command="{Binding ChangeAvatarCommand}"
                                Width="34" Height="34"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Cursor="Hand"
                                ToolTip="Đổi ảnh đại diện"
                                Margin="0,0,0,2">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="camBorder" Width="34" Height="34" CornerRadius="17" 
                                            Background="{StaticResource PrimaryBlue}" 
                                            BorderBrush="White" BorderThickness="3">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#5B6AFF" Opacity="0.3"/>
                                        </Border.Effect>
                                        <ui:SymbolIcon Symbol="Camera24" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="camBorder" Property="Background" Value="{StaticResource DarkBlue}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Name -->
                    <TextBlock Text="{Binding HoTen}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <!-- Role badge -->
                    <Border Background="#33FFFFFF" CornerRadius="12" Padding="14,5" 
                            HorizontalAlignment="Center" Margin="0,8,0,0">
                        <TextBlock Text="{Binding ChucVu}" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- CONTENT AREA -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" Padding="24,20,24,24">
                <StackPanel>
                    <!-- Avatar Save/Cancel Banner -->
                    <Border Visibility="{Binding IsAvatarChanged, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#F0FDF4"
                            CornerRadius="12"
                            Padding="16,14"
                            Margin="0,0,0,18"
                            BorderBrush="#BBF7D0"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Bạn đã chọn ảnh mới. Lưu thay đổi?" 
                                           FontSize="13" 
                                           Foreground="#16A34A" 
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Command="{Binding SaveAvatarCommand}" Cursor="Hand" Margin="0,0,10,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{StaticResource SuccessGreen}" CornerRadius="8" Padding="22,9">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Edit24" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Lưu ảnh" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#16A34A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Command="{Binding CancelAvatarChangeCommand}" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{StaticResource Gray200}" CornerRadius="8" Padding="22,9">
                                                <TextBlock Text="Hủy" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Info Cards Header -->
                    <Grid Margin="4,0,0,12">
                        <TextBlock Text="THÔNG TIN CÁ NHÂN" 
                                   FontSize="11" FontWeight="Bold" 
                                   Foreground="{StaticResource Gray400}"
                                   VerticalAlignment="Center"/>
                        <Button Command="{Binding EditProfileCommand}" 
                                Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,0">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Edit16" FontSize="12" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Sửa" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBlue}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button Command="{Binding CancelEditProfileCommand}" 
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,0" Margin="0,0,12,0">
                                <TextBlock Text="Hủy" FontSize="11" FontWeight="Medium" Foreground="{StaticResource Gray500}"/>
                            </Button>
                            <Button Command="{Binding SaveProfileCommand}" 
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4,0">
                                <TextBlock Text="Lưu" FontSize="11" FontWeight="Bold" Foreground="{StaticResource SuccessGreen}"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Username -->
                    <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,14" Margin="0,0,0,8"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource LightBlue}" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Person24" FontSize="18"
                                           Foreground="{StaticResource PrimaryBlue}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Tên đăng nhập" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Email -->
                    <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,14" Margin="0,0,0,8"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource LightBlue}" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Mail24" FontSize="18"
                                           Foreground="{StaticResource PrimaryBlue}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Email" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Email, TargetNullValue='Chưa cập nhật'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" TextTrimming="CharacterEllipsis" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Phone -->
                    <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,14" Margin="0,0,0,8"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource LightBlue}" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="Call24" FontSize="18"
                                           Foreground="{StaticResource PrimaryBlue}" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Số điện thoại *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding SDT, TargetNullValue='Chưa cập nhật'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBox Text="{Binding SDT, UpdateSourceTrigger=PropertyChanged}" behaviors:NumericInputBehavior.IsNumericOnly="True" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" BorderThickness="0" Background="Transparent" Padding="0" Margin="0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding ErrorSDT}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorSDT, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Birthday -->
                    <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,14" Margin="0,0,0,8"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource LightBlue}" Margin="0,0,14,0">
                                <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="16" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Ngày sinh *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}, TargetNullValue='Chưa cập nhật'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <DatePicker SelectedDate="{Binding NgaySinh, UpdateSourceTrigger=PropertyChanged}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" BorderThickness="0" Background="Transparent" Padding="0" Margin="-4,0,0,0" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding ErrorNgaySinh}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorNgaySinh, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Address -->
                    <Border Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,14" Margin="0,0,0,20"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource LightBlue}" Margin="0,0,14,0"
                                    VerticalAlignment="Top">
                                <ui:SymbolIcon Symbol="Location24" FontSize="16" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Địa chỉ" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding DiaChi, TargetNullValue='Chưa cập nhật'}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" TextWrapping="Wrap" Visibility="{Binding IsNotEditing, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                
                                <!-- Address editing form -->
                                <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Tỉnh/TP -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="Tỉnh / Thành phố *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,4"/>
                                        <views:SearchableComboBox ItemsSource="{Binding Provinces}" SelectedItem="{Binding SelectedProvince}" DisplayMemberPath="name" Placeholder="-- Chọn tỉnh/TP --" SearchPlaceholder="Tìm tỉnh/thành phố..."/>
                                        <TextBlock Text="{Binding ErrorTinhTP}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorTinhTP, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                    
                                    <!-- Phường/Xã -->
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="Phường / Xã *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,4"/>
                                        <views:SearchableComboBox ItemsSource="{Binding Wards}" SelectedItem="{Binding SelectedWard}" DisplayMemberPath="name" Placeholder="-- Chọn phường/xã --" SearchPlaceholder="Tìm phường/xã..."/>
                                        <TextBlock Text="{Binding ErrorPhuongXa}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorPhuongXa, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                    
                                    <!-- Thôn/Xóm -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,12,0,0">
                                        <TextBlock Text="Thôn / Xóm *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,4"/>
                                        <Border Background="White" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ErrorThonXom, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBox Text="{Binding FormThonXom, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                        <TextBlock Text="{Binding ErrorThonXom}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorThonXom, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                    
                                    <!-- Địa chỉ chi tiết -->
                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,12,0,0">
                                        <TextBlock Text="Số nhà / Đường *" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,0,0,4"/>
                                        <Border Background="White" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ErrorDiaChiChiTiet, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBox Text="{Binding FormDiaChiChiTiet, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                        <TextBlock Text="{Binding ErrorDiaChiChiTiet}" FontSize="11" Foreground="{StaticResource DangerRed}" Margin="0,4,0,0" Visibility="{Binding ErrorDiaChiChiTiet, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>



                    <Button Command="{Binding LogoutCommand}" Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource DangerRedLight}" CornerRadius="12" Padding="16,13" HorizontalAlignment="Stretch"
                                        BorderBrush="#FECDD3" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="SignOut24" FontSize="15" Foreground="{StaticResource DangerRed}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Đang xuất" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DangerRed}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="#FCA5A5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
