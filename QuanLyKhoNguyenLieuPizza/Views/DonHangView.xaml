<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.DonHangView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:DonHangViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
    <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#F1F5F9" Offset="0.5"/>
            <GradientStop Color="#F8FAFC" Offset="1"/>
        </LinearGradientBrush>
    </Grid.Background>
        <Grid Margin="32,24,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="14" Width="48" Height="48" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Cart24" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý đơn hàng" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                <TextBlock Text="Theo dõi lịch sử đơn hàng và xử lý đơn sai sót" FontSize="13" 
                                   Foreground="{StaticResource Gray400}" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Nút Thêm đơn hàng mới -->
                    <Button Command="{Binding NavigateToBanHangCommand}" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="addBorder" CornerRadius="12" Padding="18,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="3" Direction="270" Color="#5B6AFF" Opacity="0.25"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24" FontSize="16" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Thêm đơn hàng" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="addBorder" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Nút Làm mới -->
                    <Button Command="{Binding RefreshCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" 
                                        BorderThickness="1" CornerRadius="12" Width="44" Height="44">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.04"/>
                                    </Border.Effect>
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" 
                                               Foreground="{StaticResource Gray600}" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource LightBlue}"/>
                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- THẺ THỐNG KÊ -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tổng đơn hàng -->
                <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng đơn hàng" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Cart24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TongDonHang}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </Border>

                <!-- Doanh thu -->
                <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Doanh thu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#34D399" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Money24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TongDoanhThu, StringFormat='{}{0:N0}đ'}" FontSize="22" FontWeight="Bold" Foreground="#059669"/>
                    </StackPanel>
                </Border>

                <!-- NV bán chạy nhất -->
                <Border Grid.Column="4" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="NV bán chạy nhất" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                        <GradientStop Color="#FBBF24" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ui:SymbolIcon Symbol="Star24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TopNhanVienName}" FontSize="16" FontWeight="Bold" Foreground="#9A3412" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding TopNhanVienDoanhThu, StringFormat='{}{0:N0}đ'}" FontSize="12" Foreground="#EA580C" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- FILTERS -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tìm kiếm with Nơi giữ chỗ -->
                    <Border Grid.Column="0" Background="{StaticResource Gray50}" CornerRadius="10" 
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Search24" FontSize="14" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchBox" Grid.Column="1" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center"
                                     Foreground="{StaticResource Gray800}" Padding="0,9"/>
                            <TextBlock Grid.Column="1" Text="Tìm mã đơn, nhân viên, ghi chú..." FontSize="13" 
                                       Foreground="{StaticResource Gray300}" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Padding="0,9">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Từ ngày -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Từ:" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                        <DatePicker SelectedDate="{Binding TuNgay}" Width="130" FontSize="12"/>
                    </StackPanel>

                    <!-- Đến ngày -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Đến:" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                        <DatePicker SelectedDate="{Binding DenNgay}" Width="130" FontSize="12"/>
                    </StackPanel>

                    <!-- Lọc theo nhân viên -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="NV:" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                        <ComboBox ItemsSource="{Binding NhanViens}" SelectedItem="{Binding SelectedNhanVien}" 
                                  DisplayMemberPath="HoTen" Width="150" FontSize="12"/>
                    </StackPanel>

                    <!-- Clear filter -->
                    <Button Grid.Column="8" Command="{Binding ClearFilterCommand}" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="14,8">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" 
                                                   Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Xóa lọc" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource DangerRedLight}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- BẢNG ĐƠN HÀNG -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề Bảng -->
                    <Border Grid.Row="0" Background="{StaticResource Gray50}" Padding="24,14" 
                            BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0.9*"/>
                                <ColumnDefinition Width="0.7*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mã ĐƠN HÀNG" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Grid.Column="1" Text="THỜI GIAN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="NHÂN VIÊN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="THANH TOÁN" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="PHƯƠNG THỨC" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Nội dung bảng -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DonHangs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="24,14" BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#FAFBFF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.4*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="0.9*"/>
                                                <ColumnDefinition Width="0.7*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Mã đơn -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding MaDonHang}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                                                <TextBlock Text="{Binding GhiChu}" FontSize="11" Foreground="{StaticResource Gray400}" 
                                                           TextTrimming="CharacterEllipsis" MaxWidth="160" HorizontalAlignment="Left" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Thời gian -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding NgayTao, StringFormat={}{0:dd/MM/yyyy}}" 
                                                           FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray700}" TextAlignment="Center"/>
                                                <TextBlock Text="{Binding NgayTao, StringFormat={}{0:HH:mm}}" 
                                                           FontSize="11" Foreground="{StaticResource Gray400}" TextAlignment="Center" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <!-- Nhân viên -->
                                            <TextBlock Grid.Column="2" Text="{Binding NhanVien.HoTen}" 
                                                       FontSize="12" Foreground="{StaticResource Gray600}" TextAlignment="Center" VerticalAlignment="Center"/>

                                            <!-- Thanh toán -->
                                            <TextBlock Grid.Column="3" Text="{Binding ThanhToan, StringFormat='{}{0:N0} đ'}" 
                                                       FontSize="13" FontWeight="Bold" Foreground="{StaticResource Gray800}" TextAlignment="Right" VerticalAlignment="Center"/>

                                            <!-- Phương thức -->
                                            <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="8" Padding="10,5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding PhuongThucTT}" FontSize="11" FontWeight="Medium" Foreground="{StaticResource Gray600}"/>
                                            </Border>

                                            <!-- Thao tác -->
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,0"
                                                        ToolTip="Xem chi tiết đơn hàng">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="10" Padding="8,7" Width="36">
                                                                <ui:SymbolIcon x:Name="btnIcon" Symbol="Eye24" FontSize="13" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="{StaticResource PrimaryBlue}"/>
                                                                    <Setter TargetName="btnIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                
                                                <Button Command="{Binding DataContext.DeleteDonHangCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"
                                                        ToolTip="Xóa đơn hàng">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnDelBorder" Background="{StaticResource DangerRedLight}" CornerRadius="10" Padding="8,7" Width="36">
                                                                <ui:SymbolIcon x:Name="btnDelIcon" Symbol="Delete24" FontSize="13" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnDelBorder" Property="Background" Value="{StaticResource DangerRed}"/>
                                                                    <Setter TargetName="btnDelIcon" Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Loading State -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="20" Width="56" Height="56" Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="24" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- DETAIL OVERLAY -->
        <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Nền phủ -->
            <Border Background="#66111827">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseDetailCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Dialog -->
            <Border Width="640" MaxHeight="740" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="24" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="12" Direction="270" Color="#000000" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Detail Tiêu đề -->
                    <Border Grid.Row="0" Padding="32,28,32,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                                <GradientStop Color="#4F46E5" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ui:SymbolIcon Symbol="Cart24" FontSize="18" Foreground="#C7D2FE" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="Chi tiết đơn hàng" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Background="#26FFFFFF" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding SelectedDonHang.MaDonHang}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding CloseDetailCommand}" Cursor="Hand" VerticalAlignment="Top">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="closeBorder" Width="40" Height="40" CornerRadius="12" Background="#1AFFFFFF">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" 
                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="closeBorder" Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Nội dung cuộn -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel Margin="32,24,32,24">

                            <!-- Order Info Section -->
                            <TextBlock Text="Thông tin đơn hàng" FontSize="14" FontWeight="Bold" 
                                       Foreground="{StaticResource Gray800}" Margin="0,0,0,14"/>
                            
                            <Border Background="{StaticResource Gray50}" CornerRadius="14" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="16"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Thời gian + Nhân viên -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <ui:SymbolIcon Symbol="Mail24" FontSize="12" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Thời gian" FontSize="11" Foreground="{StaticResource Gray400}" FontWeight="Medium"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SelectedDonHang.NgayTao, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <ui:SymbolIcon Symbol="Person24" FontSize="14" 
                                                       Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Nhân viên" FontSize="11" Foreground="{StaticResource Gray400}" FontWeight="Medium"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SelectedDonHang.NhanVien.HoTen}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                    </StackPanel>

                                    <!-- Row 2: Phương thức -->
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <ui:SymbolIcon Symbol="ContactCard24" FontSize="12" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Phương thức thanh toán" FontSize="11" Foreground="{StaticResource Gray400}" FontWeight="Medium"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding SelectedDonHang.PhuongThucTT}" 
                                                   FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                    </StackPanel>

                                    <!-- Row 4: Ghi chú -->
                                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <ui:SymbolIcon Symbol="Pin24" FontSize="12" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Ghi chú" FontSize="11" Foreground="{StaticResource Gray400}" FontWeight="Medium"/>
                                        </StackPanel>
                                        <TextBlock FontSize="13" Foreground="{StaticResource Gray600}" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding SelectedDonHang.GhiChu}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedDonHang.GhiChu}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="Không có ghi chú"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Gray300}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedDonHang.GhiChu}" Value="">
                                                            <Setter Property="Text" Value="Không có ghi chú"/>
                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Gray300}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Financial Summary -->
                            <TextBlock Text="Tổng kết thanh toán" FontSize="14" FontWeight="Bold" 
                                       Foreground="{StaticResource Gray800}" Margin="0,0,0,14"/>

                            <Border CornerRadius="14" Padding="20" Margin="0,0,0,20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.5">
                                        <GradientStop Color="#EEF0FF" Offset="0"/>
                                        <GradientStop Color="#F5F3FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#E0E7FF"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Tổng tiền hàng" FontSize="13" Foreground="{StaticResource Gray500}"/>
                                        <TextBlock Text="{Binding SelectedDonHang.TongTien, StringFormat='{}{0:N0}đ'}" 
                                                   FontSize="13" FontWeight="Medium" Foreground="{StaticResource Gray700}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Giảm giá" FontSize="13" Foreground="{StaticResource Gray500}"/>
                                        <TextBlock Text="{Binding SelectedDonHang.GiamGia, StringFormat='-{0:N0}đ'}" 
                                                   FontSize="13" FontWeight="Medium" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Border BorderBrush="#C7D2FE" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                        <Grid>
                                            <TextBlock Text="Thanh toán" FontSize="15" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedDonHang.ThanhToan, StringFormat='{}{0:N0}đ'}" 
                                                       FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Products Section -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <TextBlock Text="Sản phẩm trong đơn" FontSize="14" FontWeight="Bold" 
                                           Foreground="{StaticResource Gray800}"/>
                                <Border Background="{StaticResource LightBlue}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ChiTietDonHangs.Count, StringFormat='{}{0} món'}" 
                                               FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                                </Border>
                            </StackPanel>

                            <Border Background="{StaticResource Gray50}" CornerRadius="14" ClipToBounds="True">
                                <!-- Tiêu đề CT -->
                                <StackPanel>
                                    <Border Padding="16,10" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="0.6*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="MÓN ĂN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400}"/>
                                            <TextBlock Grid.Column="1" Text="SL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="ĐƠN GIÁ" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="THÀNH TIỀN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource Gray400}" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Nội dung CT -->
                                    <ItemsControl ItemsSource="{Binding ChiTietDonHangs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="16,12" BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*"/>
                                                            <ColumnDefinition Width="0.6*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Background="White" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0"
                                                                    BorderBrush="{StaticResource Gray200}" BorderThickness="1" ClipToBounds="True">
                                                                <Grid>
                                                                    <ui:SymbolIcon Symbol="FoodPizza24" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding Pizza.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Pizza.TenPizza}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                                                <Border Background="{StaticResource LightBlue}" CornerRadius="4" Padding="6,1" HorizontalAlignment="Left" Margin="0,3,0,0">
                                                                    <TextBlock Text="{Binding Pizza.KichThuoc}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="6,3" 
                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                            <TextBlock Text="{Binding SoLuong, StringFormat='x{0}'}" FontSize="12" FontWeight="Bold" 
                                                                       Foreground="{StaticResource Gray700}" TextAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="2" Text="{Binding DonGia, StringFormat='{}{0:N0}đ'}" 
                                                                   FontSize="12" Foreground="{StaticResource Gray500}" TextAlignment="Right" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding ThanhTien, StringFormat='{}{0:N0}đ'}" 
                                                                   FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" TextAlignment="Right" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Chân trang Actions -->
                    <Border Grid.Row="2" Padding="32,16,32,24" BorderBrush="{StaticResource Gray100}" BorderThickness="0,1,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="Building24" FontSize="12" Foreground="{StaticResource Gray300}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <TextBlock Text="Đơn bán trực tiếp" 
                                           FontSize="11" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" FontStyle="Italic"/>
                            </StackPanel>

                            <Button HorizontalAlignment="Right" Command="{Binding PrintHoaDonCommand}" Cursor="Hand" VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="printBorder" CornerRadius="12" Padding="16,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#4F46E5" Offset="0"/>
                                                    <GradientStop Color="#818CF8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Print24" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Xuất hóa đơn" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="printBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- DELETE CONFIRMATION OVERLAY -->
        <Grid Visibility="{Binding IsDeleteDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="100">
            <Border Background="#66111827">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseDeleteDialogCommand}"/>
                </Border.InputBindings>
            </Border>
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="White" Width="400" CornerRadius="20" Padding="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="40" ShadowDepth="8" Direction="270" Color="Black" Opacity="0.18"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Icon -->
                        <Border Width="72" Height="72" CornerRadius="36" Background="#FEE2E2" HorizontalAlignment="Center" Margin="0,32,0,16">
                            <Border Width="50" Height="50" CornerRadius="25" Background="#FECACA" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🗑️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        
                        <!-- Title -->
                        <TextBlock Text="Xóa đơn hàng" FontSize="20" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" Margin="32,0,32,12"/>
                        
                        <!-- Message -->
                        <TextBlock FontSize="13" Foreground="#64748B" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="340" LineHeight="20" Margin="32,0,32,28" HorizontalAlignment="Center">
                            <Run Text="Bạn có chắc chắn muốn xóa đơn hàng "/>
                            <Run Text="{Binding DeletingDonHang.MaDonHang}" FontWeight="Bold" Foreground="#1E293B"/>
                            <Run Text=" không?"/><LineBreak/>
                            <Run Text="Hành động này sẽ cập nhật lại số lượng hàng hóa và không thể hoàn tác."/>
                        </TextBlock>
                        
                        <!-- Buttons -->
                        <Grid Margin="32,0,32,28" Height="44">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" Command="{Binding CloseDeleteDialogCommand}" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBorder" Background="#F1F5F9" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <TextBlock Text="Hủy bỏ" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBorder" Property="Background" Value="#E2E8F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <Button Grid.Column="2" Command="{Binding ConfirmDeleteDonHangCommand}" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="deleteBorder" CornerRadius="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#EF4444" Offset="0"/>
                                                    <GradientStop Color="#DC2626" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#EF4444" Opacity="0.3"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="🗑" FontSize="13" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Xóa" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="deleteBorder" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Close Button -->
                <Button Command="{Binding CloseDeleteDialogCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0" Cursor="Hand" Width="30" Height="30" Padding="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="closeBg" Background="#E2E8F0" CornerRadius="15">
                                <TextBlock Text="✕" FontSize="14" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="closeBg" Property="Background" Value="#CBD5E1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
