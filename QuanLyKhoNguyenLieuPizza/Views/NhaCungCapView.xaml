<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.NhaCungCapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:NhaCungCapViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <!-- BẢNG MÀU HIỆN ĐẠI -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessGreenLight" Color="#D1FAE5"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerRedLight" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kiểu Tiêu đề Bảng -->
        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Kiểu Ô Bảng -->
        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Gray50}">
        <Grid Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TIÊU ĐỀ TRANG -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tiêu đề -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý nhà cung cấp" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Danh sách đối tác cung cấp nguyên liệu" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nút Thêm -->
                <Button Grid.Column="1" Command="{Binding CreateNhaCungCapCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thêm nhà cung cấp" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- THẺ THỐNG KÊ -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tổng số -->
                <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng nhà cung cấp" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Person24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TongSo}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </Border>

                <!-- Active -->
                <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Đang hợp tác" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountDangHopTac}" FontSize="32" FontWeight="Bold" Foreground="#059669"/>
                    </StackPanel>
                </Border>

                <!-- Inactive -->
                <Border Grid.Column="4" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Ngừng hợp tác" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountNgungHopTac}" FontSize="32" FontWeight="Bold" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tìm kiếm & FILTERS -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hộp Tìm kiếm -->
                    <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10" Width="350">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"
                                     VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Tìm kiếm nhà cung cấp..."
                                       FontSize="14"
                                       Foreground="{StaticResource Gray400}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Filter Checkboxes -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Lọc:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox Content="Đang hợp tác"
                                      IsChecked="{Binding FilterDangHopTac}"
                                      Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox Content="Ngừng hợp tác"
                                      IsChecked="{Binding FilterNgungHopTac}"
                                      FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Bảng Dữ liệu -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề Bảng -->
                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tên nhà cung cấp" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Địa chỉ" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Số điện thoại" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Email" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Trạng thái" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="NL cung cấp" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="6" Text="Thao tác" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Bảng Nội dung -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NhaCungCaps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding TenNCC}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" TextAlignment="Left" Padding="20,16"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DiaChi}" Style="{StaticResource TableCellStyle}" TextWrapping="Wrap"/>
                                            <TextBlock Grid.Column="2" Text="{Binding SDT}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Email}" Style="{StaticResource TableCellStyle}" TextWrapping="Wrap" FontSize="12"/>

                                            <!-- Thẻ Trạng thái -->
                                            <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    CornerRadius="12" Padding="10,6">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Đang hợp tác"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                                                    <Setter Property="Text" Value="Ngừng hợp tác"/>
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- View Detail Nút -->
                                            <Button Grid.Column="5"
                                                    Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Xem chi tiết nguyên liệu"
                                                    Cursor="Hand"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32">
                                                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Nút Hành động -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.EditNhaCungCapCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Chỉnh sửa"
                                                        Cursor="Hand"
                                                        Margin="0,0,6,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32">
                                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Command="{Binding DataContext.OpenStatusDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Đổi trạng thái"
                                                        Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="32" Height="32">
                                                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Trạng thái Trống -->
                    <StackPanel Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding NhaCungCaps.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="50" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Không có nhà cung cấp nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thêm nhà cung cấp mới để bắt đầu" FontSize="13" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ADD/EDIT DIALOG -->
        <Grid Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White"
                    CornerRadius="20"
                    Width="520"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Thêm nhà cung cấp"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreateMode}" Value="False">
                                            <Setter Property="Text" Value="Sửa thông tin nhà cung cấp"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button HorizontalAlignment="Right" Command="{Binding CancelDialogCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Biểu mẫu -->
                    <Grid Grid.Row="1" Margin="0,0,0,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Tên nhà cung cấp -->
                        <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Tên nhà cung cấp" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                <TextBox Text="{Binding FormTenNCC, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <!-- Số điện thoại -->
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Số điện thoại" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                <TextBox Text="{Binding FormSDT, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Email" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14"/>
                            </Border>
                        </StackPanel>

                        <!-- Địa chỉ -->
                        <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                            <TextBlock Text="Địa chỉ" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12">
                                <TextBox Text="{Binding FormDiaChi, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" Background="Transparent" FontSize="14"
                                         TextWrapping="Wrap" MinHeight="50" AcceptsReturn="True"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelDialogCommand}" Cursor="Hand" Margin="0,0,12,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="32,14">
                                        <TextBlock Text="Hủy" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Command="{Binding SaveNhaCungCapCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="10" Padding="32,14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                                <GradientStop Color="#818CF8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                        </Border.Effect>
                                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Lưu thông tin"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCreateMode}" Value="False">
                                                            <Setter Property="Text" Value="Cập nhật"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS DIALOG -->
        <Grid Visibility="{Binding IsStatusDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White"
                    CornerRadius="20"
                    Width="440"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Trạng thái hợp tác" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseStatusDialogCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Info -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <TextBlock Text="Tên nhà cung cấp" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock Text="{Binding SelectedNhaCungCap.TenNCC}" FontSize="14" Foreground="{StaticResource Gray800}"/>
                        </Border>

                        <TextBlock Text="Trạng thái hiện tại" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border CornerRadius="10" Padding="14,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#D1FAE5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNhaCungCap.TrangThai}" Value="False">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="14" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Đang hợp tác"/>
                                        <Setter Property="Foreground" Value="#059669"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedNhaCungCap.TrangThai}" Value="False">
                                                <Setter Property="Text" Value="Ngừng hợp tác"/>
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Nút Bật/Tắt -->
                    <Button Grid.Row="2"
                            Command="{Binding ToggleStatusCommand}"
                            Cursor="Hand"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="10" Padding="40,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNhaCungCap.TrangThai}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Ngừng hợp tác"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedNhaCungCap.TrangThai}" Value="False">
                                                        <Setter Property="Text" Value="Hợp tác lại"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- DETAIL DIALOG -->
        <Grid Visibility="{Binding IsDetailDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White"
                    CornerRadius="20"
                    Width="700"
                    MaxHeight="600"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center">
                            <Run Text="Nguyên liệu cung cấp - "/>
                            <Run Text="{Binding SelectedNhaCungCap.TenNCC}"/>
                        </TextBlock>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseDetailDialogCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Supplier Info Summary -->
                    <Border Grid.Row="1" Background="{StaticResource Gray50}" CornerRadius="12" Padding="16,12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource Gray500}">
                                <TextBlock Text="&#xE81D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <Run Text=" Địa chỉ: "/>
                                <Run Text="{Binding SelectedNhaCungCap.DiaChi}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource Gray500}" Margin="0,4,0,0">
                                <TextBlock Text="&#xE717;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <Run Text=" SĐT: "/>
                                <Run Text="{Binding SelectedNhaCungCap.SDT}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                                <Run Text="    "/>
                                <TextBlock Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <Run Text=" Email: "/>
                                <Run Text="{Binding SelectedNhaCungCap.Email}" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Ingredient Bảng -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tiêu đề Bảng -->
                            <Border Background="{StaticResource Gray50}" CornerRadius="12,12,0,0" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mã NL" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="1" Text="Tên nguyên liệu" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="Đơn vị" Style="{StaticResource TableHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="Giá nhập" Style="{StaticResource TableHeaderStyle}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                                <ItemsControl ItemsSource="{Binding NguyenLieusOfNCC}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding MaNguyenLieu}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TenNguyenLieu}" Style="{StaticResource TableCellStyle}" TextAlignment="Left"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding DonViTinh.TenDonVi}" Style="{StaticResource TableCellStyle}"/>
                                                    <TextBlock Grid.Column="3" Style="{StaticResource TableCellStyle}" Foreground="{StaticResource PrimaryBlue}" FontWeight="SemiBold">
                                                        <TextBlock.Text>
                                                            <Binding Path="NguyenLieuNhaCungCaps[0].GiaNhap" StringFormat="{}{0:N0}"/>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Trạng thái Trống -->
                            <StackPanel Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding NguyenLieusOfNCC.Count, Converter={StaticResource IntToVisibilityConverter}}">
                                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="32" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Chua có nguyên liệu nào" FontSize="14" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Màn hình Chờ -->
        <Border Background="#80FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="36" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBlue}"/>
                <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray500}" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


