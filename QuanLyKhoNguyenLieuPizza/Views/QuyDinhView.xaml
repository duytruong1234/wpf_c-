<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.QuyDinhView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:behaviors="clr-namespace:QuanLyKhoNguyenLieuPizza.Behaviors"
             Background="#F4F7FE">

    <UserControl.Resources>
        <!-- Colors -->
        <Color x:Key="PrimaryColor">#5B6AFF</Color>
        <Color x:Key="PrimaryDarkColor">#4550E6</Color>
        <SolidColorBrush x:Key="Primary" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="InputBg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>

        <!-- Rounded ComboBox style -->
        <Style x:Key="ModernCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- Rounded TextBox style -->
        <Style x:Key="ModernInput" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Action Icon Button -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,28,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══════════ HEADER ══════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="46" Height="46" CornerRadius="14" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                                <GradientStop Color="{StaticResource PrimaryDarkColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="20" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Cấu hình làm bánh" FontSize="22" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Quản lý trọng lượng bột và nguyên liệu viên theo size" 
                                   FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Nút Refresh -->
                <Button Grid.Column="1" Command="{Binding LoadDataCommand}" Cursor="Hand"
                        Height="38" Padding="16,0" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="White" CornerRadius="10"
                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}" 
                                    Height="{TemplateBinding Height}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="14" Foreground="{StaticResource Primary}" 
                                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Làm mới" FontSize="13" FontWeight="SemiBold" 
                                               Foreground="{StaticResource Primary}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#F8FAFC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ══════════ CONTENT (2 columns) ══════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══════════ LEFT: TRỌNG LƯỢNG BỘT ══════════ -->
                <Border Grid.Column="0" Background="{StaticResource CardBg}" 
                        CornerRadius="16" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" 
                                          Color="#000000" Opacity="0.04"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Border Grid.Row="0" Padding="24,20" 
                                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" 
                                        Background="#EEF2FF" Margin="0,0,12,0">
                                    <ui:SymbolIcon Symbol="FoodPizza24" FontSize="20" Foreground="#4550E6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Trọng lượng bột" FontSize="16" FontWeight="Bold" 
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Cấu hình khối lượng bột theo size và loại cốt" 
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Form -->
                        <StackPanel Grid.Row="1" Margin="24,20,24,0">
                            <!-- Row 1: Size + Loại cốt -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Size bánh" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding Sizes}" 
                                                  SelectedItem="{Binding BotSelectedSize}"
                                                  DisplayMemberPath="TenSize"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Loại cốt bánh" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding LoaiCotBanhs}" 
                                                  SelectedItem="{Binding BotSelectedLoaiCotBanh}"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Trọng lượng + Đơn vị -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Trọng lượng (g)" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <TextBox Text="{Binding BotTrongLuong, UpdateSourceTrigger=PropertyChanged}" behaviors:NumericInputBehavior.IsDecimalOnly="True"
                                                 BorderThickness="0" Background="Transparent" FontSize="13" Padding="0" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Đơn vị" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding BotDonViOptions}" 
                                                  SelectedItem="{Binding BotSelectedDonVi}"
                                                  DisplayMemberPath="TenDonVi"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                        Margin="0,18,0,20">
                                <Button Command="{Binding ClearBotCommand}" Cursor="Hand"
                                        Height="38" Padding="20,0" Margin="0,0,10,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="#F1F5F9" CornerRadius="10"
                                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}" 
                                                    Height="{TemplateBinding Height}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="11" Foreground="{StaticResource TextSecondary}" 
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Hủy" FontSize="13" FontWeight="SemiBold" 
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Command="{Binding SaveBotCommand}" Cursor="Hand"
                                        Height="38" Padding="20,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="10"
                                                    Padding="{TemplateBinding Padding}" 
                                                    Height="{TemplateBinding Height}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                                                        <GradientStop Color="{StaticResource PrimaryDarkColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Save24" FontSize="12" Foreground="White" Margin="0,0,8,0" 
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="Lưu cấu hình" FontSize="13" FontWeight="SemiBold" 
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Data Table -->
                        <Border Grid.Row="2" Margin="0,0,0,0"
                                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Table Header -->
                                <Border Grid.Row="0" Background="#F8FAFC" Padding="24,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Size" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Grid.Column="1" Text="Cốt bánh" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Grid.Column="2" Text="T.L Bột" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="3" Text="ĐV" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="" FontSize="11"/>
                                    </Grid>
                                </Border>

                                <!-- Table Rows -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding QuyDinhBots}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="24,14" 
                                                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FAFBFF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Size badge -->
                                                    <Border Grid.Column="0" HorizontalAlignment="Left"
                                                            Background="#EEF2FF" CornerRadius="6" Padding="10,4">
                                                        <TextBlock Text="{Binding SizeID}" FontSize="12" 
                                                                   FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="1" Text="{Binding LoaiCotBanh}" 
                                                               FontSize="13" Foreground="{StaticResource TextPrimary}" 
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding TrongLuongBot, StringFormat={}{0:N0}}" 
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3" Text="{Binding DonViTinh.TenDonVi}"
                                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" 
                                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Border Width="30" Height="30" CornerRadius="8" 
                                                                Background="#EEF2FF" Cursor="Hand" Margin="0,0,6,0"
                                                                MouseLeftButtonDown="EditBot_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Edit24" FontSize="12" Foreground="#4F46E5"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Width="30" Height="30" CornerRadius="8" 
                                                                Background="#FEE2E2" Cursor="Hand"
                                                                MouseLeftButtonDown="DeleteBot_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Delete24" FontSize="12" Foreground="#DC2626"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- ══════════ RIGHT: NGUYÊN LIỆU VIÊN ══════════ -->
                <Border Grid.Column="2" Background="{StaticResource CardBg}" 
                        CornerRadius="16" VerticalAlignment="Top">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" 
                                          Color="#000000" Opacity="0.04"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Border Grid.Row="0" Padding="24,20" 
                                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" 
                                        Background="#FEF3C7" Margin="0,0,12,0">
                                    <ui:SymbolIcon Symbol="Cube24" FontSize="20" Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Nguyên liệu viên" FontSize="16" FontWeight="Bold" 
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Cấu hình nguyên liệu theo đế và size" 
                                               FontSize="11" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Form -->
                        <StackPanel Grid.Row="1" Margin="24,20,24,0">
                            <!-- Row 1: Đế bánh + Size bánh -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Đế bánh" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding DeBanhs}" 
                                                  SelectedItem="{Binding VienSelectedDe}"
                                                  DisplayMemberPath="TenDeBanh"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Size bánh" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding Sizes}" 
                                                  SelectedItem="{Binding VienSelectedSize}"
                                                  DisplayMemberPath="TenSize"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Nguyên liệu viên -->
                            <StackPanel Margin="0,14,0,0">
                                <TextBlock Text="Nguyên liệu viên" Style="{StaticResource FieldLabel}"/>
                                <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                    <ComboBox ItemsSource="{Binding NguyenLieus}" 
                                              SelectedItem="{Binding VienSelectedNguyenLieu}"
                                              DisplayMemberPath="TenNguyenLieu"
                                              BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                </Border>
                            </StackPanel>

                            <!-- Row 3: Định mức + Đơn vị -->
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Định mức" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <TextBox Text="{Binding VienSoLuong, UpdateSourceTrigger=PropertyChanged}" behaviors:NumericInputBehavior.IsDecimalOnly="True"
                                                 BorderThickness="0" Background="Transparent" FontSize="13" Padding="0" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Đơn vị" Style="{StaticResource FieldLabel}"/>
                                    <Border Background="White" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="10" Padding="12,10" Height="40">
                                        <ComboBox ItemsSource="{Binding VienDonViOptions}" 
                                                  SelectedItem="{Binding VienSelectedDonVi}"
                                                  DisplayMemberPath="TenDonVi"
                                                  BorderThickness="0" Background="Transparent" FontSize="13" Padding="0"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                        Margin="0,18,0,20">
                                <Button Command="{Binding ClearVienCommand}" Cursor="Hand"
                                        Height="38" Padding="20,0" Margin="0,0,10,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" Background="#F1F5F9" CornerRadius="10"
                                                    BorderBrush="{StaticResource Border}" BorderThickness="1"
                                                    Padding="{TemplateBinding Padding}" 
                                                    Height="{TemplateBinding Height}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="11" Foreground="{StaticResource TextSecondary}" 
                                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Hủy" FontSize="13" FontWeight="SemiBold" 
                                                               Foreground="{StaticResource TextSecondary}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Background" Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Command="{Binding SaveVienCommand}" Cursor="Hand"
                                        Height="38" Padding="20,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bg" CornerRadius="10"
                                                    Padding="{TemplateBinding Padding}" 
                                                    Height="{TemplateBinding Height}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
                                                        <GradientStop Color="{StaticResource PrimaryDarkColor}" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Save24" FontSize="12" Foreground="White" Margin="0,0,8,0" 
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="Lưu cấu hình" FontSize="13" FontWeight="SemiBold" 
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bg" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Data Table -->
                        <Border Grid.Row="2" 
                                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Table Header -->
                                <Border Grid.Row="0" Background="#F8FAFC" Padding="24,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Đế bánh" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Grid.Column="1" Text="Size" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Nguyên liệu" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Grid.Column="3" Text="Định mức" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="ĐV" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{StaticResource TextMuted}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="" FontSize="11"/>
                                    </Grid>
                                </Border>

                                <!-- Table Rows -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding QuyDinhViens}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="24,14" 
                                                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FAFBFF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding DoanhMucDe.TenDeBanh}" 
                                                               FontSize="13" Foreground="{StaticResource TextPrimary}" 
                                                               VerticalAlignment="Center"/>

                                                    <!-- Size badge -->
                                                    <Border Grid.Column="1" HorizontalAlignment="Center"
                                                            Background="#FEF3C7" CornerRadius="6" Padding="8,4"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DoanhMucSize.TenSize}" FontSize="11" 
                                                                   FontWeight="SemiBold" Foreground="#92400E"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="2" 
                                                               Text="{Binding NguyenLieu.TenNguyenLieu}" 
                                                               FontSize="13" FontWeight="Medium"
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3" 
                                                               Text="{Binding SoLuongVien, StringFormat={}{0:N0}}" 
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="4" Text="{Binding DonViTinh.TenDonVi}"
                                                               FontSize="12" Foreground="{StaticResource TextMuted}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                    <!-- Actions -->
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" 
                                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <Border Width="30" Height="30" CornerRadius="8" 
                                                                Background="#EEF2FF" Cursor="Hand" Margin="0,0,6,0"
                                                                MouseLeftButtonDown="EditVien_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Edit24" FontSize="12" Foreground="#4F46E5"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Border Width="30" Height="30" CornerRadius="8" 
                                                                Background="#FEE2E2" Cursor="Hand"
                                                                MouseLeftButtonDown="DeleteVien_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Delete24" FontSize="12" Foreground="#DC2626"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
