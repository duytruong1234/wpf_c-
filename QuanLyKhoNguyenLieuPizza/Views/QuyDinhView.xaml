<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.QuyDinhView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="#F4F7FE">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,24">
            <Border CornerRadius="14" Width="48" Height="48" Margin="0,0,16,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5B6AFF" Offset="0"/>
                        <GradientStop Color="#818CF8" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <ui:SymbolIcon Symbol="Settings24" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Cấu hình làm bánh" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                <TextBlock Text="Quản lý viền bánh và trọng lượng bột" FontSize="13" Foreground="{StaticResource Gray400}" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bột bánh -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Cấu hình Trọng lượng bột" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray800}" Margin="0,0,0,16"/>
                    
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Size bánh" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding BotSelectedSize}" DisplayMemberPath="TenSize" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Loại cốt bánh" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DeBanhs}" SelectedItem="{Binding BotSelectedDe}" DisplayMemberPath="LoaiCotBanh" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Trọng lượng bột" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BotTrongLuong, UpdateSourceTrigger=PropertyChanged}" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="Đơn vị" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DonVis}" SelectedItem="{Binding BotSelectedDonVi}" DisplayMemberPath="TenDonVi" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding ClearBotCommand}" Cursor="Hand" Margin="0,0,8,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBorder" Background="{StaticResource Gray100}" CornerRadius="6" Padding="12,8">
                                            <TextBlock Text="Hủy thiết lập" Foreground="{StaticResource Gray700}" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding SaveBotCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="saveBorder" Background="{StaticResource PrimaryBlue}" CornerRadius="6" Padding="12,8">
                                            <TextBlock Text="Lưu cấu hình" Foreground="White" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="saveBorder" Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding QuyDinhBots}" AutoGenerateColumns="False" 
                              BorderBrush="{StaticResource Gray200}" BorderThickness="1" Background="White"
                              CanUserAddRows="False" HeadersVisibility="Column" RowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Size" Binding="{Binding DoanhMucSize.TenSize}" Width="*"/>
                            <DataGridTextColumn Header="Cốt bánh" Binding="{Binding LoaiCotBanh}" Width="*"/>
                            <DataGridTextColumn Header="TL Bột" Binding="{Binding TrongLuongBot}" Width="*"/>
                            <DataGridTextColumn Header="Đơn vị" Binding="{Binding DonViTinh.TenDonVi}" Width="0.8*"/>
                            <DataGridTemplateColumn Header="H.Động" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.EditBotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Cursor="Hand" ToolTip="Sửa" Margin="0,0,8,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="editBorder" Background="#EEF2FF" CornerRadius="8" Width="32" Height="32">
                                                            <ui:SymbolIcon Symbol="Edit24" FontSize="14" Foreground="#4338CA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="editBorder" Property="Background" Value="#E0E7FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteBotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Cursor="Hand" ToolTip="Xóa">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="delBorder" Background="#FEE2E2" CornerRadius="8" Width="32" Height="32">
                                                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="delBorder" Property="Background" Value="#FCA5A5"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Viền bánh -->
            <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Cấu hình Nguyên liệu viền" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray800}" Margin="0,0,0,16"/>
                    
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                            <TextBlock Text="Đế bánh" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DeBanhs}" SelectedItem="{Binding VienSelectedDe}" DisplayMemberPath="TenDeBanh" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                            <TextBlock Text="Size bánh" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding VienSelectedSize}" DisplayMemberPath="TenSize" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,12">
                            <TextBlock Text="Nguyên liệu viền" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding NguyenLieus}" SelectedItem="{Binding VienSelectedNguyenLieu}" DisplayMemberPath="TenNguyenLieu" Padding="10,6"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Định mức" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding VienSoLuong, UpdateSourceTrigger=PropertyChanged}" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,16">
                            <TextBlock Text="Đơn vị" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding DonVis}" SelectedItem="{Binding VienSelectedDonVi}" DisplayMemberPath="TenDonVi" Padding="10,6"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="3" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding ClearVienCommand}" Cursor="Hand" Margin="0,0,8,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cancelBorder" Background="{StaticResource Gray100}" CornerRadius="6" Padding="12,8">
                                            <TextBlock Text="Hủy thiết lập" Foreground="{StaticResource Gray700}" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cancelBorder" Property="Background" Value="{StaticResource Gray200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding SaveVienCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="saveBorder" Background="{StaticResource PrimaryBlue}" CornerRadius="6" Padding="12,8">
                                            <TextBlock Text="Lưu cấu hình" Foreground="White" FontWeight="Medium" FontSize="13" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="saveBorder" Property="Background" Value="#1D4ED8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding QuyDinhViens}" AutoGenerateColumns="False" 
                              BorderBrush="{StaticResource Gray200}" BorderThickness="1" Background="White"
                              CanUserAddRows="False" HeadersVisibility="Column" RowBackground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Đế bánh" Binding="{Binding DoanhMucDe.TenDeBanh}" Width="*"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding DoanhMucSize.TenSize}" Width="0.8*"/>
                            <DataGridTextColumn Header="Nguyên liệu" Binding="{Binding NguyenLieu.TenNguyenLieu}" Width="1.5*"/>
                            <DataGridTextColumn Header="NL" Binding="{Binding SoLuongVien}" Width="0.6*"/>
                            <DataGridTextColumn Header="ĐV" Binding="{Binding DonViTinh.TenDonVi}" Width="0.6*"/>
                            <DataGridTemplateColumn Header="H.Động" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.EditVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Cursor="Hand" ToolTip="Sửa" Margin="0,0,8,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="editBorder" Background="#EEF2FF" CornerRadius="8" Width="32" Height="32">
                                                            <ui:SymbolIcon Symbol="Edit24" FontSize="14" Foreground="#4338CA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="editBorder" Property="Background" Value="#E0E7FF"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteVienCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Cursor="Hand" ToolTip="Xóa">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="delBorder" Background="#FEE2E2" CornerRadius="8" Width="32" Height="32">
                                                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" Foreground="#DC2626" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="delBorder" Property="Background" Value="#FCA5A5"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>


