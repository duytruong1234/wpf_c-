<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:DashboardViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Kiểu thẻ -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Kiểu thẻ khi hover -->
        <Style x:Key="HoverCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.1"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Nội dung Chính -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F8FAFC" Offset="0"/>
                <GradientStop Color="#F1F5F9" Offset="0.5"/>
                <GradientStop Color="#F8FAFC" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,20,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══════════ Tiêu đề SECTION ═══════════ -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#5B6AFF" Offset="0"/>
                                    <GradientStop Color="#818CF8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="Home24" FontSize="22" 
                                       Foreground="White" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Tổng quan hệ thống" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <TextBlock Text="Theo dõi tình trạng kho nguyên liệu và doanh thu" FontSize="12" 
                                       Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Nút Làm mới -->
                    <Button Grid.Column="1" Command="{Binding RefreshCommand}" Cursor="Hand" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" 
                                        BorderThickness="1" CornerRadius="10" Width="44" Height="44">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Color="#000000" Opacity="0.04"/>
                                    </Border.Effect>
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" 
                                               Foreground="{StaticResource Gray600}" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- ═══════════ THẺ THỐNG KÊ ROW 1: KHO ═══════════ -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Tổng nguyên liệu -->
                    <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tổng nguyên liệu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Box24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding TongSoNguyenLieu}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock Text="Đang tồn kho" FontSize="11" FontWeight="Medium" Foreground="{StaticResource SuccessGreen}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Tồn kho thấp -->
                    <Border Grid.Column="2" Background="#FFF7ED" BorderBrush="#FED7AA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tồn kho thấp" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#FBBF24" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Warning24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding SoLuongTonKhoThap}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource WarningOrangeLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock Text="Cần bổ sung" FontSize="11" FontWeight="Medium" Foreground="{StaticResource WarningOrange}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Sắp hết hạn -->
                    <Border Grid.Column="4" Background="#ECFEFF" BorderBrush="#A5F3FC" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Sắp hết hạn" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0891B2" Offset="0"/>
                                            <GradientStop Color="#22D3EE" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Clock24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding SoLuongSapHetHan}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource InfoCyanLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock Text="Trong 7 ngày" FontSize="11" FontWeight="Medium" Foreground="{StaticResource InfoCyan}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Đã hết hạn -->
                    <Border Grid.Column="6" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Đã hết hạn" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#F87171" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="CalendarCancel24" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding SoLuongHetHan}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource DangerRedLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock Text="Cần xử lý" FontSize="11" FontWeight="Medium" Foreground="{StaticResource DangerRed}"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ═══════════ CHARTS ROW ═══════════ -->
                <Grid Grid.Row="2" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Area Chart: Doanh thu 7 ngày -->
                    <Border Grid.Column="0" Style="{StaticResource HoverCardStyle}" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="DataTrending24" FontSize="16" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Doanh thu 7 ngày gần nhất" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                                    <TextBlock Text="Đơn vị: nghìn đồng (k)" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Biểu đồ Canvas WPF tùy chỉnh -->
                            <Canvas x:Name="RevenueChartCanvas" Grid.Row="1" MinHeight="240" 
                                    Background="Transparent" ClipToBounds="True"/>
                        </Grid>
                    </Border>

                    <!-- Trạng thái kho: Thanh tiến trình -->
                    <Border Grid.Column="2" Style="{StaticResource HoverCardStyle}" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#FBBF24" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="ChartMultiple24" FontSize="16" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Trạng thái nguyên liệu" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                                    <TextBlock Text="Phân loại theo tình trạng" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Thanh trạng thái tiến trình WPF tùy chỉnh -->
                            <StackPanel x:Name="StockStatusPanel" Grid.Row="1" VerticalAlignment="Top"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══════════ SALES SECTION Tiêu đề ═══════════ -->
                <Grid Grid.Row="3" Margin="0,8,0,20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="Money24" FontSize="20" 
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Doanh thu &amp; Bán hàng" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <TextBlock Text="Thống kê doanh thu, chi phí và lợi nhuận" FontSize="12" 
                                       Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ═══════════ SALES THẺ THỐNG KÊ ═══════════ -->
                <Grid Grid.Row="4" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card: Doanh thu hôm nay -->
                    <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource HoverCardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tổng doanh thu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Money24" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding DoanhThuHomNay, StringFormat='{}{0:N0}đ'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource LightBlue}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock FontSize="11" FontWeight="Medium" Foreground="{StaticResource PrimaryBlue}">
                                    <Run Text="{Binding TongDonHomNay, Mode=OneWay}"/>
                                    <Run Text=" đơn hàng"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card: Doanh thu tháng -->
                    <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource HoverCardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Doanh thu bán hàng" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#34D399" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="DataTrending24" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding DoanhThuThang, StringFormat='{}{0:N0}đ'}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock FontSize="11" FontWeight="Medium" Foreground="{StaticResource SuccessGreen}">
                                    <Run Text="{Binding TongDonThang, Mode=OneWay}"/>
                                    <Run Text=" đơn hoàn thành"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card: Chi phí NL -->
                    <Border Grid.Column="4" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource HoverCardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Chi phí NL tiêu hao" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EF4444" Offset="0"/>
                                            <GradientStop Color="#F87171" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Archive24" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding ChiPhiNguyenLieuThang, StringFormat='{}{0:N0}đ'}" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                            <Border Background="{StaticResource DangerRedLight}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <TextBlock Text="NL đã sử dụng" FontSize="11" FontWeight="Medium" Foreground="{StaticResource DangerRed}"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Card: Lợi nhuận -->
                    <Border Grid.Column="6" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource HoverCardStyle}" Padding="20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Lợi nhuận ước tính" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#34D399" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="ArrowTrending24" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding LoiNhuanThang, StringFormat='{}{0:N0}đ'}" FontSize="24" FontWeight="Bold" Foreground="#059669"/>
                            <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,0">
                                <Border.Background>
                                    <SolidColorBrush Color="#D1FAE5"/>
                                </Border.Background>
                                <TextBlock Text="Doanh thu - NL tiêu hao" FontSize="11" FontWeight="Medium" Foreground="#059669"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ═══════════ TOP PIZZA BAR CHART + RECENT ORDERS ═══════════ -->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Top Pizza Bar Chart -->
                    <Border Grid.Column="0" Style="{StaticResource HoverCardStyle}" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#F59E0B" Offset="0"/>
                                            <GradientStop Color="#FBBF24" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Trophy24" FontSize="16" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Top Pizza bán chạy" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                                    <TextBlock Text="Tất cả thời gian" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Chart Nơi giữ chỗ - filled by code-behind -->
                            <Border x:Name="TopPizzaChartHost" Grid.Row="1" MinHeight="280"/>
                        </Grid>
                    </Border>

                    <!-- Đơn hàng gần đây -->
                    <Border Grid.Column="2" Style="{StaticResource HoverCardStyle}" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ui:SymbolIcon Symbol="Cart24" FontSize="16" 
                                               Foreground="White" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Đơn hàng gần đây" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Gray900}"/>
                                    <TextBlock Text="8 đơn hàng mới nhất" FontSize="11" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Tiêu đề Bảng -->
                            <Border Grid.Row="1" Background="{StaticResource Gray50}" CornerRadius="10,10,0,0" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="0.8*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mã đơn" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500}"/>
                                    <TextBlock Grid.Column="1" Text="Thời gian" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Thanh toán" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="Phương thức" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="Trạng thái" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Nội dung bảng -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding RecentDonHangs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="14,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="White"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="0.8*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding MaDonHang}" FontSize="12" FontWeight="Medium" 
                                                               Foreground="{StaticResource Gray800}" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding NgayTao, StringFormat={}{0:dd/MM HH:mm}}" 
                                                               FontSize="12" Foreground="{StaticResource Gray500}" TextAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding ThanhToan, StringFormat='{}{0:N0}đ'}" 
                                                               FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray800}" TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding PhuongThucTT}" 
                                                               FontSize="11" Foreground="{StaticResource Gray500}" TextAlignment="Center" VerticalAlignment="Center"/>

                                                    <Border Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            CornerRadius="8" Padding="8,4">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="Hoàn thành"/>
                                                                    <Setter Property="Foreground" Value="#059669"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding TrangThai}" Value="1">
                                                                            <Setter Property="Text" Value="Đang xử lý"/>
                                                                            <Setter Property="Foreground" Value="#D97706"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding TrangThai}" Value="3">
                                                                            <Setter Property="Text" Value="Đã hủy"/>
                                                                            <Setter Property="Foreground" Value="#DC2626"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Màn hình Chờ -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Width="64" Height="64" CornerRadius="32" Margin="0,0,0,12">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#5B6AFF" Offset="0"/>
                            <GradientStop Color="#818CF8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Đang tải dữ liệu..." FontSize="14" FontWeight="Medium" Foreground="{StaticResource Gray500}"/>
            </StackPanel>
        </Border>
        <!-- Popup chi tiết Trạng thái Nguyên Liệu -->
        <Border Background="#40000000" Visibility="{Binding IsStatusPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="100">
            <Border Background="White" CornerRadius="16" Width="550" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="4" Opacity="0.1" Color="Black"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="24,20,24,20">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="12" Height="12" CornerRadius="6" VerticalAlignment="Center" Margin="0,0,12,0" Background="{Binding StatusPopupColor}"/>
                            <TextBlock Text="{Binding StatusPopupTitle}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center" 
                                Command="{Binding CloseStatusPopupCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="4">
                             <ui:SymbolIcon Symbol="Dismiss24" FontSize="18" Foreground="{StaticResource Gray500}"/>
                        </Button>
                    </Grid>
                    
                    <!-- Divider -->
                    <Border Grid.Row="1" Background="{StaticResource Gray200}"/>
                    
                    <!-- Content (List) -->
                    <Grid Grid.Row="2" Margin="24,20,24,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header Bảng -->
                        <Grid Grid.Row="0" Margin="12,0,24,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tên nguyên liệu" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}"/>
                            <TextBlock Grid.Column="1" Text="Số lượng tồn" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Hạn sử dụng" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" TextAlignment="Right"/>
                        </Grid>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="380">
                            <ItemsControl ItemsSource="{Binding StatusDetailItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="12,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{Binding TenNguyenLieu}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Gray800}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SoLuongTon, StringFormat={}{0:G29}}" FontSize="13" Foreground="{StaticResource Gray800}" FontWeight="SemiBold" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding DonVi}" FontSize="12" Foreground="{StaticResource Gray500}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                </StackPanel>
                                                
                                                <TextBlock Grid.Column="2" Text="{Binding HanSuDungText}" FontSize="12" Foreground="{StaticResource Gray500}" TextAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <!-- Nếu không có dữ liệu -->
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusDetailItems.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate>
                                                            <TextBlock Text="Không có nguyên liệu nào ở trạng thái này." 
                                                                       Foreground="{StaticResource Gray500}" FontStyle="Italic" 
                                                                       HorizontalAlignment="Center" Margin="0,40,0,40"/>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>

    </Grid>
</UserControl>

