<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:ap="clr-namespace:QuanLyKhoNguyenLieuPizza.Core.AttachedProperties"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="550"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- Slide In Animation -->
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="50" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Eye Toggle Style (SVG based, matches LoginView) -->
        <Style x:Key="PasswordEyeToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="eyeBorder" Background="Transparent" 
                                CornerRadius="10" Margin="2">
                            <Path x:Name="eyeIcon"
                                  Data="M12,9 A3,3 0 0,1 15,12 A3,3 0 0,1 12,15 A3,3 0 0,1 9,12 A3,3 0 0,1 12,9 M12,4.5 C17,4.5 21.27,7.61 23,12 C21.27,16.39 17,19.5 12,19.5 C7,19.5 2.73,16.39 1,12 C2.73,7.61 7,4.5 12,4.5" 
                                  Fill="#94A3B8" 
                                  Stretch="Uniform" 
                                  Width="20" Height="20"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="eyeBorder" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="eyeIcon" Property="Fill" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="eyeIcon" Property="Fill" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <d:UserControl.DataContext>
        <vm:ChangePasswordViewModel/>
    </d:UserControl.DataContext>
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="28" 
                Padding="48,44"
                Width="520"
                Effect="{StaticResource CardShadow}">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly" Margin="0,0,0,10">
                <StackPanel>
                <!-- Step Indicator -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Width="28" Height="28" CornerRadius="14" Background="#E2E8F0" Margin="0,0,4,0">
                        <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="24" Height="2" Background="#E2E8F0" VerticalAlignment="Center" Margin="2,0"/>
                    <Border Width="28" Height="28" CornerRadius="14" Background="#E2E8F0" Margin="0,0,4,0">
                        <TextBlock Text="2" FontSize="12" FontWeight="Bold" Foreground="#94A3B8" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Width="24" Height="2" Background="#E2E8F0" VerticalAlignment="Center" Margin="2,0"/>
                    <Border Width="28" Height="28" CornerRadius="14" Margin="0,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#34D399" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="3" FontSize="12" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Icon - Lock/Security -->
                <Viewbox Width="72" Height="72" Margin="0,0,0,16">
                    <Grid>
                        <Ellipse Width="80" Height="80">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Path Data="M12,1 L3,5 L3,11 C3,16.55 6.84,21.74 12,23 C17.16,21.74 21,16.55 21,11 L21,5 L12,1 M12,11.99 L19,11 C18.47,15.11 15.72,18.78 12,19.93 L12,12 L5,12 L5,6.3 L12,3.19" 
                              Fill="White" 
                              Stretch="Uniform" 
                              Width="36" Height="36"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                
                <!-- Header -->
                <TextBlock Text="&#x0110;&#x1ED5;i m&#x1EAD;t kh&#x1EA9;u"
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                
                <TextBlock Text="Nh&#x1EAD;p m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i cho t&#x00E0;i kho&#x1EA3;n"
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Error Message -->
                <Border Background="#FEF2F2" 
                        CornerRadius="14" 
                        Padding="16,14"
                        Margin="0,0,0,20"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="32" Height="32" 
                                CornerRadius="8" Background="#FEE2E2"
                                Margin="0,0,12,0" VerticalAlignment="Center">
                            <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                                  Fill="#DC2626" 
                                  Stretch="Uniform" 
                                  Width="16" Height="16"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding ErrorMessage}" 
                                   Foreground="#DC2626" 
                                   FontSize="13"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- New Password -->
                <TextBlock Text="M&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                CornerRadius="10" Margin="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M12,1 A5,5 0 0,1 17,6 L17,8 L19,8 C20.1,8 21,8.9 21,10 L21,20 C21,21.1 20.1,22 19,22 L5,22 C3.9,22 3,21.1 3,20 L3,10 C3,8.9 3.9,8 5,8 L7,8 L7,6 A5,5 0 0,1 12,1 M12,3 A3,3 0 0,0 9,6 L9,8 L15,8 L15,6 A3,3 0 0,0 12,3" 
                                  Fill="White" 
                                  Stretch="Uniform" 
                                  Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>

                        <!-- Password input - TextBox when showing, PasswordBox when hiding -->
                        <TextBox x:Name="txtNewPasswordText" Grid.Column="1"
                                 Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Padding="12,0,12,0"
                                 VerticalContentAlignment="Center"/>

                        <PasswordBox x:Name="txtNewPassword" Grid.Column="1"
                                     Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                     Style="{StaticResource ModernPasswordBoxStyle}"
                                     ap:PasswordBoxHelper.BindPassword="True"
                                     ap:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12,0,12,0"
                                     VerticalContentAlignment="Center"/>

                        <!-- Placeholder -->
                        <TextBlock x:Name="newPasswordPlaceholder" Grid.Column="1"
                                   Text="Nh&#x1EAD;p m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i..."
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding NewPassword, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   IsHitTestVisible="False"/>

                        <!-- Toggle show/hide -->
                        <ToggleButton Grid.Column="2"
                                      Style="{StaticResource PasswordEyeToggle}"
                                      IsChecked="{Binding ShowNewPassword, Mode=TwoWay}"
                                      ToolTip="Hi&#x1EC7;n/&#x1EA8;n m&#x1EAD;t kh&#x1EA9;u"/>
                    </Grid>
                </Border>

                <!-- Password Strength Indicator -->
                <Border Background="{StaticResource BackgroundColor}"
                        CornerRadius="14"
                        Padding="18"
                        Margin="0,0,0,20"
                        Visibility="{Binding NewPassword, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="1">
                                                <Setter Property="Background" Value="#D00000"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                                <Setter Property="Background" Value="#F48C06"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="1" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                                <Setter Property="Background" Value="#F48C06"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="2" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="3" Height="6" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                        
                        <TextBlock Text="{Binding PasswordStrengthText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="1">
                                            <Setter Property="Foreground" Value="#D00000"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                            <Setter Property="Foreground" Value="#F48C06"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                            <Setter Property="Foreground" Value="#FFBA08"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBlock Text="M&#x1EAD;t kh&#x1EA9;u n&#x00EA;n c&#x00F3; &#x00ED;t nh&#x1EA5;t 8 k&#x00FD; t&#x1EF1;, bao g&#x1ED3;m ch&#x1EEF; hoa, s&#x1ED1; v&#x00E0; k&#x00FD; t&#x1EF1; &#x0111;&#x1EB7;c bi&#x1EC7;t"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Confirm Password -->
                <TextBlock Text="X&#x00E1;c nh&#x1EAD;n m&#x1EAD;t kh&#x1EA9;u"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,6"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="38" Height="38" 
                                CornerRadius="10" Margin="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M9,20.42 L2.79,14.21 L5.62,11.38 L9,14.77 L18.88,4.88 L21.71,7.71" 
                                  Fill="White" 
                                  Stretch="Uniform" 
                                  Width="18" Height="18"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>

                        <!-- Confirm password input -->
                        <TextBox x:Name="txtConfirmPasswordText" Grid.Column="1"
                                 Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Padding="12,0,12,0"
                                 VerticalContentAlignment="Center"/>

                        <PasswordBox x:Name="txtConfirmPassword" Grid.Column="1"
                                     Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                     Style="{StaticResource ModernPasswordBoxStyle}"
                                     ap:PasswordBoxHelper.BindPassword="True"
                                     ap:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12,0,12,0"
                                     VerticalContentAlignment="Center"/>

                        <!-- Placeholder -->
                        <TextBlock x:Name="confirmPasswordPlaceholder" Grid.Column="1"
                                   Text="Nh&#x1EAD;p l&#x1EA1;i m&#x1EAD;t kh&#x1EA9;u..."
                                   Style="{StaticResource PlaceholderStyle}"
                                   Visibility="{Binding ConfirmPassword, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                   IsHitTestVisible="False"/>

                        <!-- Toggle show/hide -->
                        <ToggleButton Grid.Column="2"
                                      Style="{StaticResource PasswordEyeToggle}"
                                      IsChecked="{Binding ShowConfirmPassword, Mode=TwoWay}"
                                      ToolTip="Hi&#x1EC7;n/&#x1EA8;n m&#x1EAD;t kh&#x1EA9;u"/>
                    </Grid>
                </Border>

                <!-- Password Match Indicator -->
                <Border CornerRadius="12"
                        Padding="14,10"
                        Margin="0,0,0,16"
                        Visibility="{Binding ShowPasswordMatch, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#D1FAE5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PasswordsMatch}" Value="False">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8L10,17z" 
                              Fill="#10B981" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"
                              Visibility="{Binding PasswordsMatch, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                              Fill="#DC2626" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"
                              Visibility="{Binding PasswordsMatch, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        <TextBlock Text="{Binding PasswordMatchText}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PasswordsMatch}" Value="False">
                                            <Setter Property="Foreground" Value="#D00000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="&#x2190; Quay l&#x1EA1;i"
                            Grid.Column="0"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            FontSize="15"
                            FontWeight="Medium"
                            Padding="20,14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding BackCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="&#x0110;&#x1ED5;i m&#x1EAD;t kh&#x1EA9;u"
                            Grid.Column="1"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding ChangePasswordCommand}"
                            HorizontalAlignment="Stretch"
                            Height="54"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Margin="12,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Background="#CCFFFFFF" CornerRadius="28"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Border Width="8" Height="8" Background="#10B981" CornerRadius="4" Margin="0,0,6,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="cpDot1"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="cpDot1"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" Background="#34D399" CornerRadius="4" Margin="0,0,6,0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="cpDot2"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="cpDot2"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True" BeginTime="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Width="8" Height="8" Background="#6EE7B7" CornerRadius="4">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="cpDot3"/>
                        </Border.RenderTransform>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="cpDot3"
                                                       Storyboard.TargetProperty="Y"
                                                       From="0" To="-8" Duration="0:0:0.35"
                                                       AutoReverse="True" BeginTime="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                </StackPanel>
                <TextBlock Text="&#x0110;ang x&#x1EED; l&#x00FD;..." 
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#10B981" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
