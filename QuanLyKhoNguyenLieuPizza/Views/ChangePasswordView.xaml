<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:ap="clr-namespace:QuanLyKhoNguyenLieuPizza.Core.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="550"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- Simple icon toggle style for show/hide buttons -->
        <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{StaticResource SoftWhiteBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PizzaRedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Storyboard x:Key="SuccessAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="0.8" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="0.8" To="1" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    
    <d:UserControl.DataContext>
        <vm:ChangePasswordViewModel/>
    </d:UserControl.DataContext>
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="28" 
                Padding="48"
                Width="520"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Icon - Lock/Security -->
                <Viewbox Width="85" Height="85" Margin="0,0,0,20">
                    <Grid>
                        <Ellipse Width="85" Height="85">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Shield/Lock Icon -->
                        <Path Data="M12,1 L3,5 L3,11 C3,16.55 6.84,21.74 12,23 C17.16,21.74 21,16.55 21,11 L21,5 L12,1 M12,11.99 L19,11 C18.47,15.11 15.72,18.78 12,19.93 L12,12 L5,12 L5,6.3 L12,3.19" 
                              Fill="White" 
                              Stretch="Uniform" 
                              Width="40" Height="40"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                    </Grid>
                </Viewbox>
                
                <!-- Header -->
                <TextBlock Text="&#x0110;&#x1ED5;i m&#x1EAD;t kh&#x1EA9;u"
                           FontSize="30" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock Text="Nh&#x1EAD;p m&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i cho t&#x00E0;i kho&#x1EA3;n"
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Error Message -->
                <Border Background="#FEE2E2" 
                        CornerRadius="12" 
                        Padding="16,12"
                        Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                              Fill="#DC2626" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="#DC2626" 
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- New Password -->
                <TextBlock Text="M&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,10"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="44" Height="44" 
                                CornerRadius="12" Margin="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M12,1 A5,5 0 0,1 17,6 L17,8 L19,8 C20.1,8 21,8.9 21,10 L21,20 C21,21.1 20.1,22 19,22 L5,22 C3.9,22 3,21.1 3,20 L3,10 C3,8.9 3.9,8 5,8 L7,8 L7,6 A5,5 0 0,1 12,1 M12,3 A3,3 0 0,0 9,6 L9,8 L15,8 L15,6 A3,3 0 0,0 12,3" 
                                  Fill="White" 
                                  Stretch="Uniform" 
                                  Width="20" Height="20"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <!-- Password field: show as TextBox when ShowNewPassword is true -->
                        <Grid Grid.Column="1">
                            <TextBox x:Name="txtNewPasswordText"
                                      Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource ModernTextBoxStyle}"
                                      Padding="12,0,12,0"/>

                            <PasswordBox x:Name="txtNewPassword"
                                         Visibility="{Binding ShowNewPassword, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                         ap:PasswordBoxHelper.BindPassword="True"
                                         ap:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12,0,12,0"/>
                        </Grid>
                        
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nhập mật khẩu mới..."
                                       Style="{StaticResource PlaceholderStyle}"
                                       Visibility="{Binding NewPassword, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                       VerticalAlignment="Center"/>

                            <ToggleButton Grid.Column="1"
                                          Width="44" Height="44"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding ShowNewPassword, Mode=TwoWay}"
                                          Style="{StaticResource IconToggleButtonStyle}">
                                <TextBlock Text="👁" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Password Strength Indicator -->
                <Border Background="{StaticResource BackgroundColor}"
                        CornerRadius="14"
                        Padding="18"
                        Margin="0,0,0,20"
                        Visibility="{Binding NewPassword, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="1">
                                                <Setter Property="Background" Value="#D00000"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                                <Setter Property="Background" Value="#F48C06"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="1" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                                <Setter Property="Background" Value="#F48C06"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="2" Height="6" CornerRadius="3" Margin="0,0,4,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                                <Setter Property="Background" Value="#FFBA08"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            
                            <Border Grid.Column="3" Height="6" CornerRadius="3">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#E2E8F0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                                <Setter Property="Background" Value="#10B981"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </Grid>
                        
                        <TextBlock Text="{Binding PasswordStrengthText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="1">
                                            <Setter Property="Foreground" Value="#D00000"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="2">
                                            <Setter Property="Foreground" Value="#F48C06"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="3">
                                            <Setter Property="Foreground" Value="#FFBA08"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PasswordStrength}" Value="4">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <TextBlock Text="M&#x1EAD;t kh&#x1EA9;u n&#x00EA;n c&#x00F3; &#x00ED;t nh&#x1EA5;t 8 k&#x00FD; t&#x1EF1;, bao g&#x1ED3;m ch&#x1EEF; hoa, s&#x1ED1; v&#x00E0; k&#x00FD; t&#x1EF1; &#x0111;&#x1EB7;c bi&#x1EC7;t"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Confirm Password -->
                <TextBlock Text="X&#x00E1;c nh&#x1EAD;n m&#x1EAD;t kh&#x1EA9;u"
                           Style="{StaticResource LabelStyle}"
                           Margin="0,0,0,10"/>
                <Border Style="{StaticResource InputBorderStyle}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Width="44" Height="44" 
                                CornerRadius="12" Margin="4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#34D399" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Path Data="M9,20.42 L2.79,14.21 L5.62,11.38 L9,14.77 L18.88,4.88 L21.71,7.71" 
                                  Fill="White" 
                                  Stretch="Uniform" 
                                  Width="22" Height="22"
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                        </Border>
                        
                        <Grid Grid.Column="1">
                            <TextBox x:Name="txtConfirmPasswordText"
                                      Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource ModernTextBoxStyle}"
                                      Padding="12,0,12,0"/>

                            <PasswordBox x:Name="txtConfirmPassword"
                                          Visibility="{Binding ShowConfirmPassword, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
                                          Style="{StaticResource ModernPasswordBoxStyle}"
                                          ap:PasswordBoxHelper.BindPassword="True"
                                          ap:PasswordBoxHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Padding="12,0,12,0"/>
                        </Grid>

                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Nhập lại mật khẩu..."
                                        Style="{StaticResource PlaceholderStyle}"
                                        Visibility="{Binding ConfirmPassword, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"
                                        VerticalAlignment="Center"/>

                            <ToggleButton Grid.Column="1"
                                           Width="44" Height="44"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           IsChecked="{Binding ShowConfirmPassword, Mode=TwoWay}"
                                           Style="{StaticResource IconToggleButtonStyle}">
                                <TextBlock Text="👁" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Password Match Indicator -->
                <Border CornerRadius="12"
                        Padding="14,10"
                        Margin="0,0,0,28"
                        Visibility="{Binding ShowPasswordMatch, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#D1FAE5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PasswordsMatch}" Value="False">
                                    <Setter Property="Background" Value="#FEE2E2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Success checkmark icon (visible when passwords match) -->
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8L10,17z" 
                              Fill="#10B981" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"
                              Visibility="{Binding PasswordsMatch, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <!-- Error icon (visible when passwords don't match) -->
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                              Fill="#DC2626" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"
                              Visibility="{Binding PasswordsMatch, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        <TextBlock Text="{Binding PasswordMatchText}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#059669"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PasswordsMatch}" Value="False">
                                            <Setter Property="Foreground" Value="#D00000"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="&#x2190; Quay l&#x1EA1;i"
                            Grid.Column="0"
                            Background="Transparent"
                            Foreground="{StaticResource TextSecondary}"
                            FontSize="15"
                            FontWeight="Medium"
                            Padding="20,14"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding BackCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                    CornerRadius="12" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="&#x0110;&#x1ED5;i m&#x1EAD;t kh&#x1EA9;u"
                            Grid.Column="1"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding ChangePasswordCommand}"
                            HorizontalAlignment="Stretch"
                            Height="54"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Margin="12,0,0,0"/>
                </Grid>

                <!-- Loading Indicator -->
                <Grid Margin="0,20,0,0"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x0110;ang x&#x1EED; l&#x00FD;..." 
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
