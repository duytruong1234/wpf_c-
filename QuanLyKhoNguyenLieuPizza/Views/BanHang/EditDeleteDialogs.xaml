<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.BanHang.EditDeleteDialogs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════ EDIT PHIẾU BÁN DIALOG ═══════════════ -->
        <Grid Visibility="{Binding IsEditPhieuBanDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="16" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#FFFBEB" BorderBrush="#FEF3C7" BorderThickness="0,0,0,1" CornerRadius="16,16,0,0" Padding="20,16">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Edit24" FontSize="20" Foreground="#D97706" Margin="0,0,12,0"/>
                            <TextBlock Text="Cập nhật đơn hàng" FontSize="18" FontWeight="Bold" Foreground="#92400E" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="1" Padding="24">
                        <StackPanel DataContext="{Binding EditingPhieuBan}">
                            <TextBlock Text="Phương thức thanh toán" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,0,0,8"/>
                            <ComboBox SelectedValue="{Binding PhuongThucTT}" SelectedValuePath="Content" Margin="0,0,0,16" Padding="8">
                                <ComboBoxItem Content="Tiền mặt"/>
                                <ComboBoxItem Content="Chuyển khoản"/>
                            </ComboBox>
                            
                            <TextBlock Text="Ghi chú đơn hàng" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding GhiChu}" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Padding="8" BorderBrush="{StaticResource Gray200}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="2" Background="{StaticResource Gray50}" BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0" CornerRadius="0,0,16,16" Padding="20,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseEditPhieuBanDialogCommand}" Cursor="Hand" Margin="0,0,12,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="White" BorderBrush="{StaticResource Gray300}" BorderThickness="1" CornerRadius="8" Padding="20,10">
                                            <TextBlock Text="Hủy" FontWeight="SemiBold" Foreground="{StaticResource Gray700}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding SaveEditPhieuBanCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#F59E0B" CornerRadius="8" Padding="20,10">
                                            <TextBlock Text="Lưu thay đổi" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════ DELETE PHIẾU BÁN DIALOG ═══════════════ -->
        <Grid Visibility="{Binding IsDeletePhieuBanDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="16" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="{StaticResource DangerRedLight}" BorderBrush="#FECACA" BorderThickness="0,0,0,1" CornerRadius="16,16,0,0" Padding="20,16">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="20" Foreground="{StaticResource DangerRed}" Margin="0,0,12,0"/>
                            <TextBlock Text="Xóa đơn hàng" FontSize="18" FontWeight="Bold" Foreground="#991B1B" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="1" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Bạn có chắc chắn muốn xóa đơn hàng này?" FontSize="15" Foreground="{StaticResource Gray800}" TextWrapping="Wrap"/>
                            <TextBlock Text="Toàn bộ lịch sử chi tiết của đơn hàng cũng sẽ bị xóa vĩnh viễn và không thể khôi phục." FontSize="13" Foreground="{StaticResource Gray500}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="2" Background="{StaticResource Gray50}" BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0" CornerRadius="0,0,16,16" Padding="20,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseDeletePhieuBanDialogCommand}" Cursor="Hand" Margin="0,0,12,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="White" BorderBrush="{StaticResource Gray300}" BorderThickness="1" CornerRadius="8" Padding="20,10">
                                            <TextBlock Text="Hủy" FontWeight="SemiBold" Foreground="{StaticResource Gray700}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding ConfirmDeletePhieuBanCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{StaticResource DangerRed}" CornerRadius="8" Padding="20,10">
                                            <TextBlock Text="Xác nhận xóa" FontWeight="SemiBold" Foreground="White"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
