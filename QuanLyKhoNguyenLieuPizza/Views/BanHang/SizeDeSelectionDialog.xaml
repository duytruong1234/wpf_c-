<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.BanHang.SizeDeSelectionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
    </UserControl.Resources>

    <!-- ═══════════════ SIZE / DE SELECTION DIALOG ═══════════════ -->
    <Grid Visibility="{Binding IsSizeDeDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#B30F172A">
        <Border Background="White" CornerRadius="18" Width="380"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="8" Direction="270" Color="#000000" Opacity="0.2"/>
            </Border.Effect>
            <Grid Margin="20,20,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Hình ảnh sản phẩm (Bo tròn hoàn hảo) -->
                        <Border Width="64" Height="64" Background="Transparent" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid>
                                <Ellipse Fill="{StaticResource Gray50}" />
                                <!-- Hình ảnh gốc bo tròn qua ImageBrush -->
                                <Ellipse>
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding SelectedHangHoa.HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>
                        </Border>

                        <TextBlock Text="Chọn Size và Đế" FontSize="20" FontWeight="Black" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedHangHoa.TenHangHoa}" FontSize="13" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                    
                    <!-- Nút tắt -->
                    <Button HorizontalAlignment="Right" Command="{Binding CancelSizeDeDialogCommand}" Cursor="Hand" VerticalAlignment="Top" Margin="0,-4,-4,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#F1F5F9" CornerRadius="14" Width="28" Height="28">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="12" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Biểu mẫu chọn tuỳ chọn -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <!-- Khối chọn Size -->
                    <TextBlock Text="Cỡ Bánh *" FontSize="12" FontWeight="Bold" Foreground="#475569" Margin="4,0,0,4"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="10" Padding="12,8" Margin="0,0,0,12">
                        <ComboBox ItemsSource="{Binding Sizes}" SelectedItem="{Binding SelectedSize}"
                                  DisplayMemberPath="TenSize" BorderThickness="0" Background="Transparent" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Khối chọn Đế bánh -->
                    <TextBlock Text="Đế Bánh (tùy chọn)" FontSize="12" FontWeight="Bold" Foreground="#475569" Margin="4,0,0,4"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="10" Padding="12,8" Margin="0,0,0,16">
                        <ComboBox ItemsSource="{Binding DeBanhs}" SelectedItem="{Binding SelectedDe}"
                                  DisplayMemberPath="TenDeBanh" BorderThickness="0" Background="Transparent" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" VerticalContentAlignment="Center"/>
                    </Border>

                    <!-- Khối xem trước giá (Thẻ tổng kết) -->

                    <Border Background="#EEF2FF" BorderBrush="#E0E7FF" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Giá cỡ bánh:" FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Text="{Binding PreviewGiaBanSize, StringFormat={}{0:N0} đ}" FontSize="13" FontWeight="Bold" Foreground="#334155" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Phụ phí đế bánh:" FontSize="13" FontWeight="SemiBold" Foreground="#64748B"/>
                                <TextBlock Text="{Binding PreviewGiaThem, StringFormat=+{0:N0} đ}" FontSize="13" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right"/>
                            </Grid>
                            <Border BorderBrush="#C7D2FE" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                                <Grid>
                                    <TextBlock Text="Tổng thành tiền" FontSize="14" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PreviewGia, StringFormat={}{0:N0} đ}" FontSize="20" FontWeight="Black" Foreground="#4F46E5" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Nhóm nút Hành động (Hủy và Thêm) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2.2*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Nút Hủy -->
                    <Button Grid.Column="0" Command="{Binding CancelSizeDeDialogCommand}" Cursor="Hand" HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="#F1F5F9" CornerRadius="12" Padding="0,12">
                                    <TextBlock Text="Hủy" FontSize="14" FontWeight="Black" Foreground="#64748B" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                        <Setter TargetName="border" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="-1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#CBD5E1"/>
                                        <Setter TargetName="border" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <!-- Nút Thêm vào giỏ -->
                    <Button Grid.Column="2" Command="{Binding ConfirmAddToCartCommand}" Cursor="Hand" HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="12" Padding="0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#4338CA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="4" Direction="270" Color="#4338CA" Opacity="0.4"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Cart24" FontSize="16" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <TextBlock Text="Thêm vào giỏ" FontSize="15" FontWeight="Black" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.95"/>
                                        <Setter TargetName="border" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="-1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                        <Setter TargetName="border" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="1"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
