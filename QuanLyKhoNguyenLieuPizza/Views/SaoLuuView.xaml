<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.SaoLuuView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         mc:Ignorable="d" 
         d:DesignHeight="700" d:DesignWidth="900"
         Background="{StaticResource SoftWhiteBrush}">

    <d:UserControl.DataContext>
        <vm:SaoLuuViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="800">
            
            <!-- Tiêu đề -->
            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="Sao lưu &amp; Phục hồi dữ liệu"
                           FontSize="28"
                           FontWeight="Bold"
                           FontFamily="Segoe UI Variable, Segoe UI, Arial"
                           Foreground="#1E293B"/>
                <TextBlock Text="Bảo vệ dữ liệu hóa đơn, nguyên liệu và thông tin hệ thống"
                           FontSize="14"
                           Foreground="#64748B"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Status / Progress Bar -->
            <Border Background="#F8FAFC" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,0,0,20"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="14"
                               Foreground="#334155"
                               TextWrapping="Wrap"/>
                    <ProgressBar Value="{Binding ProgressValue}" 
                                 Height="6" 
                                 Margin="0,12,0,0"
                                 Background="#E2E8F0">
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                </StackPanel>
            </Border>

            <!-- Last Backup Info Card -->
            <Border Background="White" 
                    CornerRadius="16" 
                    Padding="24"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Biểu tượng -->
                    <Border Grid.Column="0" Width="52" Height="52" CornerRadius="14" Margin="0,0,16,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#2563EB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="Info24" FontSize="22" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Thông tin sao lưu"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1E293B"/>
                        <TextBlock Text="{Binding LastBackupInfo}"
                                   FontSize="13"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   LineHeight="22"/>
                    </StackPanel>

                    <!-- Open folder button -->
                    <Button Grid.Column="2" 
                            Command="{Binding OpenBackupFolderCommand}"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            ToolTip="Mở thư mục sao lưu">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" 
                                        Width="42" Height="42" 
                                        CornerRadius="12" 
                                        Background="#F1F5F9">
                                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="18" Foreground="#64748B"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Backup & Restore Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- SAO LƯU Card -->
                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="16" 
                        Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Biểu tượng -->
                        <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="28" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Sao lưu dữ liệu"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Xuất toàn bộ database ra file .bak để lưu trữ an toàn. Bạn có thể lưu ra USB, ổ cứng ngoài hoặc Google Drive."
                                   FontSize="13"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Margin="0,0,0,8"/>

                        <!-- Checklist -->
                        <StackPanel Margin="0,8,0,24">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="#10B981" Width="20"/>
                                <TextBlock Text="Hóa đơn, đơn hàng" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="#10B981" Width="20"/>
                                <TextBlock Text="Thông tin nguyên liệu, kho" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="#10B981" Width="20"/>
                                <TextBlock Text="Nhân viên, nhà cung cấp" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Checkmark24" FontSize="13" Foreground="#10B981" Width="20"/>
                                <TextBlock Text="Phiếu nhập, phiếu xuất" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Backup Nút -->
                        <Button Command="{Binding BackupCommand}"
                                IsEnabled="{Binding IsNotProcessing}"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" 
                                            CornerRadius="12" 
                                            Padding="16,14"
                                            HorizontalAlignment="Stretch">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#10B981" Offset="0"/>
                                                <GradientStop Color="#059669" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="16" Foreground="White" Margin="0,0,8,0"/>
                                            <TextBlock Text="Sao lưu ngay" 
                                                       FontSize="15" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
                
                <!-- PHỤC HỒI Card -->
                <Border Grid.Column="2" 
                        Background="White" 
                        CornerRadius="16" 
                        Padding="28">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                    </Border.Effect>
                    <StackPanel>
                        <!-- Biểu tượng -->
                        <Border Width="64" Height="64" CornerRadius="16" HorizontalAlignment="Left" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F59E0B" Offset="0"/>
                                    <GradientStop Color="#D97706" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="28" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Phục hồi dữ liệu"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#1E293B"
                                   Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Khôi phục database từ file .bak đã sao lưu trước đó. Sử dụng khi chuyển máy mới hoặc máy cũ bị lỗi."
                                   FontSize="13"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Margin="0,0,0,8"/>

                        <!-- Warning list -->
                        <StackPanel Margin="0,8,0,24">
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Warning24" FontSize="13" Foreground="#F59E0B" Width="20"/>
                                <TextBlock Text="Sẽ GHI ĐÈ dữ liệu hiện tại" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="Warning24" FontSize="13" Foreground="#F59E0B" Width="20"/>
                                <TextBlock Text="Không thể hoàn tác sau khi phục hồi" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="LightbulbFilament24" FontSize="13" Foreground="#D97706" Width="20"/>
                                <TextBlock Text="Nên sao lưu trước khi phục hồi" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4">
                                <ui:SymbolIcon Symbol="LightbulbFilament24" FontSize="13" Foreground="#D97706" Width="20"/>
                                <TextBlock Text="Khởi động lại app sau khi phục hồi" FontSize="13" Foreground="#475569"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Restore Nút -->
                        <Button Command="{Binding RestoreCommand}"
                                IsEnabled="{Binding IsNotProcessing}"
                                Cursor="Hand"
                                HorizontalAlignment="Stretch">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" 
                                            CornerRadius="12" 
                                            Padding="16,14"
                                            HorizontalAlignment="Stretch">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F59E0B" Offset="0"/>
                                                <GradientStop Color="#D97706" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="16" Foreground="White" Margin="0,0,8,0"/>
                                            <TextBlock Text="Phục hồi dữ liệu" 
                                                       FontSize="15" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="White"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tips Section -->
            <Border Background="#FFFBEB" 
                    CornerRadius="12" 
                    Padding="20"
                    Margin="0,20,0,0"
                    BorderBrush="#FDE68A"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ui:SymbolIcon Symbol="LightbulbFilament24" FontSize="16" Foreground="#D97706" Margin="0,0,8,0"/>
                        <TextBlock Text="Mẹo bảo vệ dữ liệu"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#92400E"/>
                    </StackPanel>
                    <TextBlock FontSize="13" Foreground="#78350F" TextWrapping="Wrap" LineHeight="24">
                        <Run FontWeight="SemiBold">• Sao lưu định kỳ:</Run>
                        <Run> Nên sao lưu ít nhất 1 lần/tuần, hoặc mỗi khi có nhiều hóa đơn mới.</Run>
                        <LineBreak/>
                        <Run FontWeight="SemiBold">• Lưu nhiều nơi:</Run>
                        <Run> Copy file .bak ra USB hoặc upload lên Google Drive để an toàn hơn.</Run>
                        <LineBreak/>
                        <Run FontWeight="SemiBold">• Chuyển máy:</Run>
                        <Run> Sao lưu trên máy cũ → cài app trên máy mới → phục hồi từ file .bak.</Run>
                        <LineBreak/>
                        <Run FontWeight="SemiBold">• Gỡ cài đặt:</Run>
                        <Run> Nếu gỡ app và cài lại, dữ liệu SQL Server vẫn còn. Nhưng nên sao lưu để chắc chắn!</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <Border Margin="0,16,0,0"
                    Visibility="{Binding StatusMessage.Length, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           Foreground="#475569"
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
