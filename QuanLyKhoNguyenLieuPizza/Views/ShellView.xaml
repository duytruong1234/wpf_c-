                    <!-- Ban hang -->
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="BanHang"
                            Visibility="{Binding CanViewBanHang, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernSidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuItem}" Value="BanHang">
                                        <Setter Property="Background" Value="#374151"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Grid>
                                                        <Border Width="4" HorizontalAlignment="Left" CornerRadius="0,2,2,0">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="#C0392B" Offset="0"/>
                                                                    <GradientStop Color="#F1C40F" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <Border Background="#374151" CornerRadius="0,12,12,0" Margin="4,0,12,0" Padding="16,14">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#374151" Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="Cart24" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Bán hàng" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                </ScrollViewer>

                <!-- User Profile & Logout -->
                <StackPanel Grid.Row="2" Margin="16,16,16,24">
                    <Border BorderBrush="#374151" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                        <Button Command="{Binding ShowProfileCommand}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand"
                                HorizontalContentAlignment="Left">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="12" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Avatar - Default gradient background -->
                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" ClipToBounds="True"
                                                    Visibility="{Binding HasAvatar, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#C0392B" Offset="0"/>
                                                        <GradientStop Color="#E74C3C" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Person24" FontSize="16" Foreground="White"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <!-- Avatar - Image from database -->
                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="22" ClipToBounds="True"
                                                    Visibility="{Binding HasAvatar, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding AvatarNguoiDung, Converter={StaticResource ImagePathConverter}}"
                                                                Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                                                <TextBlock Text="{Binding TenNguoiDung}" 
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           FontFamily="Segoe UI Variable, Segoe UI, Arial"/>
                                                <TextBlock Text="{Binding ChucVuNguoiDung}" 
                                                           FontSize="12"
                                                           Foreground="#F1C40F"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#374151"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentContent}"/>

        <!-- Profile Dialog Overlay -->
        <Grid Grid.ColumnSpan="2" 
              Visibility="{Binding IsProfileOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000">
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ProfileViewModel.CloseCommand}"/>
            </Grid.InputBindings>
            
            <Border Width="420" 
                    MaxHeight="750"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Effect="{x:Null}">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                </Border.InputBindings>
                <views:ProfileView DataContext="{Binding ProfileViewModel}"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>

