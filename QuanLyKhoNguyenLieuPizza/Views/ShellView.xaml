                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="#C0392B" Offset="0"/>
                                                                    <GradientStop Color="#F1C40F" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <Border Background="#374151" CornerRadius="0,12,12,0" Margin="4,0,12,0" Padding="16,14">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#374151" Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quản lý phiếu xuất" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
