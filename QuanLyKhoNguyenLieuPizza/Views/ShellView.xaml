                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#374151" Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="Food24" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quản lý món ăn" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ══ HỆ THỐNG ══ -->
                    <TextBlock Text="HỆ THỐNG" 
                               FontSize="10" 
                               FontWeight="SemiBold" 
                               Foreground="#64748B" 
                               Margin="24,16,0,8" 
                               FontFamily="Segoe UI Variable, Segoe UI, Arial"/>

                    <!-- Quan ly nha cung cap -->
                    <Button Command="{Binding NavigateCommand}"
