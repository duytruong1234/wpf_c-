                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#374151" Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="Archive24" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Tồn kho" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Quan ly phieu nhap -->
