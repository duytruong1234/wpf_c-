                                                        </Border>
                                                        <Border Background="#374151" CornerRadius="0,12,12,0" Margin="4,0,12,0" Padding="16,14">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#374151" Margin="0,0,10,0">
                                <ui:SymbolIcon Symbol="Food24" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Quản lý nguyên liệu" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Quan ly pizza (mon an) -->
                    <Button Command="{Binding NavigateCommand}"
                            CommandParameter="Pizza"
                            Visibility="{Binding CanViewPizza, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernSidebarButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedMenuItem}" Value="Pizza">
                                        <Setter Property="Background" Value="#374151"/>
