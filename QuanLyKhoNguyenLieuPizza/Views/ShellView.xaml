<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.ShellView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
         xmlns:views="clr-namespace:QuanLyKhoNguyenLieuPizza.Views"
         xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         mc:Ignorable="d" 
         d:DesignHeight="700" d:DesignWidth="1200"
         Background="{StaticResource SoftWhiteBrush}">
    
<d:UserControl.DataContext>
    <vm:ShellViewModel/>
</d:UserControl.DataContext>

<UserControl.Resources>
<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
<converters:ImagePathConverter x:Key="ImagePathConverter"/>
<converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    
<!-- DataTemplates for ViewModel to View mapping -->
<DataTemplate DataType="{x:Type vm:DashboardViewModel}">
    <views:DashboardView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:TonKhoViewModel}">
    <views:TonKhoView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:NguyenLieuViewModel}">
    <views:NguyenLieuView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:PhieuNhapViewModel}">
    <views:PhieuNhapView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:PhieuXuatViewModel}">
    <views:PhieuXuatView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:NhaCungCapViewModel}">
    <views:NhaCungCapView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:NhanVienViewModel}">
    <views:NhanVienView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:BanHangViewModel}">
    <views:BanHangView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:DonHangViewModel}">
    <views:DonHangView/>
</DataTemplate>
<DataTemplate DataType="{x:Type vm:PizzaViewModel}">
    <views:PizzaView/>
</DataTemplate>

    <!-- Modern Sidebar Button with Indicator -->
    <Style x:Key="ModernSidebarButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="indicator" 
                                Width="4" 
                                HorizontalAlignment="Left" 
                                Background="Transparent" 
                                CornerRadius="0,2,2,0"/>
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,12,12,0"
                                Margin="4,0,12,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#374151"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Active Sidebar Button Style with Pizza Gradient Indicator -->
    <Style x:Key="ActiveSidebarButton" TargetType="Button">
        <Setter Property="Background" Value="#374151"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="Padding" Value="16,14"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="indicator" 
                                Width="4" 
                                HorizontalAlignment="Left" 
                                CornerRadius="0,2,2,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#C0392B" Offset="0"/>
                                    <GradientStop Color="#F1C40F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="0,12,12,0"
                                Margin="4,0,12,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar - Dark Modern Style with Pizza Branding -->
        <Border Grid.Column="0" CornerRadius="0"
                Background="{StaticResource SidebarGradientPremium}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" ShadowDepth="6" Direction="0" Color="#000000" Opacity="0.20"/>
            </Border.Effect>
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo with Pizza Theme -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <StackPanel Orientation="Horizontal">
                        <!-- Pizza Logo Icon -->
                        <Border Width="44" Height="44" CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C0392B" Offset="0"/>
                                    <GradientStop Color="#E74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <ui:SymbolIcon Symbol="FoodPizza24" FontSize="18" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                            <TextBlock Text="PizzaInn" 
                                       FontSize="24" 
                                       FontWeight="Bold"
                                       Foreground="White"
                                       FontFamily="Segoe UI Variable, Segoe UI, Arial"/>
                            <TextBlock Text="Quản lý kho" 
                                       FontSize="11" 
                                       Foreground="#9CA3AF"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Menu Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel Margin="0,0,0,0">
                    <!-- ══ TỔNG QUAN ══ -->
                    <TextBlock Text="TỔNG QUAN" 
                               FontSize="10" 
                               FontWeight="SemiBold" 
                               Foreground="#64748B" 
                               Margin="24,0,0,8" 
                               FontFamily="Segoe UI Variable, Segoe UI, Arial"/>
