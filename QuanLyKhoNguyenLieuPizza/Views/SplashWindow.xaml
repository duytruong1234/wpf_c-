<Window x:Class="QuanLyKhoNguyenLieuPizza.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Spinning animation for the logo ring -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RingRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade-in for the whole window -->
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade-out for closing -->
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Progress bar shimmer -->
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ShimmerTranslate"
                             Storyboard.TargetProperty="X"
                             From="-200" To="400" Duration="0:0:1.8">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Pulse animation for the icon -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0" Duration="0:0:1.5"
                             AutoReverse="False"/>
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.5" Duration="0:0:1.5"/>
            <DoubleAnimation Storyboard.TargetName="PulseScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.5" Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Tiêu đề slide up -->
        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.7"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource ShimmerAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource SlideUpAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="20" Width="460" Height="380" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="60" ShadowDepth="8"
                              Direction="270" Color="#000000" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <!-- Dark gradient background -->
            <Border CornerRadius="20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0F172A" Offset="0"/>
                        <GradientStop Color="#1E293B" Offset="0.5"/>
                        <GradientStop Color="#0F172A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Decorative background glow -->
            <Ellipse Width="300" Height="300" Opacity="0.06"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-80,-80,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#E85D04" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="250" Height="250" Opacity="0.04"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="-60,0,0,-60" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#C0392B" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Top accent line -->
            <Border CornerRadius="20,20,0,0" Height="3" VerticalAlignment="Top">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#C0392B" Offset="0"/>
                        <GradientStop Color="#E85D04" Offset="0.3"/>
                        <GradientStop Color="#F48C06" Offset="0.6"/>
                        <GradientStop Color="#FFBA08" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Nội dung Chính -->
            <StackPanel x:Name="ContentPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.RenderTransform>
                    <TranslateTransform Y="30"/>
                </StackPanel.RenderTransform>

                <!-- Logo area -->
                <Grid HorizontalAlignment="Center" Width="100" Height="100" Margin="0,0,0,28">
                    <!-- Pulse ring -->
                    <Ellipse x:Name="PulseRing" Width="100" Height="100" StrokeThickness="2" Opacity="0.6"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E85D04" Offset="0"/>
                                <GradientStop Color="#FFBA08" Offset="1"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="PulseScale" CenterX="50" CenterY="50"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Spinning outer ring -->
                    <Ellipse Width="96" Height="96" StrokeThickness="2.5"
                             HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#E85D04" Offset="0"/>
                                <GradientStop Color="#F48C06" Offset="0.4"/>
                                <GradientStop Color="Transparent" Offset="0.7"/>
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="RingRotate" CenterX="48" CenterY="48"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Inner pizza circle -->
                    <Border Width="76" Height="76" CornerRadius="38"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C0392B" Offset="0"/>
                                <GradientStop Color="#E85D04" Offset="0.5"/>
                                <GradientStop Color="#F48C06" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                              Color="#E85D04" Opacity="0.4"/>
                        </Border.Effect>
                        <!-- Pizza emoji -->
                        <TextBlock Text="🍕" FontSize="34"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- App name -->
                <TextBlock Text="PizzaInn"
                           FontSize="32" FontWeight="Bold"
                           FontFamily="Segoe UI Variable, Segoe UI, Arial"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#E2E8F0" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <TextBlock Text="W  A  R  E  H  O  U  S  E"
                           FontSize="11" FontWeight="Medium"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"
                           FontFamily="Segoe UI Variable, Segoe UI, Arial"/>

                <TextBlock Text="Quản lý kho nguyên liệu"
                           FontSize="13" Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,36"
                           FontFamily="Segoe UI Variable, Segoe UI, Arial"/>

                <!-- Progress bar -->
                <Grid Width="200" Height="4" HorizontalAlignment="Center" ClipToBounds="True">
                    <!-- Track -->
                    <Border CornerRadius="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="0.5"/>

                    <!-- Moving shimmer -->
                    <Border CornerRadius="2" Width="80" HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#E85D04" Offset="0.3"/>
                                <GradientStop Color="#F48C06" Offset="0.5"/>
                                <GradientStop Color="#FFBA08" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="ShimmerTranslate" X="-200"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>

                <TextBlock Text="Đang khởi động..."
                           FontSize="11" Foreground="#475569"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           FontFamily="Segoe UI Variable, Segoe UI, Arial"/>
            </StackPanel>

            <!-- Version info at bottom -->
            <TextBlock Text="v1.0.0"
                       FontSize="10" Foreground="#334155"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,16"/>
        </Grid>
    </Border>
</Window>
