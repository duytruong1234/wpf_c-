<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:ap="clr-namespace:QuanLyKhoNguyenLieuPizza.Core.AttachedProperties"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1100"
             Background="Transparent">

    <UserControl.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                           From="30" To="0" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Modern Input Focus Kiểu -->
        <Style x:Key="LoginInputBorder" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" 
                                              Color="#E85D04" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Kiểu Nút Bật/Tắt -->
        <Style x:Key="EyeToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="eyeBorder" Background="Transparent" 
                                CornerRadius="10" Margin="2">
                            <Path x:Name="eyeIcon"
                                  Data="M12,9 A3,3 0 0,1 15,12 A3,3 0 0,1 12,15 A3,3 0 0,1 9,12 A3,3 0 0,1 12,9 M12,4.5 C17,4.5 21.27,7.61 23,12 C21.27,16.39 17,19.5 12,19.5 C7,19.5 2.73,16.39 1,12 C2.73,7.61 7,4.5 12,4.5" 
                                  Fill="#94A3B8" 
                                  Stretch="Uniform" 
                                  Width="20" Height="20"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="eyeBorder" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="eyeIcon" Property="Fill" Value="#64748B"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="eyeIcon" Property="Fill" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <d:UserControl.DataContext>
        <vm:LoginViewModel/>
    </d:UserControl.DataContext>

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <!-- Main Card -->
        <Border VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="White"
                CornerRadius="24"
                Width="480"
                Effect="{StaticResource CardShadow}">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>

            <Grid>


                <StackPanel Margin="44,36,44,40">

                    <!-- Logo with Glow Ring - FIXED CENTERING -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,20" Width="100" Height="100">
                        <!-- Hiệu ứng viền sáng mờ -->
                        <Ellipse Width="100" Height="100" Opacity="0.15"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#E85D04" Offset="0.4"/>
                                    <GradientStop Color="#00E85D04" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Outer glow ring -->
                        <Ellipse Width="94" Height="94" StrokeThickness="2.5" Opacity="0.35"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse.Stroke>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E85D04" Offset="0"/>
                                    <GradientStop Color="#F48C06" Offset="0.5"/>
                                    <GradientStop Color="#FFBA08" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                        </Ellipse>
                        <!-- Inner pizza circle - properly centered -->
                        <Viewbox Width="72" Height="72" 
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="80" Height="80">
                                <Ellipse Width="80" Height="80">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#E85D04" Offset="0"/>
                                            <GradientStop Color="#DC2F02" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <!-- Pizza slice - căn giữa -->
                                <Path Fill="#FFF3D4" Data="M40,14 L64,66 L16,66 Z"
                                      Stretch="None"/>
                                <!-- Đốm phô mai -->
                                <Ellipse Fill="#FFBA08" Width="11" Height="11" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="28,38,0,0"/>
                                <Ellipse Fill="#FFBA08" Width="9" Height="9" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="45,48,0,0"/>
                                <Ellipse Fill="#FFBA08" Width="8" Height="8" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="36,56,0,0"/>
                                <!-- Pepperoni -->
                                <Ellipse Fill="#D00000" Width="12" Height="12" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="34,30,0,0"/>
                                <Ellipse Fill="#D00000" Width="10" Height="10" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="46,52,0,0"/>
                                <Ellipse Fill="#D00000" Width="10" Height="10" 
                                         HorizontalAlignment="Left" VerticalAlignment="Top"
                                         Margin="25,50,0,0"/>
                            </Grid>
                        </Viewbox>
                    </Grid>

                    <!-- Tiêu đề -->
                    <TextBlock x:Name="txtTitle" 
                               Text="Chào mừng trở lại!"
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="txtSubtitle" 
                               Text="Đăng nhập vào hệ thống quản lý kho"
                               FontSize="14" 
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <!-- Divider -->
                    <Border Height="1" Margin="40,0,40,28" Opacity="0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#E2E8F0" Offset="0.3"/>
                                <GradientStop Color="#E2E8F0" Offset="0.7"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Thông báo lỗi -->
                    <Border Background="#FEF2F2" 
                            CornerRadius="14" 
                            Padding="16,14"
                            Margin="0,0,0,20"
                            BorderBrush="#FECACA"
                            BorderThickness="1"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" 
                                    CornerRadius="8" Background="#FEE2E2"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                                      Fill="#DC2626" 
                                      Stretch="Uniform" 
                                      Width="16" Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" 
                                       Text="{Binding ErrorMessage}" 
                                       Foreground="#DC2626" 
                                       FontSize="13"
                                       FontWeight="Medium"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Username Field -->
                    <TextBlock x:Name="lblUsername" 
                               Text="Tên đăng nhập"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="4,0,0,8"/>
                    <Border Style="{StaticResource LoginInputBorder}" Margin="0,0,0,18" x:Name="usernameBorder">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="42" Height="42" 
                                    CornerRadius="11" Margin="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E85D04" Offset="0"/>
                                        <GradientStop Color="#F48C06" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M12,4 A4,4 0 1,1 12,12 A4,4 0 1,1 12,4 M12,14 C8,14 4,16 4,18 L4,20 L20,20 L20,18 C20,16 16,14 12,14" 
                                      Fill="White" 
                                      Stretch="Uniform" 
                                      Width="20" Height="20"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>

                            <TextBox x:Name="txtUsername" Grid.Column="1"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12,0,12,0"
                                     VerticalContentAlignment="Center"/>

                            <TextBlock Grid.Column="1" 
                                       Text="Nhập tên đăng nhập"
                                       Style="{StaticResource PlaceholderStyle}"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Text, ElementName=txtUsername, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </Grid>
                    </Border>

                    <!-- Password Field -->
                    <TextBlock x:Name="lblPassword" 
                               Text="Mật khẩu"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="4,0,0,8"/>
                    <Border Style="{StaticResource LoginInputBorder}" Margin="0,0,0,14" x:Name="passwordBorder">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="42" Height="42" 
                                    CornerRadius="11" Margin="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#E85D04" Offset="0"/>
                                        <GradientStop Color="#F48C06" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Path Data="M12,1 A5,5 0 0,1 17,6 L17,8 L19,8 C20.1,8 21,8.9 21,10 L21,20 C21,21.1 20.1,22 19,22 L5,22 C3.9,22 3,21.1 3,20 L3,10 C3,8.9 3.9,8 5,8 L7,8 L7,6 A5,5 0 0,1 12,1 M12,3 A3,3 0 0,0 9,6 L9,8 L15,8 L15,6 A3,3 0 0,0 12,3" 
                                      Fill="White" 
                                      Stretch="Uniform" 
                                      Width="18" Height="18"
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Grid.Column="1" 
                                       Text="Nhập mật khẩu..."
                                       Style="{StaticResource PlaceholderStyle}"
                                       IsHitTestVisible="False"
                                       Visibility="{Binding Password, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Inverse}"/>

                            <TextBox Grid.Column="1"
                                     x:Name="txtPasswordUnmasked"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="12,0,12,0"
                                     VerticalContentAlignment="Center"
                                     Visibility="{Binding IsChecked, ElementName=btnTogglePassword, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <PasswordBox Grid.Column="1"
                                         x:Name="txtPassword"
                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                         ap:PasswordBoxHelper.BindPassword="True"
                                         ap:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="12,0,12,0"
                                         VerticalContentAlignment="Center"
                                         Visibility="{Binding IsChecked, ElementName=btnTogglePassword, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>

                            <ToggleButton Grid.Column="2" 
                                          Style="{StaticResource EyeToggleStyle}"
                                          x:Name="btnTogglePassword"
                                          ToolTip="Hiện/Ẩn mật khẩu"/>
                        </Grid>
                    </Border>

                    <!-- Ghi nhớ & Quên mật khẩu -->
                    <Grid Margin="4,0,4,24">
                        <CheckBox x:Name="chkRememberMe"
                                  Content="Ghi nhớ đăng nhập"
                                  Foreground="{StaticResource TextSecondary}"
                                  FontSize="13"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding RememberMe}"/>

                        <TextBlock x:Name="lnkForgotPassword"
                                   Text="Quên mật khẩu?"
                                   Foreground="{StaticResource PrimaryColor}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Cursor="Hand">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding ForgotPasswordCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                    </Grid>

                    <!-- Login Nút -->
                    <Button x:Name="btnLogin"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" 
                                        CornerRadius="14" 
                                        Padding="24,16"
                                        Effect="{StaticResource CardShadow}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#E85D04" Offset="0"/>
                                            <GradientStop Color="#F48C06" Offset="0.5"/>
                                            <GradientStop Color="#FFBA08" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <TextBlock Text="Đăng nhập"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="20" ShadowDepth="4" 
                                                                  Direction="270" Color="#E85D04" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="btnBorder" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="-2"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.9"/>
                                        <Setter TargetName="btnBorder" Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Loading Indicator -->
                    <Border Margin="0,20,0,0" CornerRadius="12" 
                            Background="#FFF7ED" Padding="12,10"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                            <Border Width="8" Height="8" Background="{StaticResource PrimaryColor}" 
                                    CornerRadius="4" Margin="0,0,6,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="dot1"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="dot1"
                                                               Storyboard.TargetProperty="Y"
                                                               From="0" To="-8" Duration="0:0:0.35"
                                                               AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <Border Width="8" Height="8" Background="{StaticResource SecondaryColor}" 
                                    CornerRadius="4" Margin="0,0,6,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="dot2"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="dot2"
                                                               Storyboard.TargetProperty="Y"
                                                               From="0" To="-8" Duration="0:0:0.35"
                                                               AutoReverse="True" BeginTime="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <Border Width="8" Height="8" Background="{StaticResource WarningColor}" 
                                    CornerRadius="4">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="dot3"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="dot3"
                                                               Storyboard.TargetProperty="Y"
                                                               From="0" To="-8" Duration="0:0:0.35"
                                                               AutoReverse="True" BeginTime="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <TextBlock Text="Đang xử lý..." 
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
