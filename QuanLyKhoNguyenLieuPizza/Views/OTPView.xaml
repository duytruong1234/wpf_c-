<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.OTPView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="550"
             Background="Transparent">
    
    <UserControl.Resources>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- OTP Input Box Style with Pizza Theme -->
        <Style x:Key="OTPBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Focusable="false"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>
    
    <d:UserControl.DataContext>
        <vm:OTPViewModel/>
    </d:UserControl.DataContext>
    
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" 
                CornerRadius="28" 
                Padding="40,36"
                Width="520"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Email Icon -->
                <Viewbox Width="70" Height="70" Margin="0,0,0,16">
                    <Grid>
                        <Ellipse Width="70" Height="70">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F48C06" Offset="0"/>
                                    <GradientStop Color="#E85D04" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <!-- Email/OTP Icon -->
                        <Canvas Width="70" Height="70">
                            <Path Data="M20,4 L4,4 C2.9,4 2,4.9 2,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 M20,8 L12,13 L4,8 L4,6 L12,11 L20,6" 
                                  Fill="White" 
                                  Stretch="Uniform" 
                                  Width="32" Height="32"
                                  Canvas.Left="19" Canvas.Top="19"/>
                        </Canvas>
                    </Grid>
                </Viewbox>
                
                <!-- Header -->
                <TextBlock Text="X�c th?c OTP"
                           FontSize="26" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                
                <TextBlock Text="Nh?p m� OTP d� g?i d?n email c?a b?n"
                           FontSize="14" 
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="txtEmailHint"
                           FontSize="14" 
                           Foreground="{StaticResource PrimaryColor}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"
                           Text="{Binding Email}"/>

                <!-- Error Message -->
                <Border Background="#FEE2E2" 
                        CornerRadius="12" 
                        Padding="16,12"
                        Margin="0,0,0,20"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z" 
                              Fill="#DC2626" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding ErrorMessage}" 
                                   Foreground="#DC2626" 
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Success Message -->
                <Border Background="#D1FAE5" 
                        CornerRadius="12" 
                        Padding="16,12"
                        Margin="0,0,0,20"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8L10,17z" 
                              Fill="#059669" 
                              Stretch="Uniform" 
                              Width="18" Height="18"
                              Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding SuccessMessage}" 
                                   Foreground="#059669" 
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- OTP Input Boxes -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp1"/>
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp2"/>
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp3"/>
                    <Border Width="16"/>
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp4"/>
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp5"/>
                    <TextBox Style="{StaticResource OTPBoxStyle}" x:Name="otp6"/>
                </StackPanel>

                <!-- Countdown Timer -->
                <Border CornerRadius="14"
                        Padding="16,10"
                        Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFF8E7" Offset="0"/>
                            <GradientStop Color="#FEF3CD" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <Path Data="M12,2 A10,10 0 1,1 12,22 A10,10 0 1,1 12,2 M12,6 L12,12 L16,14" 
                              Stroke="{StaticResource PrimaryColor}" 
                              StrokeThickness="2"
                              Fill="Transparent"
                              Stretch="Uniform" 
                              Width="20" Height="20"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"/>
                        <TextBlock Text="M� h?t h?n sau: "
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CountdownText}"
                                   Foreground="{StaticResource PrimaryColor}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Verify Button -->
                <Button Content="X�c th?c"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding VerifyOTPCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="24,14"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Margin="0,0,0,16"/>

                <!-- Resend OTP -->
                <Border Background="{StaticResource BackgroundColor}"
                        CornerRadius="12"
                        Padding="14,10"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <TextBlock Text="Kh�ng nh?n du?c m�? "
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="G?i l?i"
                                   Foreground="{StaticResource PrimaryColor}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Cursor="Hand"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding CanResend, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding ResendOTPCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>
                        <TextBlock Text="Vui l�ng ch?..."
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14"
                                   FontStyle="Italic"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding CanResend, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>
                </Border>

                <!-- Back Button -->
                <Button Content="? Quay l?i"
                        Background="Transparent"
                        Foreground="{StaticResource TextSecondary}"
                        FontSize="15"
                        FontWeight="Medium"
                        Padding="16,10"
                        BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding CloseCommand}"
                        HorizontalAlignment="Center">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Loading Indicator -->
                <Grid Margin="0,10,0,0"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#x0110;ang x&#x1EED; l&#x00FD;..." 
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="14"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
