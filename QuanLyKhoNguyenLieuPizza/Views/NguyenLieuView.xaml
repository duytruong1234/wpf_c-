<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.NguyenLieuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:views="clr-namespace:QuanLyKhoNguyenLieuPizza.Views"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100">
    
    <d:UserControl.DataContext>
        <vm:NguyenLieuViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
        
        <!-- MODERN COLOR PALETTE -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="DarkGreen" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#22C55E"/>
        <SolidColorBrush x:Key="SuccessGreenLight" Color="#F0FDF4"/>
        <SolidColorBrush x:Key="WarningOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerRedLight" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <!-- Gradient for Popup Header -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button Styles -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlue}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Gray100}"/>
            <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{StaticResource Gray50}">
        <!-- Main NguyenLieu View -->
        <Grid Visibility="{Binding IsLoaiNguyenLieuViewVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid Margin="30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Page Title + Search + Actions -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <TextBlock Text="&#xE773;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Qu?n l� nguy�n li?u" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <TextBlock Text="Danh s�ch nguy�n li?u trong kho" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Search Box -->
                    <Border Grid.Column="1" 
                            Background="White"
                            BorderBrush="{StaticResource Gray200}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            Width="320" HorizontalAlignment="Right" Margin="0,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14" 
                                     Foreground="{StaticResource Gray800}" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="T�m ki?m nguy�n li?u..." FontSize="14" Foreground="{StaticResource Gray400}"
                                       VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Action Buttons -->
                    <Button Grid.Column="2" Style="{StaticResource OutlineButton}"
                            Command="{Binding OpenLoaiNguyenLieuCommand}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Thi?t l?p lo?i nguy�n li?u" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Command="{Binding OpenAddPopupCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Th�m nguy�n li?u" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Summary Stat Card -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource LightBlue}" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource PrimaryBlue}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="T?ng nguy�n li?u" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding TotalNguyenLieu}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="20" Margin="5,0,5,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#F0FDF4" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE8FB;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource SuccessGreen}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="�ang s? d?ng" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding CountDangSuDung}" FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="20" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#FEF2F2" CornerRadius="10" Width="36" Height="36" Margin="0,0,12,0">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="{StaticResource DangerRed}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ng?ng s? d?ng" FontSize="12" Foreground="{StaticResource Gray400}"/>
                                <TextBlock Text="{Binding CountNgungSuDung}" FontSize="22" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Filters Section -->
                <Border Grid.Row="2" 
                        Style="{StaticResource CardStyle}" 
                        Padding="20"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Filter Title -->
                        <StackPanel Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,14">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="B? l?c" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                        </StackPanel>

                        <!-- T�nh tr?ng filter -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Bottom">
                            <TextBlock Text="T�nh tr?ng" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="�ang s? d?ng" IsChecked="{Binding FilterDangSuDung}" Margin="0,0,12,0" FontSize="13"/>
                                <CheckBox Content="Ng?ng s? d?ng" IsChecked="{Binding FilterNgungSuDung}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nh� cung c?p -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Nh� cung c?p" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                <ComboBox ItemsSource="{Binding NhaCungCaps}"
                                          SelectedItem="{Binding SelectedNhaCungCapFilter}"
                                          DisplayMemberPath="TenNCC"
                                          BorderThickness="0" Background="Transparent" FontSize="13" Width="180"/>
                            </Border>
                        </StackPanel>

                        <!-- Lo?i nguy�n li?u -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Lo?i nguy�n li?u" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                <ComboBox ItemsSource="{Binding LoaiNguyenLieus}"
                                          SelectedItem="{Binding SelectedLoaiFilter}"
                                          DisplayMemberPath="TenLoai"
                                          BorderThickness="0" Background="Transparent" FontSize="13" Width="180"/>
                            </Border>
                        </StackPanel>

                        <!-- Clear Filter -->
                        <Button Grid.Row="1" Grid.Column="4" Cursor="Hand" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="16,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="X�a l?c" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Data Table -->
                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <DataGrid ItemsSource="{Binding FilteredNguyenLieus}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FAFB"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Height" Value="52"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Height" Value="70"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray100}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource LightBlue}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Padding" Value="16,8"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="#1F2937"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="M� nguy�n li?u" Binding="{Binding MaNguyenLieu}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="T�n nguy�n li?u" Binding="{Binding TenNguyenLieu}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="12,0,0,0"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="H�nh ?nh" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="50" Height="50" 
                                                    CornerRadius="25"
                                                    BorderBrush="{StaticResource Gray200}"
                                                    BorderThickness="1"
                                                    Background="{StaticResource Gray50}">
                                                <Border CornerRadius="25" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Lo?i nguy�n li?u" Binding="{Binding LoaiNguyenLieu}" Width="150">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="�on v? t�nh" Binding="{Binding DonViTinh}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Cung c?p" Binding="{Binding NhaCungCap}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Gi� nh?p" Binding="{Binding GiaNhap, StringFormat=N0}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,12,0"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Tr?ng th�i" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" 
                                                    Padding="12,6"
                                                    HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTrangThaiActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding TrangThaiText}" 
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Style.Triggers>
