<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.NguyenLieuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:views="clr-namespace:QuanLyKhoNguyenLieuPizza.Views"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100">
    
    <d:UserControl.DataContext>
        <vm:NguyenLieuViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>
        
        <!-- Gradient cho Tiêu đề Popup -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B6AFF" Offset="0"/>
            <GradientStop Color="#818CF8" Offset="1"/>
        </LinearGradientBrush>

        <!-- Kiểu Nút -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlue}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Gray100}"/>
            <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource Gray600}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid>
    <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#F1F5F9" Offset="0.5"/>
            <GradientStop Color="#F8FAFC" Offset="1"/>
        </LinearGradientBrush>
    </Grid.Background>
        <!-- Main NguyenLieu View -->
        <Grid Visibility="{Binding IsLoaiNguyenLieuViewVisible, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid Margin="30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Page Tiêu đề + Tìm kiếm + Actions -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                            <ui:SymbolIcon Symbol="Food24" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Quản lý nguyên liệu" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                            <TextBlock Text="Danh sách nguyên liệu trong kho" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Hộp Tìm kiếm -->
                    <Border Grid.Column="1" 
                            Background="White"
                            BorderBrush="{StaticResource Gray200}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            Width="260" HorizontalAlignment="Right" Margin="16,0,12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Search24" FontSize="17" VerticalAlignment="Center" Margin="2,0,12,0" Foreground="{StaticResource Gray400}"/>
                            <TextBlock Grid.Column="1" Text="Tìm kiếm nguyên liệu..." FontSize="14" Foreground="{StaticResource Gray400}"
                                       Padding="4,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1" 
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14" 
                                     Foreground="{StaticResource Gray800}" Padding="0" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2" Style="{StaticResource OutlineButton}"
                            Command="{Binding OpenQuyDoiCommand}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowSwap24" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Hệ số quy đổi" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" Style="{StaticResource OutlineButton}"
                            Command="{Binding OpenLoaiNguyenLieuCommand}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Loại nguyên liệu" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" Command="{Binding OpenAddPopupCommand}" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5B6AFF" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24" FontSize="16" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Thêm nguyên liệu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Thẻ Thống kê -->
                <Grid Grid.Row="1" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,10,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Tổng nguyên liệu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding TotalNguyenLieu}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20" Margin="5,0,5,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Đang sử dụng" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border Background="#F0FDF4" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding CountDangSuDung}" FontSize="32" FontWeight="Bold" Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20" Margin="10,0,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="Ngừng sử dụng" FontSize="12" Foreground="{StaticResource Gray500}"/>
                                <Border Background="#FEF2F2" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                    <ui:SymbolIcon Symbol="Warning24" FontSize="16" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <TextBlock Text="{Binding CountNgungSuDung}" FontSize="32" FontWeight="Bold" Foreground="#DC2626"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Filters Section -->
                <Border Grid.Row="2" 
                        Style="{StaticResource CardStyle}" 
                        Padding="20"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Filter Tiêu đề -->
                        <StackPanel Grid.ColumnSpan="5" Orientation="Horizontal" Margin="0,0,0,14">
                            <ui:SymbolIcon Symbol="Filter24" FontSize="16" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Bộ lọc" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray800}"/>
                        </StackPanel>

                    <!-- Tình trạng filter -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,24,0" VerticalAlignment="Bottom">
                        <TextBlock Text="Tình trạng" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <CheckBox Content="Đang sử dụng" IsChecked="{Binding FilterDangSuDung}" Margin="0,0,12,0" FontSize="13"/>
                            <CheckBox Content="Ngừng sử dụng" IsChecked="{Binding FilterNgungSuDung}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Nhà cung cấp -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Nhà cung cấp" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                <ComboBox ItemsSource="{Binding NhaCungCaps}"
                                          SelectedItem="{Binding SelectedNhaCungCapFilter}"
                                          DisplayMemberPath="TenNCC"
                                          BorderThickness="0" Background="Transparent" FontSize="13" Width="180"/>
                            </Border>
                        </StackPanel>

                        <!-- Loại nguyên liệu -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Loại nguyên liệu" FontSize="12" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                            <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                <ComboBox ItemsSource="{Binding LoaiNguyenLieus}"
                                          SelectedItem="{Binding SelectedLoaiFilter}"
                                          DisplayMemberPath="TenLoai"
                                          BorderThickness="0" Background="Transparent" FontSize="13" Width="180"/>
                            </Border>
                        </StackPanel>

                        <!-- Clear Filter -->
                        <Button Grid.Row="1" Grid.Column="4" Cursor="Hand" VerticalAlignment="Bottom" Margin="12,0,0,0" Command="{Binding ClearFiltersCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="16,10">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="Xóa lọc" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Bảng Dữ liệu -->
                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <DataGrid ItemsSource="{Binding FilteredNguyenLieus}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Background="White"
                                  RowBackground="White"
                                  AlternatingRowBackground="#F9FAFB"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Height" Value="52"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="MinHeight" Value="70"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray100}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource LightBlue}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="Foreground" Value="#1F2937"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="#1F2937"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mã nguyên liệu" Binding="{Binding MaNguyenLieu}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Tên nguyên liệu" Binding="{Binding TenNguyenLieu}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Left"/>
                                            <Setter Property="Padding" Value="12,0,0,0"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Hình ảnh" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="46" Height="46" 
                                                    CornerRadius="23"
                                                    BorderBrush="{StaticResource Gray200}"
                                                    BorderThickness="1"
                                                    Background="{StaticResource Gray50}"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                                <Border CornerRadius="23" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Loại nguyên liệu" Binding="{Binding LoaiNguyenLieu}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Đơn vị tính" Binding="{Binding DonViTinh}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Cung cấp" Binding="{Binding NhaCungCap}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Giá nhập" Binding="{Binding GiaNhap, Mode=OneWay, StringFormat='{}{0:N0} đ'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,12,0"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Trạng thái" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" 
                                                    Padding="12,6"
                                                    HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTrangThaiActive}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding TrangThaiText}" 
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#16A34A"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsTrangThaiActive}" Value="False">
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="Thao tác" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding EditCommand}" ToolTip="Chỉnh sửa" Cursor="Hand" Margin="0,0,6,0" VerticalAlignment="Center" Width="36" Height="36" Padding="0" BorderThickness="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8">
                                                                <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding DeleteCommand}" ToolTip="Xóa" Cursor="Hand" VerticalAlignment="Center" Width="36" Height="36" Padding="0" BorderThickness="0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource DangerRedLight}" CornerRadius="8">
                                                                <ui:SymbolIcon Symbol="Delete24" FontSize="16" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Màn hình Chờ -->
                        <Border Background="#80FFFFFF" 
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ui:SymbolIcon Symbol="ArrowSync24" FontSize="36" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBlue}"/>
                                <TextBlock Text="Đang tải dữ liệu..." FontSize="14" Foreground="{StaticResource Gray500}" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Add/Edit Popup Overlay -->
            <Grid Visibility="{Binding IsAddEditPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
                <Border Background="White" 
                        CornerRadius="20" 
                        Width="540"
                        MaxHeight="720"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Padding="32">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tiêu đề -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Thêm nguyên liệu"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Text" Value="Sửa nguyên liệu"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button HorizontalAlignment="Right" Command="{Binding ClosePopupCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                            <ui:SymbolIcon Symbol="Dismiss24" FontSize="14" Foreground="{StaticResource Gray500}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Nội dung Biểu mẫu -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <!-- Mã nguyên liệu -->
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                    <Run Text="Mã nguyên liệu"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                </TextBlock>
                                <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,16">
                                    <TextBox Text="{Binding FormMaNguyenLieu, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent" FontSize="13"/>
                                </Border>

                                <!-- Tên nguyên liệu -->
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                    <Run Text="Tên nguyên liệu"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                </TextBlock>
                                <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,0,16">
                                    <TextBox Text="{Binding FormTenNguyenLieu, UpdateSourceTrigger=PropertyChanged}"
                                             BorderThickness="0" Background="Transparent" FontSize="13"/>
                                </Border>

                                <!-- Hình ảnh -->
                                <TextBlock Text="Hình ảnh" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10" Margin="0,0,12,0">
                                            <TextBox Text="{Binding FormHinhAnh, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                        <Button Grid.Column="1" Command="{Binding BrowseImageCommand}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="16,10">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="13" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Chọn file" FontSize="13" Foreground="{StaticResource Gray600}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Width="140" Height="140"
                                            HorizontalAlignment="Left"
                                            CornerRadius="12"
                                            BorderBrush="{StaticResource Gray200}"
                                            BorderThickness="1"
                                            Background="{StaticResource Gray50}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding FormHinhAnh, Converter={StaticResource ImagePathConverter}}"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <ui:SymbolIcon Symbol="Image24" FontSize="40" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ui:SymbolIcon.Style>
                                                    <Style TargetType="ui:SymbolIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FormHinhAnh}" Value="">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding FormHinhAnh}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ui:SymbolIcon.Style>
                                            </ui:SymbolIcon>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="2"
                                               Text="Nhập URL hoặc chọn file từ máy tính"
                                               FontSize="11"
                                               Foreground="{StaticResource Gray400}"
                                               Margin="0,6,0,0"/>
                                </Grid>

                                <!-- Bố cục 2 cột cho dropdown -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                            <Run Text="Loại nguyên liệu"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                        </TextBlock>
                                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                            <ComboBox ItemsSource="{Binding LoaiNguyenLieus}"
                                                      SelectedItem="{Binding FormLoaiNguyenLieu}"
                                                      DisplayMemberPath="TenLoai"
                                                      BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                            <Run Text="Đơn vị tính"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                        </TextBlock>
                                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                            <ComboBox ItemsSource="{Binding DonViTinhs}"
                                                      SelectedItem="{Binding FormDonViTinh}"
                                                      DisplayMemberPath="TenDonVi"
                                                      BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Two column layout for supplier + price -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                            <Run Text="Nhà cung cấp"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                        </TextBlock>
                                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                            <ComboBox ItemsSource="{Binding NhaCungCaps}"
                                                      SelectedItem="{Binding FormNhaCungCap}"
                                                      DisplayMemberPath="TenNCC"
                                                      BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6">
                                            <Run Text="Giá nhập"/><Run Text=" *" Foreground="{StaticResource DangerRed}"/>
                                        </TextBlock>
                                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10">
                                            <TextBox Text="{Binding FormGiaNhap, UpdateSourceTrigger=PropertyChanged}"
                                                     BorderThickness="0" Background="Transparent" FontSize="13"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <!-- Trạng thái -->
                                <Border Background="{StaticResource Gray50}" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                                    <CheckBox Content="Đang sử dụng" 
                                              IsChecked="{Binding FormTrangThai}" FontSize="13"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Actions -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Command="{Binding ClosePopupCommand}" Cursor="Hand" Margin="0,0,12,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="32,14">
                                            <TextBlock Text="Hủy" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Gray600}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Command="{Binding SaveCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" CornerRadius="10" Padding="32,14">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#5B6AFF" Offset="0"/>
                                                    <GradientStop Color="#818CF8" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                            </Border.Effect>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Lưu"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Text" Value="Cập nhật"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- LoaiNguyenLieu View -->
        <views:LoaiNguyenLieuView DataContext="{Binding LoaiNguyenLieuVM}"
                                   Visibility="{Binding DataContext.IsLoaiNguyenLieuViewVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- STATUS DIALOG -->
        <Grid Visibility="{Binding IsStatusDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="440"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="#000000" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Trạng thái nguyên liệu" FontSize="22" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Command="{Binding CloseStatusDialogCommand}" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="8" Width="32" Height="32">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Gray500}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Info -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,24">
                        <TextBlock Text="Tên nguyên liệu" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                            <TextBlock Text="{Binding StatusNguyenLieu.TenNguyenLieu}" FontSize="14" Foreground="{StaticResource Gray800}"/>
                        </Border>

                        <TextBlock Text="Trạng thái hiện tại" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Gray500}" Margin="0,0,0,6"/>
                        <Border CornerRadius="10" Padding="14,12">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#D1FAE5"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusNguyenLieu.TrangThai}" Value="False">
                                            <Setter Property="Background" Value="#FEE2E2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="14" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Đang sử dụng"/>
                                        <Setter Property="Foreground" Value="#059669"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusNguyenLieu.TrangThai}" Value="False">
                                                <Setter Property="Text" Value="Ngừng sử dụng"/>
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>

                    <!-- Nút chuyển trạng thái -->
                    <Button Grid.Row="2" Command="{Binding ConfirmToggleStatusCommand}" Cursor="Hand" HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" CornerRadius="10" Padding="40,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource DangerRed}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusNguyenLieu.TrangThai}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource SuccessGreen}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="White">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Ngừng sử dụng"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusNguyenLieu.TrangThai}" Value="False">
                                                        <Setter Property="Text" Value="Sử dụng lại"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- QUY DOI DON VI POPUP -->
        <Grid Visibility="{Binding QuyDoiVM.IsOpen, Converter={StaticResource BoolToVisibilityConverter}}" Background="#80000000">
            <Border Background="White" CornerRadius="20" Width="820" MaxHeight="600"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="6" Direction="270" Color="#000000" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,20,24,16">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#F97316" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Quản Lý Hệ Số Quy Đổi" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Cài đặt hệ số chuyển đổi giữa các đơn vị tính" FontSize="12" Foreground="#FFFFFFCC" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Command="{Binding QuyDoiVM.CloseCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="closeBorder" Width="32" Height="32" CornerRadius="16" Background="#30FFFFFF">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="closeBorder" Property="Background" Value="#50FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Body -->
                    <Grid Grid.Row="1" Margin="24,16,24,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Ingredient selector -->
                        <Border Grid.Column="0" Background="{StaticResource Gray50}" CornerRadius="12" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Filter -->
                                <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Padding="8,6" Margin="0,0,0,10">
                                    <ComboBox ItemsSource="{Binding QuyDoiVM.LoaiFilters}"
                                              SelectedItem="{Binding QuyDoiVM.FilterLoai}"
                                              BorderThickness="0" Background="Transparent" FontSize="13"/>
                                </Border>

                                <!-- Ingredient grid -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding QuyDoiVM.FilteredNguyenLieus}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.QuyDoiVM.SelectNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand" Margin="4">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="itemBorder" Width="95" Padding="6,8" CornerRadius="10" Background="White"
                                                                    BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <Border Width="48" Height="48" CornerRadius="24" ClipToBounds="True" 
                                                                            Background="{StaticResource Gray100}" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{StaticResource Gray100}"/>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Border CornerRadius="24" ClipToBounds="True">
                                                                            <Border.Background>
                                                                                <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                            </Border.Background>
                                                                        </Border>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding TenNguyenLieu}" FontSize="11" FontWeight="Medium" 
                                                                               Foreground="{StaticResource Gray800}" TextAlignment="Center"
                                                                               TextWrapping="Wrap" MaxWidth="85"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter TargetName="itemBorder" Property="BorderBrush" Value="#F59E0B"/>
                                                                    <Setter TargetName="itemBorder" Property="BorderThickness" Value="2"/>
                                                                    <Setter TargetName="itemBorder" Property="Background" Value="#FFF7ED"/>
                                                                </DataTrigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="itemBorder" Property="Background" Value="{StaticResource Gray50}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- RIGHT: Conversion table -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Selected ingredient name -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="{Binding QuyDoiVM.SelectedNguyenLieu.TenNguyenLieu, FallbackValue='Chọn nguyên liệu'}"
                                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,4,0,0">
                                    <Run Text="Đơn vị chính: "/><Run Text="{Binding QuyDoiVM.SelectedNguyenLieu.DonViChinh, FallbackValue='-'}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Conversion table -->
                            <Border Grid.Row="1" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Table header -->
                                    <Grid Grid.Row="0" Background="{StaticResource Gray50}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Đơn Vị" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" Padding="14,10" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Hệ Số" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" Padding="8,10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="Loại" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" Padding="8,10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Mặc Định" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" Padding="8,10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="Xóa" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" Padding="8,10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Table rows -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                                        <ItemsControl ItemsSource="{Binding QuyDoiVM.QuyDoiRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1" Padding="0,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="50"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Tên đơn vị -->
                                                            <TextBlock Grid.Column="0" Text="{Binding TenDonVi}" FontSize="14" FontWeight="Medium" 
                                                                       Foreground="{StaticResource Gray800}" Padding="14,8" VerticalAlignment="Center"/>

                                                            <!-- Hệ số (editable) -->
                                                            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" 
                                                                    CornerRadius="6" Margin="4,4" Padding="6,4">
                                                                <TextBox Text="{Binding HeSoText, UpdateSourceTrigger=PropertyChanged}" 
                                                                         BorderThickness="0" Background="Transparent" FontSize="13" 
                                                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                            </Border>

                                                            <!-- Loại đơn vị indicator -->
                                                            <Border Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4">
                                                                <TextBlock Text="{Binding LoaiDonVi}" FontSize="11" FontWeight="Medium" HorizontalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#F59E0B"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding LaDonViChuan}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#10B981"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Mặc định checkbox -->
                                                            <CheckBox Grid.Column="3" IsChecked="{Binding LaDonViChuan}" 
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                            <!-- Xóa button -->
                                                            <Button Grid.Column="4" Command="{Binding DeleteCommand}" Cursor="Hand"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="delBorder" Width="28" Height="28" CornerRadius="6" Background="{StaticResource DangerRedLight}">
                                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                                                                       Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="delBorder" Property="Background" Value="#FEE2E2"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <!-- Add new unit row -->
                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="8" Padding="8,4">
                                    <ComboBox ItemsSource="{Binding QuyDoiVM.DonViTinhs}" 
                                              SelectedItem="{Binding QuyDoiVM.SelectedNewDonVi}"
                                              DisplayMemberPath="TenDonVi"
                                              BorderThickness="0" Background="Transparent" FontSize="13"/>
                                </Border>
                                <Button Grid.Column="1" Command="{Binding QuyDoiVM.AddNewRowCommand}" Cursor="Hand" Margin="8,0,0,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="addBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Padding="14,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Add24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Thêm" FontSize="13" FontWeight="Medium" Foreground="{StaticResource PrimaryBlue}"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="addBorder" Property="Background" Value="#DCE0FF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Save button -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                <Button Command="{Binding QuyDoiVM.SaveCommand}" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="saveBorder" CornerRadius="10" Padding="28,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#F59E0B" Offset="0"/>
                                                        <GradientStop Color="#F97316" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="Lưu" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="saveBorder" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Button Command="{Binding QuyDoiVM.AddNewRowCommand}" Cursor="Hand" Margin="10,0,0,0"
                                        Visibility="Collapsed">
                                    <!-- Hidden Thêm Mới button placeholder -->
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
