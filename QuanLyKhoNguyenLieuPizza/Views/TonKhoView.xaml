<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.TonKhoView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
         xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
         xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
         xmlns:behaviors="clr-namespace:QuanLyKhoNguyenLieuPizza.Behaviors"
         mc:Ignorable="d" 
         d:DesignHeight="750" d:DesignWidth="1100">

<d:UserControl.DataContext>
    <vm:TonKhoViewModel/>
</d:UserControl.DataContext>

<UserControl.Resources>
    <!-- Bộ chuyển đổi -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <converters:StringLengthToVisibilityConverter x:Key="StringLengthToVisibilityConverter"/>
    <converters:ImagePathConverter x:Key="ImagePathConverter"/>

    <!-- Gradient cho Tiêu đề Popup -->
    <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E74C3C" Offset="0"/>
        <GradientStop Color="#F39C12" Offset="1"/>
    </LinearGradientBrush>

    <!-- Kiểu thẻ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.05"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Nút Chính -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="24,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource DarkBlue}"/>
                            <Setter TargetName="border" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#5B6AFF" Opacity="0.3"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Kiểu Nút Icon -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FEE2E2"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Nút Bộ lọc Thẻ -->
    <Style x:Key="FilterChipBase" TargetType="Button">
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Thẻ Material kèm Hover -->
    <Style x:Key="MaterialCard" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="14"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.04"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#E74C3C"/>
                <Setter Property="Background" Value="#FFF5F5"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270" Color="#E74C3C" Opacity="0.15"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>
</UserControl.Resources>

<Grid>
    <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0"/>
            <GradientStop Color="#F1F5F9" Offset="0.5"/>
            <GradientStop Color="#F8FAFC" Offset="1"/>
        </LinearGradientBrush>
    </Grid.Background>
<!-- Nội dung Chính -->
<Grid Margin="30,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ Tiêu đề SECTION ═══════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tiêu đề -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="14" Width="48" Height="48" Margin="0,0,16,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#5B6AFF" Offset="0"/>
                            <GradientStop Color="#818CF8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="Archive24" FontSize="22" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Quản lý tồn kho" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    <TextBlock Text="Theo dõi nguyên liệu và tối ưu hóa kho hàng" FontSize="13" Foreground="{StaticResource Gray400}" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Nút Làm mới -->
            <Button Grid.Column="1" Command="{Binding RefreshCommand}" Cursor="Hand" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Width="44" Height="44">
                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="18" Foreground="{StaticResource Gray600}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Nút Thêm tồn kho (Phiếu Nhập) -->
            <Button Grid.Column="3" Command="{Binding GoToPhieuNhapCommand}" Cursor="Hand" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#2ECC71" BorderBrush="#27AE60" BorderThickness="1" CornerRadius="10" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Thêm tồn kho" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#27AE60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Nút Xuất kho (Phiếu Xuất) -->
            <Button Grid.Column="5" Command="{Binding GoToPhieuXuatCommand}" Cursor="Hand" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#E74C3C" BorderBrush="#C0392B" BorderThickness="1" CornerRadius="10" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="14" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Xuất kho" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Nút Hệ Số Quy Đổi -->
            <Button Grid.Column="7" Command="{Binding OpenQuyDoiPopupCommand}" Cursor="Hand" VerticalAlignment="Center">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Filter24" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Hệ số quy đổi" FontSize="14" Foreground="{StaticResource Gray600}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Thống kê Tổng -->
            <Border Grid.Column="9" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" CornerRadius="16" Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.03"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="12" Width="44" Height="44" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#5B6AFF" Offset="0"/>
                                <GradientStop Color="#818CF8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ui:SymbolIcon Symbol="DataBarVertical24" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Tổng nguyên liệu" FontSize="12" Foreground="{StaticResource Gray500}"/>
                        <TextBlock Text="{Binding SoNguyenLieuTonKho}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════ Tìm kiếm & FILTER BAR ═══════════ -->
        <Border Grid.Row="1" 
                Style="{StaticResource HoverCardStyle}" 
                Padding="20,14"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hộp Tìm kiếm -->
                <Border Grid.Column="0" 
                        CornerRadius="12"
                        Padding="14,10"
                        BorderThickness="1.5">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource Gray50}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Gray200}"/>
                            <Style.Triggers>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#E74C3C" Opacity="0.12"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Search24" FontSize="17" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="2,0,12,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="Tìm kiếm tên hoặc mã nguyên liệu..."
                                   Foreground="{StaticResource Gray400}"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Padding="4,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="SearchTextBox"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 FontSize="14"
                                 Padding="0"
                                 Foreground="{StaticResource Gray800}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>

                <!-- Bộ lọc Thẻ -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Tất Cả -->
                    <Button Command="{Binding FilterTatCaCommand}" Style="{StaticResource FilterChipBase}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="chipBorder" 
                                        Background="Transparent" 
                                        CornerRadius="20" 
                                        Padding="18,9" 
                                        BorderBrush="{StaticResource Gray300}" 
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon x:Name="chipDot" Symbol="Checkmark24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" Margin="0,0,6,0" Visibility="Collapsed"/>
                                        <TextBlock x:Name="chipText" Text="Tất Cả" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.SelectedFilter, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="TatCa">
                                        <Setter TargetName="chipBorder" Property="Background" Value="#E74C3C"/>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="#E74C3C"/>
                                        <Setter TargetName="chipText" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="#E74C3C"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Tồn Thấp -->
                    <Button Command="{Binding FilterTonThapCommand}" Style="{StaticResource FilterChipBase}" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="chipBorder" 
                                        Background="Transparent" 
                                        CornerRadius="20" 
                                        Padding="18,9" 
                                        BorderBrush="{StaticResource Gray300}" 
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon x:Name="chipDot" Symbol="Checkmark24" FontSize="14" Foreground="{StaticResource DangerRed}" Margin="0,0,6,0" Visibility="Collapsed"/>
                                        <TextBlock x:Name="chipText" Text="Tồn Thấp" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.SelectedFilter, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="TonThap">
                                        <Setter TargetName="chipBorder" Property="Background" Value="{StaticResource DangerRed}"/>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                                        <Setter TargetName="chipText" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="{StaticResource DangerRed}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Tồn Cao -->
                    <Button Command="{Binding FilterTonCaoCommand}" Style="{StaticResource FilterChipBase}" Margin="8,0,0,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="chipBorder" 
                                        Background="Transparent" 
                                        CornerRadius="20" 
                                        Padding="18,9" 
                                        BorderBrush="{StaticResource Gray300}" 
                                        BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon x:Name="chipDot" Symbol="Checkmark24" FontSize="14" Foreground="{StaticResource SuccessGreen}" Margin="0,0,6,0" Visibility="Collapsed"/>
                                        <TextBlock x:Name="chipText" Text="Tồn Cao" FontSize="13" FontWeight="Medium" Foreground="{StaticResource Gray600}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.SelectedFilter, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="TonCao">
                                        <Setter TargetName="chipBorder" Property="Background" Value="{StaticResource SuccessGreen}"/>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="{StaticResource SuccessGreen}"/>
                                        <Setter TargetName="chipText" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Foreground" Value="White"/>
                                        <Setter TargetName="chipDot" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="chipBorder" Property="BorderBrush" Value="{StaticResource SuccessGreen}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════ Bảng Dữ liệu ═══════════ -->
        <Border Grid.Row="2" 
                Style="{StaticResource HoverCardStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tiêu đề Bảng -->
                <Border Grid.Row="0" 
                        Background="{StaticResource Gray50}"
                        CornerRadius="16,16,0,0"
                        Padding="28,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Mã NL" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Tên Nguyên Liệu" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" Margin="8,0,0,0"/>
                        <TextBlock Grid.Column="2" Text="Số Lượng" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="Đơn Vị" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Trạng Thái" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Hàng Bảng -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,4,0,8">
                    <ItemsControl ItemsSource="{Binding FilteredTonKhoItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="28,14"
                                        Cursor="Hand">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Gray100}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FAFBFF"/>
                                                    <Setter Property="BorderBrush" Value="#E8EAFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Mã NL -->
                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding MaNguyenLieu}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource Gray600}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Tên kèm Hình ảnh -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                            <Border Width="40" Height="40"
                                                    CornerRadius="20"
                                                    Background="{StaticResource Gray100}"
                                                    Margin="0,0,14,0">
                                                <Grid>
                                                    <Border CornerRadius="20" ClipToBounds="True">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HinhAnh}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HinhAnh}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <ui:SymbolIcon Symbol="Box24" FontSize="18"
                                                               Foreground="{StaticResource Gray400}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <ui:SymbolIcon.Style>
                                                            <Style TargetType="ui:SymbolIcon">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HinhAnh}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HinhAnh}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:SymbolIcon.Style>
                                                    </ui:SymbolIcon>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding TenNguyenLieu}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Gray800}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Số lượng -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding SoLuongTon, StringFormat=N2}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource Gray900}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Đơn vị -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DonViTinh}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource Gray500}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Thẻ Trạng thái -->
                                        <Border Grid.Column="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                CornerRadius="12"
                                                Padding="14,4,14,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#DCFCE7"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="Background" Value="#FEE2E2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding MucDoTonKho}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#16A34A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                                <Setter Property="Foreground" Value="#DC2626"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Trạng thái Trống -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredTonKhoItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="80" Height="80" CornerRadius="40" Background="{StaticResource Gray100}" Margin="0,0,0,16" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Archive24" FontSize="36" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Không tìm thấy nguyên liệu"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{StaticResource Gray400}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm"
                               FontSize="13"
                               Foreground="{StaticResource Gray400}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

        <!-- ═══════════ MANAGEMENT POPUP ═══════════ -->
        <Grid Visibility="{Binding IsQuyDoiPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Nền phủ -->
            <Border Background="#000000" Opacity="0.5">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseQuyDoiPopupCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Thẻ Popup -->
            <Border Width="920" 
                    Height="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="20"
                    Background="White">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0" Color="#000000" Opacity="0.2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề Popup -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource HeaderGradient}"
                            CornerRadius="20,20,0,0"
                            Padding="28,22">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Quản Lý Hệ Số Quy Đổi"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="Cài đặt hệ số chuyển đổi giữa các đơn vị tính"
                                           FontSize="13"
                                           Foreground="White"
                                           Opacity="0.85"
                                           Margin="0,6,0,0"/>
                            </StackPanel>

                            <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseQuyDoiPopupCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                        </Grid>
                    </Border>

                    <!-- Nội dung Popup -->
                    <Grid Grid.Row="1" Margin="28,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Panel Trái -->
                        <Border Grid.Column="0" 
                                Background="{StaticResource Gray50}"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,0,20,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Bộ lọc Danh mục -->
                                <Border Grid.Row="0" 
                                        Background="White"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,14">
                                    <ComboBox Background="Transparent"
                                              BorderThickness="0"
                                              ItemsSource="{Binding LoaiNguyenLieus}"
                                              SelectedItem="{Binding SelectedLoaiNguyenLieu}"
                                              DisplayMemberPath="TenLoai"
                                              FontSize="14"/>
                                </Border>

                                <!-- Lưới Nguyên liệu -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FilteredNguyenLieus}" HorizontalAlignment="Center">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource MaterialCard}"
                                                        Width="100"
                                                        Margin="4">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick" 
                                                                      Command="{Binding DataContext.SelectNguyenLieuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <Border Width="54" Height="54"
                                                                CornerRadius="27"
                                                                Background="{StaticResource LightBlue}"
                                                                Margin="0,0,0,10">
                                                            <Grid>
                                                                <!-- Hình ảnh -->
                                                                <Border CornerRadius="27" ClipToBounds="True">
                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                                    </Border.Background>
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HinhAnh}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding HinhAnh}" Value="">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                                
                                                                <!-- Icon Thay thế -->
                                                                <ui:SymbolIcon Symbol="Box24" FontSize="22"
                                                                           Foreground="{StaticResource Gray400}"
                                                                           HorizontalAlignment="Center" 
                                                                           VerticalAlignment="Center">
                                                                    <ui:SymbolIcon.Style>
                                                                        <Style TargetType="ui:SymbolIcon">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HinhAnh}" Value="{x:Null}">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding HinhAnh}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ui:SymbolIcon.Style>
                                                                </ui:SymbolIcon>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{Binding TenNguyenLieu}" 
                                                                   FontSize="12"
                                                                   FontWeight="Medium"
                                                                   Foreground="{StaticResource Gray800}"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   MaxWidth="85"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- Panel Phải -->
                        <Border Grid.Column="1" 
                                Background="White"
                                CornerRadius="12"
                                Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Nguyên liệu đã chọn -->
                                <TextBlock Grid.Row="0" 
                                           Text="{Binding SelectedNguyenLieu.TenNguyenLieu, FallbackValue='Chọn Nguyên Liệu'}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource Gray800}"
                                           Margin="0,0,0,10"/>

                                <!-- Bảng Quy đổi -->
                                <Border Grid.Row="2"
                                        BorderBrush="{StaticResource Gray200}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Tiêu đề Bảng -->
                                        <Border Grid.Row="0" 
                                                Background="{StaticResource Gray50}"
                                                CornerRadius="12,12,0,0"
                                                Padding="16,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="50"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Đơn Vị" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="Hệ Số" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="ĐV Chuẩn" FontWeight="SemiBold" Foreground="{StaticResource Gray500}" FontSize="13" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="3"/>
                                            </Grid>
                                        </Border>

                                        <!-- Nội dung bảng -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding QuyDoiDonVis}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1" Padding="14,10">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="50"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" 
                                                                           Text="{Binding TenDonVi}" 
                                                                           FontSize="14"
                                                                           Foreground="{StaticResource Gray800}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                                
                                                                <!-- Hệ số chỉnh sửa -->
                                                                <Border Grid.Column="1" 
                                                                        Background="{StaticResource Gray50}"
                                                                        CornerRadius="6"
                                                                        Padding="8,4"
                                                                        HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding HeSoText, UpdateSourceTrigger=PropertyChanged}" behaviors:NumericInputBehavior.IsDecimalOnly="True"
                                                                             Background="Transparent"
                                                                             BorderThickness="0"
                                                                             FontWeight="SemiBold"
                                                                             FontSize="14"
                                                                             Foreground="{StaticResource PrimaryBlue}"
                                                                             IsReadOnly="{Binding LaDonViChuan}"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             TextAlignment="Center"
                                                                             Width="100"/>
                                                                </Border>
                                                                
                                                                <CheckBox Grid.Column="2" 
                                                                          IsChecked="{Binding LaDonViChuan}"
                                                                          HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>

                                                                <!-- Delete button -->
                                                                <Button Grid.Column="3" 
                                                                        Command="{Binding DeleteCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource IconButton}" 
                                                                        Visibility="{Binding LaDonViChuan, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                                                        ToolTip="Xóa quy đổi"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                    <ui:SymbolIcon Symbol="Delete24" Foreground="{StaticResource DangerRed}"/>
                                                                </Button>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- Nút Hành động -->
                                <StackPanel Grid.Row="3" 
                                            Orientation="Horizontal" 
                                            HorizontalAlignment="Center"
                                            Margin="0,18,0,0">
                                    <Button Content="Lưu"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource SuccessGreen}"
                                            Width="110"
                                            Margin="0,0,10,0"
                                            Command="{Binding SaveCommand}"/>
                                    <Button Content="Thêm Mới"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource WarningOrange}"
                                            Width="120"
                                            Command="{Binding AddQuyDoiCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════ ADD NEW POPUP ═══════════ -->
        <Grid Visibility="{Binding IsAddQuyDoiPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#000000" Opacity="0.5">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAddQuyDoiPopupCommand}"/>
                </Border.InputBindings>
            </Border>

            <Border Width="460" 
                    Height="460"
                    CornerRadius="20"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0" Color="#000000" Opacity="0.2"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource HeaderGradient}"
                            CornerRadius="20,20,0,0"
                            Padding="26,20">
                        <Grid>
                            <TextBlock Text="Thêm Hệ Số Quy Đổi Mới"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <Button Style="{StaticResource CircularCloseButtonStyle}" Command="{Binding CloseAddQuyDoiPopupCommand}" Margin="0,-16,-16,0" Panel.ZIndex="10"/>
                        </Grid>
                    </Border>

                    <!-- Biểu mẫu -->
                    <StackPanel Grid.Row="1" Margin="26,22">
                        <TextBlock Text="Đơn vị nhập" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray600}"
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Gray50}"
                                CornerRadius="10"
                                Padding="14"
                                Margin="0,0,0,18"
                                BorderBrush="{StaticResource Gray200}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding DonViNhap, FallbackValue='Chưa chọn'}"
                                       Foreground="{StaticResource Gray800}"
                                       FontSize="14"/>
                        </Border>

                        <TextBlock Text="Đơn vị"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray600}"
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Gray50}"
                                CornerRadius="10"
                                Padding="10"
                                Margin="0,0,0,18"
                                BorderBrush="{StaticResource Gray200}"
                                BorderThickness="1">
                            <ComboBox Background="Transparent"
                                      BorderThickness="0"
                                      ItemsSource="{Binding DonViTinhs}"
                                      SelectedItem="{Binding SelectedDonViXuat}"
                                      DisplayMemberPath="TenDonVi"
                                      FontSize="14"/>
                        </Border>

                        <TextBlock Text="Nhập hệ số" 
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray600}"
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        <Border Background="{StaticResource Gray50}"
                                CornerRadius="10"
                                Padding="4"
                                Margin="0,0,0,24"
                                BorderBrush="{StaticResource Gray200}"
                                BorderThickness="1">
                            <TextBox Background="Transparent"
                                     BorderThickness="0"
                                     Text="{Binding HeSoNhap, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="15"
                                     Padding="10"/>
                        </Border>

                        <Button Content="Lưu Hệ Số"
                                Style="{StaticResource PrimaryButton}"
                                Background="{StaticResource SuccessGreen}"
                                HorizontalAlignment="Stretch"
                                Padding="0,14"
                                FontSize="15"
                                Command="{Binding SaveNewQuyDoiCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
