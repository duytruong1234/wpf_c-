<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="QuanLyKhoNguyenLieuPizza.Views.NhanVienView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:QuanLyKhoNguyenLieuPizza.ViewModels"
             xmlns:converters="clr-namespace:QuanLyKhoNguyenLieuPizza.Converters"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <d:UserControl.DataContext>
        <vm:NhanVienViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <!-- BẢNG MÀU HIỆN ĐẠI -->
        <SolidColorBrush x:Key="PrimaryBlue" Color="#5B6AFF"/>
        <SolidColorBrush x:Key="DarkBlue" Color="#4A56D6"/>
        <SolidColorBrush x:Key="LightBlue" Color="#EEF0FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessGreenLight" Color="#D1FAE5"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerRedLight" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="Gray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="Gray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="Gray200" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Gray300" Color="#CBD5E1"/>
        <SolidColorBrush x:Key="Gray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Gray500" Color="#64748B"/>
        <SolidColorBrush x:Key="Gray600" Color="#475569"/>
        <SolidColorBrush x:Key="Gray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="Gray900" Color="#0F172A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray500}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TableCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource Gray800}"/>
            <Setter Property="Padding" Value="8,14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Gray50}">
        <!-- MAIN EMPLOYEE VIEW -->
        <Grid Visibility="{Binding IsMainView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TIÊU ĐỀ TRANG -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Tiêu đề -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Background="{StaticResource LightBlue}" CornerRadius="12" Width="44" Height="44" Margin="0,0,14,0">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Quản lý nhân viên" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                        <TextBlock Text="Danh sách nhân viên trong hệ thống" FontSize="12" Foreground="{StaticResource Gray400}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Quản lý chức vụ -->
                <Button Grid.Column="1" Command="{Binding OpenChucVuViewCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE779;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Quản lý chức vụ" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray50}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Nút Thêm -->
                <Button Grid.Column="3" Command="{Binding CreateNhanVienCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" CornerRadius="10" Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#5B6AFF" Offset="0"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Direction="270" Color="#5B6AFF" Opacity="0.2"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Thêm nhân viên" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- THẺ THỐNG KÊ -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF2FF" BorderBrush="#C7D2FE" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Tổng nhân viên" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource LightBlue}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Person24" FontSize="14" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding TongSo}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource Gray900}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Đang làm việc" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource SuccessGreenLight}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Edit24" FontSize="16" Foreground="{StaticResource SuccessGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountDangLamViec}" FontSize="32" FontWeight="Bold" Foreground="#059669"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1.5" MinHeight="110" Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Đã nghỉ việc" FontSize="12" Foreground="{StaticResource Gray500}"/>
                            <Border Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="32" Height="32" HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding CountDaNghiViec}" FontSize="32" FontWeight="Bold" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Tìm kiếm & FILTERS -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Hộp Tìm kiếm -->
                    <Border Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1" CornerRadius="10" Padding="12,10" HorizontalAlignment="Left" Width="300" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1"
                                        Text="Tìm kiếm nhân viên..."
                                        FontSize="14" Foreground="{StaticResource Gray400}"
                                        Padding="4,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="SearchTextBox" Grid.Column="1"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Background="Transparent" FontSize="14" Padding="0" VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Filters row: Tình trạng + Chức vụ -->
                    <WrapPanel Orientation="Horizontal">
                        <!-- Tình trạng -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,32,8">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Tình trạng:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <CheckBox Content="Đang làm việc" IsChecked="{Binding FilterDangLamViec}" Margin="0,0,16,0" FontSize="13"/>
                            <CheckBox Content="Đã nghỉ việc" IsChecked="{Binding FilterDaNghiViec}" FontSize="13"/>
                        </StackPanel>

                        <!-- Chức vụ -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray500}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Chức vụ:" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <ItemsControl ItemsSource="{Binding ChucVuFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding ChucVu.TenChucVu}" 
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,12,4" FontSize="13"
                                                  Command="{Binding DataContext.ApplyChucVuFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Bảng Dữ liệu -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề Bảng -->
                    <Border Grid.Row="0" Background="{StaticResource Gray50}" CornerRadius="16,16,0,0" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.5*"/>
                                <ColumnDefinition Width="0.7*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="0.7*"/>
                                <ColumnDefinition Width="0.7*"/>
                                <ColumnDefinition Width="0.7*"/>
                                <ColumnDefinition Width="0.6*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Tên nhân viên" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="Hình ảnh" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="Ngày sinh" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="Địa chỉ" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="Số điện thoại" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="5" Text="Email" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="6" Text="Chức vụ" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="7" Text="Tài khoản" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="8" Text="Trạng thái" Style="{StaticResource TableHeaderStyle}"/>
                            <TextBlock Grid.Column="9" Text="Thao tác" Style="{StaticResource TableHeaderStyle}"/>
                        </Grid>
                    </Border>

                    <!-- Bảng Nội dung -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding NhanViens}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}" BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="White"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Gray50}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.5*"/>
                                                <ColumnDefinition Width="0.7*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="0.8*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="0.7*"/>
                                                <ColumnDefinition Width="0.7*"/>
                                                <ColumnDefinition Width="0.7*"/>
                                                <ColumnDefinition Width="0.6*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding HoTen}" Style="{StaticResource TableCellStyle}" FontWeight="SemiBold" TextAlignment="Left"/>

                                            <!-- Avatar -->
                                            <Border Grid.Column="1" Width="40" Height="40" CornerRadius="20" 
                                                    Background="{StaticResource Gray200}" Margin="4" HorizontalAlignment="Center">
                                                <Border CornerRadius="20" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding HinhAnh, Converter={StaticResource ImagePathConverter}}" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                            </Border>

                                            <TextBlock Grid.Column="2" Text="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding DiaChi}" Style="{StaticResource TableCellStyle}" TextAlignment="Left"/>
                                            <TextBlock Grid.Column="4" Text="{Binding SDT}" Style="{StaticResource TableCellStyle}"/>
                                            <TextBlock Grid.Column="5" Text="{Binding Email}" Style="{StaticResource TableCellStyle}" TextAlignment="Left" FontSize="11"/>
                                            <TextBlock Grid.Column="6" Text="{Binding ChucVu.TenChucVu}" Style="{StaticResource TableCellStyle}"/>

                                            <!-- Account -->
                                            <StackPanel Grid.Column="7" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Có tài khoản: hiện username dạng nút bấm được để sửa -->
                                                <Button Command="{Binding DataContext.OpenAccountDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"
                                                        Visibility="{Binding TaiKhoan, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="6" Padding="8,4">
                                                                <TextBlock Text="{Binding TaiKhoan.Username}" FontSize="11" Foreground="{StaticResource PrimaryBlue}" FontWeight="Medium"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <!-- Chưa có tài khoản: hiện nút thiết lập -->
                                                <Button Command="{Binding DataContext.OpenAccountDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" Cursor="Hand"
                                                        Visibility="{Binding TaiKhoan, Converter={StaticResource NullToVisibilityInverseConverter}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="6" Padding="8,4">
                                                                <TextBlock Text="Thiết lập" FontSize="11" Foreground="{StaticResource PrimaryBlue}" FontWeight="Medium"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>

                                            <!-- Thẻ Trạng thái -->
                                            <Border Grid.Column="8" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    CornerRadius="12" Padding="10,5">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Đang làm việc"/>
                                                            <Setter Property="Foreground" Value="#059669"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding TrangThai}" Value="False">
                                                                    <Setter Property="Text" Value="Đã nghỉ việc"/>
                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- Nút Hành động -->
                                            <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Command="{Binding DataContext.EditNhanVienCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="Chỉnh sửa" Cursor="Hand" Margin="0,0,6,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource LightBlue}" CornerRadius="8" Width="30" Height="30">
                                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#DCE0FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <Button Command="{Binding DataContext.ToggleStatusCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" ToolTip="Đổi trạng thái" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="btnBorder" Background="{StaticResource DangerRedLight}" CornerRadius="8" Width="30" Height="30">
                                                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{StaticResource DangerRed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="btnBorder" Property="Background" Value="#FEE2E2"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Trạng thái Trống -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding NhanViens.Count, Converter={StaticResource IntToVisibilityConverter}}">
                        <Border Background="{StaticResource LightBlue}" CornerRadius="50" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="{StaticResource PrimaryBlue}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Không có nhân viên nào" FontSize="16" Foreground="{StaticResource Gray400}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Thêm nhân viên mới để bắt đầu" FontSize="13" Foreground="{StaticResource Gray300}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- CHUCVU VIEW -->
        <Grid Visibility="{Binding IsChucVuView, Converter={StaticResource BoolToVisibilityConverter}}" Margin="30,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tiêu đề -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding BackToMainViewCommand}" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{StaticResource Gray100}" CornerRadius="10" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Gray600}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Quay lại" FontSize="14" Foreground="{StaticResource Gray600}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
